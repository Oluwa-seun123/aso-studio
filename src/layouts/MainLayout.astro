---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "ASO Creative Studio — AI-Powered Creative Agency",
  description = "ASO Creative Studio crafts AI videos, brand graphics, web experiences, and automation systems for forward-thinking brands. Nigeria-based. Working worldwide.",
  image = "/og-image.jpg",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#c9a227" />
    <meta name="robots" content="index, follow" />

    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />

    <style is:global>
      /* Global high-performance scroll transitions - completely detaches from CSS Keyframe bugs */
      .animate-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: opacity, transform;
      }
      .animate-on-scroll.is-revealed {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        
        /* 1. Bulletproof Mobile Menu Toggle Logic */
        const originalMenuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (originalMenuToggle && mobileMenu) {
          // Clone node to entirely obliterate any prior hidden event bindings that cause Astro double-fire bugs
          const menuToggle = originalMenuToggle.cloneNode(true);
          originalMenuToggle.parentNode.replaceChild(menuToggle, originalMenuToggle);
          
          menuToggle.addEventListener('click', (e) => {
            e.preventDefault();
            const isOpen = menuToggle.classList.contains('menu-is-open');
            
            if (!isOpen) {
              menuToggle.classList.add('menu-is-open');
              mobileMenu.classList.remove('hidden');
              document.body.classList.add('overflow-hidden');
            } else {
              menuToggle.classList.remove('menu-is-open');
              mobileMenu.classList.add('hidden');
              document.body.classList.remove('overflow-hidden');
            }
          });
        }

        /* 2. High-Performance IntersectionObserver (Fade-Ups) */
        const revealOptions = {
          root: null,
          rootMargin: "0px 0px -10% 0px", // Trigger slightly before element is fully in view
          threshold: 0
        };

        const scrollObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Defer class addition to next frame rendering cycle to prevent layout trashing
              requestAnimationFrame(() => {
                entry.target.classList.add('is-revealed');
              });
              observer.unobserve(entry.target);
            }
          });
        }, revealOptions);

        document.querySelectorAll('.animate-on-scroll').forEach(el => {
          scrollObserver.observe(el);
        });

        /* 3. Number Counters Animation */
        const counterObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const targetStr = entry.target.getAttribute('data-target');
              if (!targetStr) return;
              
              const target = +targetStr;
              const duration = 2000; 
              const increment = target / (duration / 16);
              
              let current = 0;
              const updateCounter = () => {
                current += increment;
                if (current < target) {
                  entry.target.innerHTML = Math.ceil(current).toString();
                  requestAnimationFrame(updateCounter);
                } else {
                  entry.target.innerHTML = target.toString();
                }
              };
              updateCounter();
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });

        document.querySelectorAll('.counter').forEach(counter => {
          counterObserver.observe(counter);
        });
      });
    </script>
  </body>
</html>
