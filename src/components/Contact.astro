---
import SectionLabel from './ui/SectionLabel.astro';
---

<section id="contact" class="reveal-section py-[120px] bg-aso-surface/50">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- LEFT: Info -->
      <div>
        <SectionLabel number="07" text="Get In Touch" />

        <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl text-aso-text mb-6">
          Let's Create Something <span class="gradient-text">Extraordinary</span>
        </h2>
        <p class="text-aso-text-secondary leading-relaxed mb-10">
          Have a project in mind? I'd love to hear about it. Whether you need AI videos,
          graphics, a new website, or automation — let's make it happen.
        </p>

        <!-- Contact info -->
        <div class="space-y-6 mb-10">

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Email</div>
              <a href="mailto:samuelaina683@gmail.com" class="text-aso-text hover:text-aso-gold transition-colors duration-200">
                samuelaina683@gmail.com
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Location</div>
              <div class="text-aso-text">Nigeria &middot; Available Worldwide</div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Response Time</div>
              <div class="text-aso-text">Within 24 hours</div>
            </div>
          </div>

        </div>

        <!-- Social icons with REAL platform SVGs — always visible, no CDN dependency -->
        <div class="mb-3">
          <p class="text-xs font-mono text-aso-text-muted uppercase tracking-widest mb-4">Find me on</p>
          <div class="flex items-center gap-3">

            <!-- Twitter / X -->
            <a href="https://twitter.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
              title="Twitter / X"
              class="group w-11 h-11 rounded-xl bg-aso-black border border-aso-border flex flex-col items-center justify-center gap-1 no-underline transition-all duration-300 hover:border-aso-gold hover:bg-aso-gold/5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-aso-text-secondary group-hover:text-aso-gold transition-colors">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span style="font-size:8px; letter-spacing:0.05em;" class="text-aso-text-muted group-hover:text-aso-gold transition-colors font-mono uppercase">X</span>
            </a>

            <!-- Instagram -->
            <a href="https://instagram.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
              title="Instagram"
              class="group w-11 h-11 rounded-xl bg-aso-black border border-aso-border flex flex-col items-center justify-center gap-1 no-underline transition-all duration-300 hover:border-aso-gold hover:bg-aso-gold/5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-aso-text-secondary group-hover:text-aso-gold transition-colors">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
              <span style="font-size:8px; letter-spacing:0.05em;" class="text-aso-text-muted group-hover:text-aso-gold transition-colors font-mono uppercase">IG</span>
            </a>

            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/samuel-aina-150391390" target="_blank" rel="noopener noreferrer"
              title="LinkedIn"
              class="group w-11 h-11 rounded-xl bg-aso-black border border-aso-border flex flex-col items-center justify-center gap-1 no-underline transition-all duration-300 hover:border-aso-gold hover:bg-aso-gold/5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-aso-text-secondary group-hover:text-aso-gold transition-colors">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              <span style="font-size:8px; letter-spacing:0.05em;" class="text-aso-text-muted group-hover:text-aso-gold transition-colors font-mono uppercase">in</span>
            </a>

            <!-- Dribbble -->
            <a href="https://dribbble.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
              title="Dribbble"
              class="group w-11 h-11 rounded-xl bg-aso-black border border-aso-border flex flex-col items-center justify-center gap-1 no-underline transition-all duration-300 hover:border-aso-gold hover:bg-aso-gold/5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-aso-text-secondary group-hover:text-aso-gold transition-colors">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/>
              </svg>
              <span style="font-size:8px; letter-spacing:0.05em;" class="text-aso-text-muted group-hover:text-aso-gold transition-colors font-mono uppercase">Drbl</span>
            </a>

            <!-- WhatsApp (bonus — common for Nigerian clients) -->
            <a href="https://wa.me/2348105594722" target="_blank" rel="noopener noreferrer"
              title="WhatsApp"
              class="group w-11 h-11 rounded-xl bg-aso-black border border-aso-border flex flex-col items-center justify-center gap-1 no-underline transition-all duration-300 hover:border-aso-gold hover:bg-aso-gold/5"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-aso-text-secondary group-hover:text-aso-gold transition-colors">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              <span style="font-size:8px; letter-spacing:0.05em;" class="text-aso-text-muted group-hover:text-aso-gold transition-colors font-mono uppercase">WA</span>
            </a>

          </div>
        </div>

        <!-- Calendly -->
        <div class="mt-10 p-6 rounded-2xl bg-aso-black border border-aso-border">
          <div class="flex items-center gap-3 mb-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span class="font-heading font-medium text-aso-text">Prefer to book a call?</span>
          </div>
          <p class="text-sm text-aso-text-secondary mb-4">
            Schedule a free 30-minute discovery call to discuss your project.
          </p>
          <a
            href="https://calendly.com/samuelaina683/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-aso-gold/10 border border-aso-gold/30 text-aso-gold text-sm font-heading font-medium no-underline hover:bg-aso-gold hover:text-aso-black transition-all duration-300"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/>
            </svg>
            Book a Free Call
          </a>
        </div>

      </div>

      <!-- RIGHT: Form -->
      <div class="bg-aso-black border border-aso-border rounded-2xl p-8">
        <h3 class="font-heading font-bold text-xl text-aso-text mb-1">Send a Message</h3>
        <p class="text-sm text-aso-text-muted mb-8">I'll respond within 24 hours.</p>

        <form id="contact-form" novalidate>
          <div class="space-y-5">

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-name">Name *</label>
              <input id="c-name" name="name" type="text"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors"
                placeholder="Your full name" />
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-email">Email *</label>
              <input id="c-email" name="email" type="email"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors"
                placeholder="your@email.com" />
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-service">Service *</label>
              <select id="c-service" name="service"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text focus:border-aso-gold focus:outline-none transition-colors cursor-pointer">
                <option value="" disabled selected>Select a service</option>
                <option value="AI Video">AI Video Creation</option>
                <option value="Graphics">Graphic Design</option>
                <option value="Web Dev">Web Development</option>
                <option value="AI Automation">AI Automation</option>
                <option value="Multiple">Multiple Services</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-message">Message *</label>
              <textarea id="c-message" name="message" rows="4"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors resize-none"
                placeholder="Tell me about your project..."></textarea>
            </div>

            <button id="c-submit" type="button"
              class="w-full flex items-center justify-center gap-2.5 px-8 py-4 rounded-full bg-aso-gold text-aso-black font-heading font-semibold text-base border-none cursor-pointer transition-all duration-300 hover:gold-glow-strong transform hover:-translate-y-0.5">
              <span id="c-btn-idle" class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
                Send Message
              </span>
              <span id="c-btn-busy" style="display:none;" class="flex items-center gap-2">
                <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Sending...
              </span>
            </button>

          </div>
        </form>

        <div id="c-success" style="display:none;" class="mt-4 p-4 rounded-xl bg-green-500/10 border border-green-500/30 text-green-400 text-sm flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Message sent! I'll respond within 24 hours.
        </div>

        <div id="c-error" style="display:none;" class="mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          Something went wrong. Please try again or email me directly.
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var FORMSPREE = 'https://formspree.io/f/meedjqgv';
  var SHEET_URL = 'https://script.google.com/macros/s/AKfycbzshACmsl7qo0mmquRhyNLAqVSvMIob6YS6P9CC2HF_Vk9LI6I3NRNsEMnbw2d15mS5ag/exec';

  var btnSubmit = document.getElementById('c-submit');
  var btnIdle   = document.getElementById('c-btn-idle');
  var btnBusy   = document.getElementById('c-btn-busy');
  var msgOk     = document.getElementById('c-success');
  var msgErr    = document.getElementById('c-error');
  var submitting = false;

  function setLoading(on) {
    submitting            = on;
    btnSubmit.disabled    = on;
    btnIdle.style.display = on ? 'none' : 'flex';
    btnBusy.style.display = on ? 'flex' : 'none';
  }

  function showMsg(ok) {
    msgOk.style.display  = ok ? 'flex' : 'none';
    msgErr.style.display = ok ? 'none' : 'flex';
  }

  function logToSheet(data) {
    try {
      fetch(SHEET_URL, {
        method:  'POST',
        mode:    'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          timestamp: new Date().toISOString(),
          name:    data.name,
          email:   data.email,
          service: data.service,
          message: data.message,
          status:  'New'
        })
      });
    } catch (e) {}
  }

  btnSubmit.addEventListener('click', function () {
    if (submitting) return;

    var name    = document.getElementById('c-name').value.trim();
    var email   = document.getElementById('c-email').value.trim();
    var service = document.getElementById('c-service').value;
    var message = document.getElementById('c-message').value.trim();

    if (!name || !email || !service || !message) {
      alert('Please fill in all fields before sending.');
      return;
    }
    if (email.indexOf('@') < 1) {
      alert('Please enter a valid email address.');
      return;
    }

    msgOk.style.display  = 'none';
    msgErr.style.display = 'none';
    setLoading(true);

    var payload = { name: name, email: email, service: service, message: message };

    fetch(FORMSPREE, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      if (data.ok || data.next) {
        showMsg(true);
        document.getElementById('contact-form').reset();
        logToSheet(payload);
      } else {
        showMsg(false);
      }
    })
    .catch(function () { showMsg(false); })
    .then(function () { setLoading(false); });
  });
})();
</script>
