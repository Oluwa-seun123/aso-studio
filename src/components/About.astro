---
// About.astro
---

<section id="about" class="relative py-[120px] bg-aso-black overflow-hidden">

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-px bg-gradient-to-r from-transparent via-aso-gold/30 to-transparent pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-16">
      <span class="font-label text-[11px] tracking-[0.35em] uppercase text-aso-gold">06 / About Me</span>
      <div class="w-16 h-px bg-gradient-to-r from-aso-gold to-transparent"></div>
    </div>

    <!-- Split layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- LEFT: Photo -->
      <div class="relative">

        <!-- Photo container with decorative borders -->
        <div class="relative pr-8 pb-8">
          <!-- Gold offset borders -->
          <div class="absolute top-4 right-4 w-full h-full rounded-2xl border border-aso-gold/25 pointer-events-none z-0"></div>
          <div class="absolute top-8 right-0 w-full h-full rounded-2xl border border-aso-gold/10 pointer-events-none z-0"></div>

          <!-- Photo area -->
          <div class="relative z-10 rounded-2xl overflow-hidden border border-aso-border bg-aso-elevated" style="aspect-ratio: 4/5;">
            <!-- Replace the div below with <img src="/images/samuel.jpg" ...> when ready -->
            <img
              src="/images/samuel.jpg"
              alt="Samuel Aina — ASO Creative Studio"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <!-- Fallback placeholder -->
            <div class="w-full h-full flex-col items-center justify-center gap-4 bg-gradient-to-br from-aso-elevated to-aso-surface hidden">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-aso-gold to-aso-gold-glow flex items-center justify-center font-heading font-bold text-2xl text-aso-black">
                ASO
              </div>
              <p class="font-label text-[11px] tracking-[0.2em] uppercase text-aso-text-muted text-center px-6">
                Add your photo to<br/>/public/images/samuel.jpg
              </p>
            </div>
          </div>

          <!-- Availability badge overlay -->
          <div class="absolute -bottom-4 -right-4 z-20 bg-aso-surface border border-aso-border rounded-xl px-4 py-3 flex items-center gap-2.5 shadow-xl">
            <span class="w-2.5 h-2.5 rounded-full bg-aso-green pulse-green flex-shrink-0"></span>
            <span class="font-label text-[11px] tracking-wide text-aso-text-muted">Available for work</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Text -->
      <div>
        <!-- Headline -->
        <h2 class="font-heading font-bold mb-7" style="font-size: clamp(2rem, 3.5vw, 3rem); line-height: 1.1;">
          Hi, I'm <span class="gradient-text">Samuel Aina</span>
        </h2>

        <!-- Bio -->
        <div class="prose-aso mb-8">
          <p>
            I'm the founder of <strong class="text-aso-text font-semibold">ASO Creative Studio</strong> — a one-person creative powerhouse built at the intersection of AI, design, and technology. I started ASO because I believe every brand, no matter the size, deserves world-class creative work.
          </p>
          <p>
            My passion sits at the crossroads of <strong class="text-aso-text font-semibold">AI video production</strong>, premium brand design, and intelligent automation. I don't just create visuals — I build systems and experiences that drive real results.
          </p>
          <p>
            Based in <strong class="text-aso-text font-semibold">Nigeria</strong>, working with clients across 5 countries and counting. Whether you're a startup finding your voice or an established brand ready to evolve — I'm the creative partner you need.
          </p>
        </div>

        <!-- Inline stats -->
        <div class="grid grid-cols-3 gap-px bg-aso-border rounded-2xl overflow-hidden mb-8">
          <div class="flex flex-col items-center text-center py-5 px-4 bg-aso-elevated">
            <span class="font-heading font-bold text-3xl gradient-text">50+</span>
            <span class="font-label text-[10px] tracking-[0.15em] uppercase text-aso-text-muted mt-1">Projects</span>
          </div>
          <div class="flex flex-col items-center text-center py-5 px-4 bg-aso-elevated">
            <span class="font-heading font-bold text-3xl gradient-text">3+</span>
            <span class="font-label text-[10px] tracking-[0.15em] uppercase text-aso-text-muted mt-1">Years</span>
          </div>
          <div class="flex flex-col items-center text-center py-5 px-4 bg-aso-elevated">
            <span class="font-heading font-bold text-3xl gradient-text">100%</span>
            <span class="font-label text-[10px] tracking-[0.15em] uppercase text-aso-text-muted mt-1">Remote</span>
          </div>
        </div>

        <!-- Resume CTA -->
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full border border-aso-gold bg-transparent text-aso-gold font-heading font-semibold no-underline transition-all duration-300 hover:bg-aso-gold/10 hover:shadow-[0_0_24px_rgba(201,162,39,0.2)]"
          style="font-size: 15px;"
        >
          Download Resume
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </a>

      </div>
    </div>
  </div>
</section>
