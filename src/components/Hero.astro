---
// Hero.astro
---

<section
  id="hero"
  style="position:relative; min-height:100vh; display:flex; flex-direction:column; justify-content:center; overflow:hidden;"
>

  <!-- Background -->
  <div style="position:absolute; inset:0; z-index:0;">
    <div style="position:absolute; inset:0; background:#050505;"></div>
    <div style="position:absolute; top:-20%; left:-10%; width:600px; height:600px; border-radius:50%; background:radial-gradient(circle,#c9a227 0%,transparent 70%); filter:blur(80px); opacity:0.18;" class="orb"></div>
    <div style="position:absolute; bottom:-20%; right:-10%; width:500px; height:500px; border-radius:50%; background:radial-gradient(circle,#f59e0b 0%,transparent 70%); filter:blur(100px); opacity:0.13;" class="orb"></div>
    <div style="position:absolute; top:40%; right:20%; width:300px; height:300px; border-radius:50%; background:radial-gradient(circle,#c9a227 0%,transparent 70%); filter:blur(60px); opacity:0.08;" class="orb"></div>
    <div style="position:absolute; inset:0; opacity:0.04; background-image:radial-gradient(circle,#a1a1aa 1px,transparent 1px); background-size:32px 32px;"></div>
    <div style="position:absolute; inset:0; background:radial-gradient(ellipse at center,transparent 40%,#050505 100%);"></div>
  </div>

  <!-- Content -->
  <div style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:128px 2.5rem 80px;">
    <div style="max-width:900px;">

      <!-- Availability Badge -->
      <div
        id="hero-badge"
        style="opacity:0; transform:translateY(32px); display:inline-flex; align-items:center; gap:10px; padding:8px 16px; border-radius:9999px; border:1px solid rgba(201,162,39,0.3); background:rgba(201,162,39,0.06); margin-bottom:32px;"
      >
        <span style="position:relative; display:flex; width:8px; height:8px;">
          <span style="position:absolute; display:inline-flex; width:100%; height:100%; border-radius:50%; background:#22c55e; opacity:0.75; animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite;"></span>
          <span style="position:relative; display:inline-flex; width:8px; height:8px; border-radius:50%; background:#22c55e;"></span>
        </span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; color:#c9a227;">
          Available for freelance work
        </span>
      </div>

      <!-- Headline -->
      <h1 style="font-family:'Space Grotesk',sans-serif; font-weight:700; line-height:1.05; margin-bottom:24px;">
        <span
          id="hero-line-1"
          style="opacity:0; transform:translateY(32px); display:block; color:#fafafa; font-size:clamp(3rem,8vw,7rem);"
        >
          AI-Powered
        </span>
        <span
          id="hero-line-2"
          style="opacity:0; transform:translateY(32px); display:block; font-size:clamp(3rem,8vw,7rem); background:linear-gradient(135deg,#c9a227 0%,#f59e0b 50%,#c9a227 100%); background-size:200% auto; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:shimmer 3s linear infinite;"
        >
          Creative Studio
        </span>
      </h1>

      <!-- Subtitle -->
      <p
        id="hero-sub"
        style="opacity:0; transform:translateY(32px); font-family:'Inter',sans-serif; color:#a1a1aa; line-height:1.7; margin-bottom:40px; max-width:680px; font-size:clamp(1.05rem,2vw,1.25rem);"
      >
        From cinematic AI videos and premium brand graphics to full web
        experiences and intelligent automation — everything your brand needs
        to dominate in the <strong style="color:#fafafa; font-weight:500;">AI era.</strong>
      </p>

      <!-- CTAs -->
      <div
        id="hero-ctas"
        style="opacity:0; transform:translateY(32px); display:flex; flex-wrap:wrap; align-items:center; gap:16px; margin-bottom:56px;"
      >
        <a href="#work" id="hero-btn-primary">View My Work →</a>
        <a href="#contact" id="hero-btn-outline">Start a Project ↗</a>
      </div>

      <!-- Social Proof -->
      <div
        id="hero-social"
        style="opacity:0; transform:translateY(32px); display:flex; align-items:center; gap:12px; flex-wrap:wrap;"
      >
        <div style="display:flex;">
          <div style="width:32px; height:32px; border-radius:50%; background:#c9a227; border:2px solid #050505; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:#050505; margin-right:-8px; z-index:4;">A</div>
          <div style="width:32px; height:32px; border-radius:50%; background:#6366f1; border:2px solid #050505; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:#fff; margin-right:-8px; z-index:3;">B</div>
          <div style="width:32px; height:32px; border-radius:50%; background:#ec4899; border:2px solid #050505; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:#fff; margin-right:-8px; z-index:2;">C</div>
          <div style="width:32px; height:32px; border-radius:50%; background:#14b8a6; border:2px solid #050505; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:#fff; z-index:1;">D</div>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
          <span style="color:#c9a227; font-size:14px;">★★★★★</span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#52525b; letter-spacing:0.05em;">
            Trusted by brands worldwide &nbsp;•&nbsp; 100% Remote
          </span>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll chevron -->
  <div style="position:absolute; bottom:32px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:6px;">
    <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.25em; text-transform:uppercase; color:#52525b;">Scroll</span>
    <span style="color:#52525b; animation:chevronBounce 2s ease-in-out infinite;">&#8964;</span>
  </div>

</section>

<style>
  /* ── Hero CTA Buttons ── */
  #hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #050505;
    text-decoration: none;
    box-shadow: 0 0 24px rgba(201,162,39,0.35);
    transition: all 0.3s ease;
  }
  #hero-btn-primary:hover {
    box-shadow: 0 0 40px rgba(245,158,11,0.55);
    transform: translateY(-2px);
  }

  #hero-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 9999px;
    border: 1px solid #27272a;
    background: transparent;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #fafafa;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  #hero-btn-outline:hover {
    border-color: #c9a227;
    color: #c9a227;
  }

  /* ── Orb animations ── */
  .orb:nth-child(1) { animation: float1 8s ease-in-out infinite; }
  .orb:nth-child(2) { animation: float2 10s ease-in-out infinite; }
  .orb:nth-child(3) { animation: float3 12s ease-in-out infinite; }

  @keyframes float1 {
    0%,100% { transform:translate(0,0) scale(1); }
    50%      { transform:translate(20px,30px) scale(1.05); }
  }
  @keyframes float2 {
    0%,100% { transform:translate(0,0) scale(1); }
    50%      { transform:translate(-25px,-20px) scale(1.08); }
  }
  @keyframes float3 {
    0%,100% { transform:translate(0,0) scale(1); }
    50%      { transform:translate(15px,-25px) scale(1.03); }
  }

  @keyframes ping {
    75%,100% { transform:scale(2); opacity:0; }
  }

  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  @keyframes chevronBounce {
    0%,100% { transform:translateY(0);  opacity:0.4; }
    50%      { transform:translateY(6px); opacity:0.9; }
  }
</style>

<script>
  window.addEventListener("load", () => {
    if (typeof gsap === "undefined") return;
    const tl = gsap.timeline({ delay: 0.3 });
    tl.to("#hero-badge",   { opacity:1, y:0, duration:0.6, ease:"power3.out" })
      .to("#hero-line-1",  { opacity:1, y:0, duration:0.65, ease:"power3.out" }, "-=0.3")
      .to("#hero-line-2",  { opacity:1, y:0, duration:0.65, ease:"power3.out" }, "-=0.45")
      .to("#hero-sub",     { opacity:1, y:0, duration:0.6,  ease:"power3.out" }, "-=0.35")
      .to("#hero-ctas",    { opacity:1, y:0, duration:0.55, ease:"power3.out" }, "-=0.3")
      .to("#hero-social",  { opacity:1, y:0, duration:0.5,  ease:"power3.out" }, "-=0.25");
  });
</script>