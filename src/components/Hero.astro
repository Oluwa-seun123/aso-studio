---
// src/components/Hero.astro
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-aso-black"
>
  <!-- Grid Layer -->
  <div class="absolute inset-0 hero-grid opacity-100 pointer-events-none"></div>

  <!-- Ambient Glow Elements -->
  <div 
    class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%)", filter: "blur(60px)" }}
  >
  </div>

  <div 
    class="absolute -bottom-40 -right-20 w-[500px] h-[500px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%)", filter: "blur(80px)" }}
  >
  </div>

  <!-- Main Content Wrapper -->
  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-10 pt-32 pb-24">
    <div class="max-w-4xl">

      <!-- Status Tag -->
      <div class="animate-on-scroll inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-aso-gold/30 bg-aso-gold/5 mb-8">
        <span class="relative flex w-2.5 h-2.5">
          <span class="pulse-green absolute inline-flex w-full h-full rounded-full bg-aso-green opacity-75"></span>
          <span class="relative inline-flex w-2.5 h-2.5 rounded-full bg-aso-green"></span>
        </span>
        <span class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-gold">
          Available for freelance work
        </span>
      </div>

      <!-- Main Typography Stack -->
      <h1 class="font-heading font-bold leading-[1.05] mb-6">
        <span 
          class="animate-on-scroll block text-aso-text" 
          style={{ fontSize: "clamp(3rem, 8vw, 7rem)", transitionDelay: "100ms" }}
        >
          AI-Powered
        </span>
        <span 
          class="animate-on-scroll block shimmer-gold" 
          style={{ fontSize: "clamp(3rem, 8vw, 7rem)", transitionDelay: "200ms" }}
        >
          Creative Studio
        </span>
      </h1>

      <p 
        class="animate-on-scroll font-body text-aso-text-secondary leading-relaxed mb-10 max-w-2xl text-balance"
        style={{ fontSize: "clamp(1.05rem, 2vw, 1.25rem)", transitionDelay: "300ms" }}
      >
        From cinematic AI videos and premium brand graphics to full web experiences
        and intelligent automation — everything your brand needs to stand out in the
        <strong class="text-aso-text font-medium">AI era.</strong>
      </p>

      <!-- Call To Actions -->
      <div 
        class="animate-on-scroll flex flex-wrap items-center gap-4 mb-14" 
        style={{ transitionDelay: "400ms" }}
      >
        <a
          href="#work"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full bg-gradient-to-br from-aso-gold to-aso-gold-glow font-heading font-semibold text-aso-black no-underline gold-glow transition-all duration-300 hover:scale-105"
          style={{ fontSize: "15px" }}
        >
          View My Work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full border border-aso-text/20 bg-transparent font-heading font-semibold text-aso-text no-underline transition-all duration-300 hover:border-aso-gold hover:text-aso-gold"
          style={{ fontSize: "15px" }}
        >
          Start a Project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </a>
      </div>

      <!-- Trust Badges & Performance Metrics -->
      <div 
        class="animate-on-scroll flex flex-col md:flex-row md:items-center gap-8 md:gap-12" 
        style={{ transitionDelay: "500ms" }}
      >
        <div class="flex items-center gap-3 flex-wrap">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-aso-gold border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-aso-black z-[4]">A</div>
            <div class="w-8 h-8 rounded-full bg-indigo-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[3]">B</div>
            <div class="w-8 h-8 rounded-full bg-pink-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[2]">C</div>
            <div class="w-8 h-8 rounded-full bg-teal-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[1]">D</div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-aso-gold text-sm">★★★★★</span>
            <span class="font-label text-xs text-aso-text-muted tracking-wide">
              Trusted Worldwide
            </span>
          </div>
        </div>

        <div class="flex items-center gap-8 border-l-0 md:border-l border-aso-border/50 pl-0 md:pl-8">
          <div>
            <h3 class="text-2xl font-heading font-bold text-aso-text">
              <span class="counter" data-target="50">0</span>+
            </h3>
            <p class="text-aso-text-muted font-label text-[10px] uppercase tracking-wider mt-1">Projects</p>
          </div>
          <div>
            <h3 class="text-2xl font-heading font-bold text-aso-text">
              <span class="counter" data-target="3">0</span>+
            </h3>
            <p class="text-aso-text-muted font-label text-[10px] uppercase tracking-wider mt-1">Years Exp.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Downward Indicator -->
  <div 
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-on-scroll" 
    style={{ transitionDelay: "600ms" }}
  >
    <span class="font-label text-[10px] tracking-[0.25em] uppercase text-aso-text-muted">Scroll</span>
    <span class="text-aso-text-muted chevron-bounce text-xl">⌄</span>
  </div>
</section>
    <span class="text-aso-text-muted chevron-bounce text-xl">⌄</span>
  </div>
</section>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .animate-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (function() {
    if (window._heroEnginesInitialized) return;
    window._heroEnginesInitialized = true;

    /** 
     * ENGINE 1: Scroll Animation & Viewport Failsafe
     */
    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          window.requestAnimationFrame(() => {
            entry.target.classList.add('is-revealed');
          });
          scrollObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    const animatedElements = document.querySelectorAll('.animate-on-scroll');
    
    animatedElements.forEach(el => {
      scrollObserver.observe(el);
      
      // Viewport Failsafe Post-Mount Initialization
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom >= 0) {
        window.requestAnimationFrame(() => {
          el.classList.add('is-revealed');
        });
        scrollObserver.unobserve(el);
      }
    });

    /** 
     * ENGINE 2: High-Precision Counter Interpolation
     */
    const DURATION_MS = 2000;
    
    // Strict Ease-Out Cubic function
    const easeOutCubic = (x) => 1 - Math.pow(1 - x, 3);

    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const targetValue = parseFloat(el.getAttribute('data-target')) || 0;
          let startTimestamp = null;

          const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.max(0, Math.min((timestamp - startTimestamp) / DURATION_MS, 1));
            
            const easedProgress = easeOutCubic(progress);
            el.textContent = Math.floor(easedProgress * targetValue);

            if (progress < 1) {
              window.requestAnimationFrame(step);
            } else {
              el.textContent = targetValue; // Force clamp to precise target
            }
          };

          window.requestAnimationFrame(step);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.counter').forEach(counter => {
      counterObserver.observe(counter);
    });
  })();
</script>
