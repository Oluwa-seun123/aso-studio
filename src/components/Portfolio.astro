---
// src/components/Portfolio.astro

const driveLinkPlaceholder = "https://drive.google.com/drive/folders/placeholder-link";

const portfolioItems = [
  {
    id: "ai-video",
    category: "AI Video",
    title: "Cinematic AI Video Production & Direction",
    image: null,
    link: driveLinkPlaceholder,
  },
  {
    id: "graphics-design",
    category: "Graphics Design",
    title: "Premium Church Graphics & Visual Identity Systems",
    image: "/images/1000611783.jpg",
    link: driveLinkPlaceholder,
  },
  {
    id: "web-dev",
    category: "Web Dev",
    title: "High-Performance Creative Digital Platforms",
    image: "/images/1000611848.jpg",
    link: driveLinkPlaceholder,
  },
  {
    id: "automation",
    category: "Automation",
    title: "AI Workflow Systems & Agency Automation",
    image: null,
    link: driveLinkPlaceholder,
  }
];

const categories = ["All", "AI Video", "Graphics Design", "Web Dev", "Automation"];
---

<section id="work" class="relative w-full bg-[#050505] text-[#fafafa] py-32 px-6 lg:px-12 overflow-hidden flex flex-col items-center">
  
  <!-- Ambient Background Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#c9a227]/5 rounded-[100%] blur-[120px] pointer-events-none"></div>

  <div class="w-full max-w-7xl relative z-10">
    <!-- Header Architecture -->
    <header class="mb-20 w-full">
      <!-- Glowing Top Border & Index -->
      <div class="flex items-center w-full mb-12">
        <span class="text-[#c9a227] font-mono text-sm tracking-widest mr-6 shrink-0">04 / PORTFOLIO</span>
        <div class="h-[1px] w-full bg-gradient-to-r from-[#c9a227]/50 via-[#c9a227]/10 to-transparent shadow-[0_-2px_10px_rgba(201,162,39,0.2)]"></div>
      </div>
      
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-none">
          Selected <br/> <span class="text-[#c9a227]">Masterpieces</span>
        </h2>
        <p class="max-w-md text-right text-gray-400 text-sm md:text-base leading-relaxed">
          A curated collection of elite digital craftsmanship. From visual identity systems to high-performance creative platforms and cinematic AI direction.
        </p>
      </div>
    </header>

    <!-- Filter Controls -->
    <nav class="flex flex-wrap gap-3 mb-16" aria-label="Portfolio Filters">
      {categories.map((category, index) => (
        <button 
          class={`filter-btn px-6 py-2.5 rounded-full text-sm font-medium tracking-wide transition-all duration-300 border ${
            index === 0 
              ? 'bg-[#c9a227] text-[#050505] border-[#c9a227]' 
              : 'bg-transparent text-gray-300 border-gray-800 hover:border-[#c9a227]/50 hover:text-[#c9a227]'
          }`}
          data-filter={category}
        >
          {category}
        </button>
      ))}
    </nav>

    <!-- Grid Architecture -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 min-h-[50vh]" id="portfolio-grid">
      {portfolioItems.map((item) => (
        <article 
          class="portfolio-card animate-on-scroll group relative rounded-lg overflow-hidden bg-[#0a0a0a] border border-gray-900 card-hover flex flex-col"
          data-category={item.category}
        >
          <!-- Visual Slot (16/10 Aspect Ratio) -->
          <div class="relative w-full aspect-[16/10] overflow-hidden bg-[#0d0d0d] flex items-center justify-center">
            {item.image ? (
              <img 
                src={item.image} 
                alt={item.title} 
                loading="lazy" 
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            ) : (
              item.category === "AI Video" ? (
                // AI Video Placeholder SVG
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#050505] to-[#111]">
                  <svg class="w-24 h-24 text-[#c9a227]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    <circle cx="9" cy="12" r="2" stroke="currentColor" />
                  </svg>
                </div>
              ) : (
                // Automation Placeholder SVG
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#050505] to-[#111]">
                  <svg class="w-24 h-24 text-[#c9a227]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                  </svg>
                </div>
              )
            )}
            
            <!-- Hover Overlay -->
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center z-10">
              <a 
                href={item.link} 
                target="_blank" 
                rel="noopener noreferrer"
                class="px-8 py-4 bg-transparent border border-[#c9a227] text-[#c9a227] hover:bg-[#c9a227] hover:text-[#050505] transition-colors duration-300 font-mono text-sm uppercase tracking-widest flex items-center gap-2 translate-y-4 group-hover:translate-y-0"
              >
                View Project Files
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>

          <!-- Card Meta Data -->
          <div class="p-6 flex-grow flex flex-col justify-between border-t border-gray-900 relative z-20 bg-[#0a0a0a]">
            <span class="text-[#c9a227] font-mono text-xs tracking-wider uppercase mb-3 block">{item.category}</span>
            <h3 class="text-xl md:text-2xl font-bold leading-snug tracking-tight text-white group-hover:text-[#c9a227] transition-colors duration-300">
              {item.title}
            </h3>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty State -->
    <div id="portfolio-empty" class="filter-hidden w-full py-20 flex flex-col items-center justify-center text-center border border-dashed border-gray-800 rounded-lg">
      <svg class="w-12 h-12 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
      <h3 class="text-xl font-bold text-gray-300">No Projects Found</h3>
      <p class="text-gray-500 mt-2">Adjust your filters to see more of our portfolio.</p>
    </div>

    <!-- Footer Redirect CTA -->
    <div class="mt-24 w-full flex justify-center">
      <a 
        href={driveLinkPlaceholder} 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative px-10 py-5 overflow-hidden border border-[#c9a227] text-[#c9a227] uppercase font-bold tracking-[0.2em] transition-all duration-300 hover:text-[#050505]"
      >
        <span class="absolute inset-0 w-full h-full bg-[#c9a227] transform -translate-x-full transition-transform duration-500 ease-out group-hover:translate-x-0 z-0"></span>
        <span class="relative z-10 flex items-center gap-3">
          Explore Production Catalog
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </span>
      </a>
    </div>

  </div>
</section>

<style>
  @import "tailwindcss";

  /* 
    Tailwind v4 strict compatibility rules:
    NO @layer base, @layer components, or @layer utilities.
    Pure vanilla CSS mapped natively.
  */

  .card-hover {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
  }
  
  .card-hover:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px -12px rgba(201, 162, 39, 0.15);
  }

  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Utility for JS filtering to prevent display layout issues */
  .filter-hidden {
    display: none !important;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const portfolioCards = document.querySelectorAll('.portfolio-card');
    const emptyState = document.getElementById('portfolio-empty');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filterValue = button.getAttribute('data-filter');

        // 1. Manage Active Button States (Vanilla class toggling)
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');
          btn.classList.add('bg-transparent', 'text-gray-300', 'border-gray-800');
        });
        
        button.classList.remove('bg-transparent', 'text-gray-300', 'border-gray-800');
        button.classList.add('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');

        // 2. Filter Grid Items
        let visibleCount = 0;
        
        portfolioCards.forEach(card => {
          const category = card.getAttribute('data-category');
          
          if (filterValue === 'All' || filterValue === category) {
            card.classList.remove('filter-hidden');
            // Trigger a quick reflow for animation if needed
            void card.offsetWidth; 
            visibleCount++;
          } else {
            card.classList.add('filter-hidden');
          }
        });

        // 3. Handle Empty State Container
        if (visibleCount === 0) {
          emptyState.classList.remove('filter-hidden');
        } else {
          emptyState.classList.add('filter-hidden');
        }
      });
    });
  });
</script>
