---
// src/components/Portfolio.astro

// Define clean data structures with explicit typing implicit to the array map
const categories = ["All", "AI Video", "Branding", "Web Apps"];

const projects = [
  {
    title: "Cinematic Sci-Fi Short",
    category: "AI Video",
    image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=800&q=80",
    link: "#",
    tags: ["Runway Gen-3", "Midjourney", "Premiere"]
  },
  {
    title: "Neo-Finance Brand Identity",
    category: "Branding",
    image: "https://images.unsplash.com/photo-1634017839464-5c339ebe3cb4?auto=format&fit=crop&w=800&q=80",
    link: "#",
    tags: ["Vector Design", "3D Assets", "Guidelines"]
  },
  {
    title: "Automation SaaS Dashboard",
    category: "Web Apps",
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
    link: "#",
    tags: ["Astro", "Tailwind v4", "FastAPI"]
  }
];
---

<section id="work" class="relative py-24 bg-aso-black overflow-hidden border-t border-aso-border/30">
  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-10">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16">
      <h2 class="animate-on-scroll text-4xl md:text-5xl font-heading font-bold text-aso-text mb-4">
        Selected Works
      </h2>
      <p class="animate-on-scroll text-aso-text-secondary font-body text-lg max-w-xl">
        Explore our latest experiments and high-end client productions engineered at the intersection of AI and design.
      </p>
    </div>

    <!-- Category Filter Bar -->
    <div class="animate-on-scroll flex flex-wrap gap-2.5 mb-12" id="portfolio-filters">
      {categories.map((category) => (
        <button
          data-filter={category.toLowerCase().replace(/\s+/g, '-')}
          class="portfolio-filter-btn px-5 py-2 rounded-full border border-aso-text/10 bg-aso-white/5 font-label text-xs uppercase tracking-wider text-aso-text-secondary transition-all hover:border-aso-gold hover:text-aso-text active"
        >
          {category}
        </button>
      ))}
    </div>

    <!-- Master Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="portfolio-grid">
      {projects.map((project) => (
        <div 
          data-category={project.category.toLowerCase().replace(/\s+/g, '-')}
          class="portfolio-item animate-on-scroll group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-aso-border/40 bg-gradient-to-b from-aso-white/5 to-transparent p-4 transition-all duration-300 hover:border-aso-gold/30 hover:shadow-[0_12px_40px_rgba(201,162,39,0.05)]"
        >
          <div>
            <div class="relative aspect-video w-full overflow-hidden rounded-xl mb-5">
              <img 
                src={project.image} 
                alt={project.title}
                class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-aso-black/80 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 flex items-end p-4">
                <span class="font-label text-[10px] uppercase tracking-widest text-aso-gold bg-aso-black/60 px-2.5 py-1 rounded-md backdrop-blur-sm">
                  {project.category}
                </span>
              </div>
            </div>

            <h3 class="text-xl font-heading font-semibold text-aso-text mb-2 transition-colors group-hover:text-aso-gold">
              {project.title}
            </h3>

            <!-- Tags Sub-Loop -->
            <div class="flex flex-wrap gap-1.5 mb-6">
              {project.tags.map((tag) => (
                <span class="font-label text-[10px] text-aso-text-muted border border-aso-text/10 px-2 py-0.5 rounded">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <a 
            href={project.link}
            class="inline-flex items-center gap-2 font-heading text-sm font-medium text-aso-text no-underline transition-colors group-hover:text-aso-gold-glow mt-2"
          >
            Explore Case Study
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"/>
              <polyline points="7 7 17 7 17 17"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  (function() {
    if (window._portfolioEngineInitialized) return;
    window._portfolioEngineInitialized = true;

    const filterButtons = document.querySelectorAll('.portfolio-filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    if (filterButtons.length === 0 || portfolioItems.length === 0) return;

    // Set 'All' filter as structurally active on mount
    filterButtons[0].classList.add('border-aso-gold', 'text-aso-text');
    filterButtons[0].classList.remove('text-aso-text-secondary');

    filterButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        
        const targetFilter = button.getAttribute('data-filter');

        // Update active class typography states
        filterButtons.forEach(btn => {
          btn.classList.remove('border-aso-gold', 'text-aso-text');
          btn.classList.add('text-aso-text-secondary');
        });
        button.classList.add('border-aso-gold', 'text-aso-text');
        button.classList.remove('text-aso-text-secondary');

        // Filter calculation grid loop
        portfolioItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category');
          
          if (targetFilter === 'all' || itemCategory === targetFilter) {
            window.requestAnimationFrame(() => {
              item.style.display = 'flex';
              setTimeout(() => { item.style.opacity = '1'; }, 10);
            });
          } else {
            window.requestAnimationFrame(() => {
              item.style.opacity = '0';
              item.style.display = 'none';
            });
          }
        });
      });
    });
  })();
</script>
</section>

<style>
  @import "tailwindcss";

  .card-hover {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
  }
  
  .card-hover:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px -12px rgba(201, 162, 39, 0.15);
  }

  /* Utility for JS filtering to prevent display layout issues */
  .filter-hidden {
    display: none !important;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const portfolioCards = document.querySelectorAll('.portfolio-card');
    const emptyState = document.getElementById('portfolio-empty');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filterValue = button.getAttribute('data-filter');

        // 1. Manage Active Button States (Vanilla class toggling)
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');
          btn.classList.add('bg-transparent', 'text-gray-300', 'border-gray-800');
        });
        
        button.classList.remove('bg-transparent', 'text-gray-300', 'border-gray-800');
        button.classList.add('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');

        // 2. Filter Grid Items
        let visibleCount = 0;
        
        portfolioCards.forEach(card => {
          const category = card.getAttribute('data-category');
          
          if (filterValue === 'All' || filterValue === category) {
            card.classList.remove('filter-hidden');
            // Trigger a quick reflow for animation if needed
            void card.offsetWidth; 
            visibleCount++;
          } else {
            card.classList.add('filter-hidden');
          }
        });

        // 3. Handle Empty State Container
        if (visibleCount === 0) {
          emptyState.classList.remove('filter-hidden');
        } else {
          emptyState.classList.add('filter-hidden');
        }
      });
    });
  });
</script>
