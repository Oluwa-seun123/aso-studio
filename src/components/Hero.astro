---
// Hero.astro
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-aso-black"
>
  <div class="absolute inset-0 hero-grid opacity-100 pointer-events-none"></div>

  <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%); filter: blur(60px);">
  </div>

  <div class="absolute -bottom-40 -right-20 w-[500px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%); filter: blur(80px);">
  </div>

  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-10 pt-32 pb-24 w-full">
    <div class="max-w-4xl">

      <div class="fade-up inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-aso-gold/30 bg-aso-gold/5 mb-8">
        <span class="relative flex w-2.5 h-2.5">
          <span class="pulse-green absolute inline-flex w-full h-full rounded-full bg-aso-green opacity-75"></span>
          <span class="relative inline-flex w-2.5 h-2.5 rounded-full bg-aso-green"></span>
        </span>
        <span class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-gold">
          Available for freelance work
        </span>
      </div>

      <h1 class="font-heading font-bold leading-[1.05] mb-6">
        <span class="fade-up fade-up-2 block text-aso-text" style="font-size: clamp(3rem, 8vw, 7rem);">
          AI-Powered
        </span>
        <span class="fade-up fade-up-3 block shimmer-gold" style="font-size: clamp(3rem, 8vw, 7rem);">
          Creative Studio
        </span>
      </h1>

      <p class="fade-up fade-up-3 font-body text-aso-text-secondary leading-relaxed mb-10 max-w-2xl text-balance"
        style="font-size: clamp(1.05rem, 2vw, 1.25rem);">
        From cinematic AI videos and premium brand graphics to full web experiences
        and intelligent automation — everything your brand needs to stand out in the
        <strong class="text-aso-text font-medium">AI era.</strong>
      </p>

      <div class="fade-up fade-up-4 flex flex-wrap items-center gap-4 mb-14">
        <a
          href="#work"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full bg-gradient-to-br from-aso-gold to-aso-gold-glow font-heading font-semibold text-aso-black no-underline gold-glow transition-all duration-300 hover:scale-105"
          style="font-size: 15px;"
        >
          View My Work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full border border-aso-text/20 bg-transparent font-heading font-semibold text-aso-text no-underline transition-all duration-300 hover:border-aso-gold hover:text-aso-gold"
          style="font-size: 15px;"
        >
          Start a Project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </a>
      </div>

      <div class="fade-up fade-up-5 flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
        <div class="flex items-center gap-3 flex-wrap">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-aso-gold border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-aso-black z-[4]">A</div>
            <div class="w-8 h-8 rounded-full bg-indigo-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[3]">B</div>
            <div class="w-8 h-8 rounded-full bg-pink-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[2]">C</div>
            <div class="w-8 h-8 rounded-full bg-teal-500 border-2 border-aso-black flex items-center justify-center font-label text-[10px] font-bold text-white z-[1]">D</div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-aso-gold text-sm">★★★★★</span>
            <span class="font-label text-xs text-aso-text-muted tracking-wide">
              Trusted Worldwide &nbsp;•&nbsp; 100% Remote
            </span>
          </div>
        </div>

        <div class="flex items-center gap-8 border-l-0 md:border-l border-aso-border/50 pl-0 md:pl-8">
          <div>
            <h3 class="text-2xl font-heading font-bold text-aso-text">
              <span class="counter" data-target="50">0</span>+
            </h3>
            <p class="text-aso-text-muted font-label text-[10px] uppercase tracking-wider mt-1">Projects Completed</p>
          </div>
          <div>
            <h3 class="text-2xl font-heading font-bold text-aso-text">
              <span class="counter" data-target="3">0</span>+
            </h3>
            <p class="text-aso-text-muted font-label text-[10px] uppercase tracking-wider mt-1">Years Experience</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 fade-up fade-up-5">
    <span class="font-label text-[10px] tracking-[0.25em] uppercase text-aso-text-muted">Scroll</span>
    <span class="text-aso-text-muted chevron-bounce text-xl">⌄</span>
  </div>

</section>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
      
      <!-- Secondary Action CTA -->
      <a href="#work" class="inline-flex items-center justify-center px-8 py-4 border border-aso-gold/30 text-aso-text bg-transparent hover:bg-aso-gold/5 font-label font-bold rounded-full transition-colors">
        Explore Work
      </a>
    </div>

    <!-- Social Proof / Trust Signature Block -->
    <div class="pt-8 border-t border-aso-gold/10 flex flex-col sm:flex-row items-start sm:items-center gap-6" style={{ transitionDelay: "500ms" }}>
      
      <!-- Overlapping Avatar Cluster -->
      <div class="flex -space-x-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-800 text-aso-text font-label text-sm font-bold z-10">TR</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-700 text-aso-text font-label text-sm font-bold z-20">AL</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-600 text-aso-text font-label text-sm font-bold z-30">MK</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-aso-gold text-aso-black font-label text-sm font-bold z-40">50+</div>
      </div>

      <!-- Trust Copy & Star Graphics -->
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-1">
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <span class="font-body text-sm text-aso-text-muted tracking-wide">
          Trusted by worldwide leading brands
        </span>
      </div>
    </div>
    
  </div>
</section>
