---
// Footer.astro
---

<<footer class="relative bg-background border-t border-border py-10">
  
  <div class="max-w-site mx-auto px-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <!-- LEFT: Logo -->
      <a href="/" class="flex items-center gap-3 no-underline">
        <div class="w-9 h-9 rounded-lg bg-gold-gradient flex items-center justify-center font-heading font-bold text-xs tracking-widest text-background shrink-0">
          ASO
        </div>
        <span class="font-heading font-semibold text-sm text-secondary tracking-wide">
          Creative Studio
        </span>
      </a>

      <!-- CENTER: Copyright -->
      <p class="font-label text-xs text-muted tracking-widest text-center">
        © 2026 ASO Creative Studio. All rights reserved.
      </p>

      <!-- RIGHT: Back to top -->
      <button 
        id="back-to-top" 
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-border bg-transparent text-secondary font-heading font-medium text-sm cursor-pointer transition-all duration-300 hover:border-gold hover:text-gold hover:bg-gold hover:bg-opacity-5"
        aria-label="Back to top"
      >
        Back to top ↑
      </button>

    </div>
  </div>
</footer>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
