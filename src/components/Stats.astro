---
// Stats.astro
---

<section id="stats" class="reveal-section bg-aso-surface border-y border-aso-border py-16 lg:py-20">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 stagger-container">

      <div class="stagger-item text-center">
        <div
          class="stat-number font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-gold"
          data-target="50"
          data-suffix="+"
        >0+</div>
        <div class="mt-2 text-aso-text-secondary text-sm sm:text-base font-medium">Projects Completed</div>
      </div>

      <div class="stagger-item text-center">
        <div
          class="stat-number font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-gold"
          data-target="30"
          data-suffix="+"
        >0+</div>
        <div class="mt-2 text-aso-text-secondary text-sm sm:text-base font-medium">Happy Clients</div>
      </div>

      <div class="stagger-item text-center">
        <div
          class="stat-number font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-gold"
          data-target="5"
          data-suffix=""
        >0</div>
        <div class="mt-2 text-aso-text-secondary text-sm sm:text-base font-medium">Countries Served</div>
      </div>

      <div class="stagger-item text-center">
        <div
          class="stat-number font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-gold"
          data-target="3"
          data-suffix="+"
        >0+</div>
        <div class="mt-2 text-aso-text-secondary text-sm sm:text-base font-medium">Years Experience</div>
      </div>

    </div>
  </div>
</section>
