---
const navLinks = [
  { name: "Work",     href: "#work"     },
  { name: "Services", href: "#services" },
  { name: "Process",  href: "#process"  },
  { name: "About",    href: "#about"    },
  { name: "Contact",  href: "#contact"  },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-[72px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline group">
        <div class="w-10 h-10 rounded-[10px] bg-gradient-to-br from-aso-gold to-aso-gold-glow flex items-center justify-center font-bold text-lg text-aso-black">
          ASO
        </div>
        <div class="hidden sm:flex flex-col leading-none">
          <span class="font-heading font-semibold text-[15px] text-aso-text group-hover:text-aso-gold transition-colors">Creative Studio</span>
          <span class="font-mono text-[10px] text-aso-text-muted tracking-[0.2em] uppercase mt-0.5">AI · Design · Web</span>
        </div>
      </a>

      <!-- Desktop Links -->
      <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
        {navLinks.map((link) => (
          <li>
            <a 
              href={link.href} 
              class="relative text-aso-text-secondary hover:text-aso-text text-sm font-medium transition-colors group"
            >
              {link.name}
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-aso-gold transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop Right -->
      <div class="hidden md:flex items-center gap-3">
        <button 
          id="theme-toggle" 
          class="w-9 h-9 rounded-full border border-aso-border flex items-center justify-center text-aso-text-secondary hover:text-aso-gold hover:border-aso-gold transition-all"
          aria-label="Toggle theme"
        >
          <span id="theme-icon">🌙</span>
        </button>
        <a 
          href="#contact" 
          class="px-5 py-2.5 bg-aso-gold text-aso-black text-sm font-medium rounded-full hover:bg-aso-gold-glow transition-colors"
        >
          Start a Project
        </a>
      </div>

      <!-- Hamburger -->
      <button 
        id="mobile-menu-btn" 
        class="md:hidden w-10 h-10 rounded-full border border-aso-border flex flex-col items-center justify-center gap-1.5 text-aso-text hover:text-aso-gold hover:border-aso-gold transition-all"
        aria-label="Open menu"
      >
        <span class="block w-5 h-0.5 bg-current rounded-full transition-all duration-300 origin-center" id="ham-1"></span>
        <span class="block w-5 h-0.5 bg-current rounded-full transition-all duration-300 origin-center" id="ham-2"></span>
        <span class="block w-3 h-0.5 bg-current rounded-full transition-all duration-300 origin-center" id="ham-3"></span>
      </button>

    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div 
  id="mobile-menu" 
  class="fixed inset-0 z-40 bg-aso-black/95 backdrop-blur-xl flex-col items-center justify-center gap-8 hidden"
>
  <button 
    id="mobile-close" 
    class="absolute top-6 right-6 w-10 h-10 rounded-full border border-aso-border flex items-center justify-center text-aso-text hover:text-aso-gold hover:border-aso-gold transition-all text-xl"
  >
    ✕
  </button>
  <ul class="flex flex-col items-center gap-6 list-none m-0 p-0">
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class="mobile-link text-2xl font-heading font-medium text-aso-text hover:text-aso-gold transition-colors">
          {link.name}
        </a>
      </li>
    ))}
  </ul>
  <a 
    href="#contact" 
    class="mobile-link mt-4 px-6 py-3 bg-aso-gold text-aso-black font-medium rounded-full hover:bg-aso-gold-glow transition-colors"
  >
    Start a Project
  </a>
</div>

<script is:inline>
  var menuBtn    = document.getElementById('mobile-menu-btn');
  var closeBtn   = document.getElementById('mobile-close');
  var mobileMenu = document.getElementById('mobile-menu');
  var mobileLinks = document.querySelectorAll('.mobile-link');
  var ham1 = document.getElementById('ham-1');
  var ham2 = document.getElementById('ham-2');
  var ham3 = document.getElementById('ham-3');

  function openMenu() {
    if (mobileMenu) {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      document.body.style.overflow = 'hidden';
      if (ham1) ham1.style.transform = 'rotate(45deg) translateY(6px)';
      if (ham2) ham2.style.opacity = '0';
      if (ham3) { ham3.style.width = '20px'; ham3.style.transform = 'rotate(-45deg) translateY(-6px)'; }
    }
  }

  function closeMenu() {
    if (mobileMenu) {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      document.body.style.overflow = '';
      if (ham1) ham1.style.transform = '';
      if (ham2) ham2.style.opacity = '1';
      if (ham3) { ham3.style.width = '12px'; ham3.style.transform = ''; }
    }
  }

  if (menuBtn) menuBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  mobileLinks.forEach(function(link) {
    link.addEventListener('click', closeMenu);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });

  // Nav scroll effect
  var mainNav = document.getElementById('main-nav');
  window.addEventListener('scroll', function() {
    if (!mainNav) return;
    if (window.scrollY > 80) {
      mainNav.classList.add('bg-aso-black/80', 'backdrop-blur-xl', 'border-b', 'border-aso-border');
    } else {
      mainNav.classList.remove('bg-aso-black/80', 'backdrop-blur-xl', 'border-b', 'border-aso-border');
    }
  }, { passive: true });

  // Theme toggle
  var themeBtn = document.getElementById('theme-toggle');
  var themeIcon = document.getElementById('theme-icon');

  function getSavedTheme() {
    try {
      return localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    } catch(e) {
      return 'dark';
    }
  }

  function applyTheme(theme) {
    var html = document.documentElement;
    if (theme === 'dark') {
      html.removeAttribute('data-theme');
      if (themeIcon) themeIcon.textContent = '🌙';
    } else {
      html.setAttribute('data-theme', 'light');
      if (themeIcon) themeIcon.textContent = '☀️';
    }
  }

  var currentTheme = getSavedTheme();
  applyTheme(currentTheme);

  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      var next = currentTheme === 'dark' ? 'light' : 'dark';
      currentTheme = next;
      try { localStorage.setItem('theme', next); } catch(e) {}
      applyTheme(next);
    });
  }
</script>