---
// src/components/Hero.astro
---

<section id="hero" class="hero-section">
  <!-- Grid Background Layer -->
  <div class="hero-grid-bg hero-grid"></div>

  <!-- Ambient Glow Elements -->
  <div class="glow-top-left"></div>
  <div class="glow-bottom-right"></div>

  <!-- Main Content Layout Grid -->
  <div class="hero-container">
    <div class="hero-content-max">

      <!-- Availability Indicator Tag -->
      <div class="status-badge animate-on-scroll">
        <span class="pulse-wrapper">
          <span class="pulse-bg"></span>
          <span class="pulse-dot"></span>
        </span>
        <span class="status-text">
          Available for freelance work
        </span>
      </div>

      <!-- Typography Header Stack -->
      <h1 class="hero-heading">
        <span class="animate-on-scroll title-line-1">
          AI-Powered
        </span>
        <span class="animate-on-scroll shimmer-gold title-line-2">
          Creative Studio
        </span>
      </h1>

      <!-- Value Proposition Paragraph -->
      <p class="animate-on-scroll hero-description">
        From cinematic AI videos and premium brand graphics to full web experiences
        and intelligent automation — everything your brand needs to stand out in the
        <strong class="hero-bold-text">AI era.</strong>
      </p>

      <!-- Interactive Call to Action Anchors -->
      <div class="animate-on-scroll cta-group">
        <a href="#work" class="btn-primary">
          View My Work
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#contact" class="btn-secondary">
          Start a Project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </a>
      </div>

      <!-- Trust Metrics & Counter Display Grid -->
      <div class="animate-on-scroll metrics-row">
        <div class="avatar-group-container">
          <div class="avatar-stack">
            <div class="avatar av-1">A</div>
            <div class="avatar av-2">B</div>
            <div class="avatar av-3">C</div>
            <div class="avatar av-4">D</div>
          </div>
          <div class="rating-block">
            <span class="stars">★★★★★</span>
            <span class="rating-text">Trusted Worldwide</span>
          </div>
        </div>

        <div class="counter-separator">
          <div class="counter-item">
            <h3 class="counter-number">
              <span class="counter" data-target="50">0</span>+
            </h3>
            <p class="counter-label">Projects</p>
          </div>
          <div class="counter-item">
            <h3 class="counter-number">
              <span class="counter" data-target="3">0</span>+
            </h3>
            <p class="counter-label">Years Exp.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Micro-interaction Scroll Track Arrow -->
  <div class="scroll-indicator-block animate-on-scroll">
    <span class="scroll-indicator-text">Scroll</span>
    <span class="scroll-indicator-chevron">⌄</span>
  </div>
</section>

<!-- COMPILER SAFEGUARD STYLING ENGINE -->
<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background-color: #0a0a0a;
  }
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    opacity: 1;
    pointer-events: none;
  }
  .glow-top-left {
    position: absolute;
    top: -10rem;
    left: -10rem;
    width: 600px;
    height: 600px;
    border-radius: 9999px;
    pointer-events: none;
    background: radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%);
    filter: blur(60px);
  }
  .glow-bottom-right {
    position: absolute;
    bottom: -10rem;
    right: -5rem;
    width: 500px;
    height: 500px;
    border-radius: 9999px;
    pointer-events: none;
    background: radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%);
    filter: blur(80px);
  }
  .hero-container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: 8rem;
    padding-bottom: 6rem;
  }
  @media (min-width: 1024px) {
    .hero-container {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }
  .hero-content-max {
    max-width: 56rem;
  }
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding-left: 1rem;
    padding-right: 1rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(201,162,39,0.3);
    background-color: rgba(201,162,39,0.05);
    margin-bottom: 2rem;
  }
  .pulse-wrapper {
    position: relative;
    display: flex;
    width: 0.625rem;
    height: 0.625rem;
  }
  .pulse-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    background-color: #10b981;
    opacity: 0.75;
  }
  .pulse-dot {
    position: relative;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background-color: #10b981;
  }
  .status-text {
    font-family: var(--font-label, sans-serif);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c9a227;
  }
  .hero-heading {
    font-family: var(--font-heading, sans-serif);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }
  .title-line-1 {
    display: block;
    color: #ffffff;
    font-size: clamp(3rem, 8vw, 7rem);
    transition-delay: 100ms;
  }
  .title-line-2 {
    display: block;
    font-size: clamp(3rem, 8vw, 7rem);
    transition-delay: 200ms;
  }
  .hero-description {
    font-family: var(--font-body, sans-serif);
    color: #a3a3a3;
    line-height: 1.625;
    margin-bottom: 2.5rem;
    max-width: 42rem;
    text-wrap: balance;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    transition-delay: 300ms;
  }
  .hero-bold-text {
    color: #ffffff;
    font-weight: 500;
  }
  .cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3.5rem;
    transition-delay: 400ms;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    background: linear-gradient(to bottom right, #c9a227, #f59e0b);
    font-family: var(--font-heading, sans-serif);
    font-weight: 600;
    color: #0a0a0a;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 15px;
  }
  .btn-primary:hover {
    transform: scale(1.05);
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background-color: transparent;
    font-family: var(--font-heading, sans-serif);
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 15px;
  }
  .btn-secondary:hover {
    border-color: #c9a227;
    color: #c9a227;
  }
  .metrics-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    transition-delay: 500ms;
  }
  @media (min-width: 768px) {
    .metrics-row {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
  }
  .avatar-group-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .avatar-stack {
    display: flex;
    margin-left: 0.5rem;
  }
  .avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 2px solid #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-label, sans-serif);
    font-size: 10px;
    font-weight: 700;
    margin-left: -0.5rem;
  }
  .av-1 { background-color: #c9a227; color: #0a0a0a; z-index: 4; }
  .av-2 { background-color: #6366f1; color: #ffffff; z-index: 3; }
  .av-3 { background-color: #ec4899; color: #ffffff; z-index: 2; }
  .av-4 { background-color: #14b8a6; color: #ffffff; z-index: 1; }
  .rating-block {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .stars { color: #c9a227; font-size: 0.875rem; }
  .rating-text {
    font-family: var(--font-label, sans-serif);
    font-size: 12px;
    color: #737373;
    letter-spacing: 0.025em;
  }
  .counter-separator {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-left: 0;
    border-left: 0;
  }
  @media (min-width: 768px) {
    .counter-separator {
      border-left: 1px solid rgba(38, 38, 38, 0.5);
      padding-left: 2rem;
    }
  }
  .counter-number {
    font-size: 1.5rem;
    font-family: var(--font-heading, sans-serif);
    font-weight: 700;
    color: #ffffff;
  }
  .counter-label {
    color: #737373;
    font-family: var(--font-label, sans-serif);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
  .scroll-indicator-block {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition-delay: 600ms;
  }
  .scroll-indicator-text {
    font-family: var(--font-label, sans-serif);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #737373;
  }
  .scroll-indicator-chevron {
    color: #737373;
    font-size: 1.25rem;
  }
</style>
