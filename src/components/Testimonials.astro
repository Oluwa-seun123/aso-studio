---
import SectionLabel from './ui/SectionLabel.astro';

var testimonials = [
  {
    initials:    'VA',
    name:        'Victoria Abiodun',
    role:        'Founder',
    company:     'VeeLuxe',
    avatarStyle: 'background:rgba(201,162,39,0.15);border:1.5px solid rgba(201,162,39,0.4);color:#c9a227;',
    accentColor: 'rgba(201,162,39,0.4)',
    quote:       'The whole process felt easy and well thought out. They really understood our vision and brought it to life through clean, modern graphics that feel true to our brand.',
  },
  {
    initials:    'MA',
    name:        'Morountodun Aládé',
    role:        'CEO',
    company:     'Cuticles & Co.',
    avatarStyle: 'background:rgba(244,114,182,0.15);border:1.5px solid rgba(244,114,182,0.4);color:#f472b6;',
    accentColor: 'rgba(244,114,182,0.4)',
    quote:       'Clean and intentional designs. He does not just create designs; he brings brands to life through creativity and attention to detail.',
  },
  {
    initials:    'AW',
    name:        'Awele',
    role:        'Founder',
    company:     "Awele's Fresh Fix",
    avatarStyle: 'background:rgba(45,212,191,0.15);border:1.5px solid rgba(45,212,191,0.4);color:#2dd4bf;',
    accentColor: 'rgba(45,212,191,0.4)',
    quote:       'Samuel built Awele\'s Fresh Fix exactly how I envisioned it. The ordering flow is seamless, the design is beautiful, and the admin dashboard makes managing everything effortless. My customers keep complimenting how easy the site is to use.',
  },
];
---

<section id="testimonials" class="reveal-section py-[120px] bg-aso-surface/30">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="05" text="Testimonials" />

    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-16">
      What Clients <span class="gradient-text">Say</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-container">
      {testimonials.map(function(t) {
        return (
          <div class="stagger-item relative bg-aso-black border border-aso-border rounded-2xl p-8 hover:border-aso-gold/50 transition-all duration-500 flex flex-col group">

            <!-- Quote icon -->
            <div class="mb-6 text-aso-gold/40 group-hover:text-aso-gold/60 transition-colors duration-300">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/>
                <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
              </svg>
            </div>

            <!-- Stars -->
            <div class="flex gap-1 mb-5">
              <span class="text-aso-gold">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            </div>

            <!-- Quote -->
            <p class="text-aso-text-secondary leading-relaxed mb-8 flex-1" style="font-size:15px;">
              &ldquo;{t.quote}&rdquo;
            </p>

            <!-- Divider -->
            <div class="h-px bg-aso-border mb-6"></div>

            <!-- Author -->
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 rounded-full flex items-center justify-center font-heading font-semibold text-sm flex-shrink-0"
                style={t.avatarStyle}
              >
                {t.initials}
              </div>
              <div>
                <div class="font-heading font-medium text-aso-text">{t.name}</div>
                <div class="text-sm text-aso-text-muted">{t.role}, {t.company}</div>
              </div>
            </div>

            <!-- Bottom accent line -->
            <div
              class="absolute bottom-0 left-8 right-8 h-px opacity-40"
              style={"background:linear-gradient(90deg," + t.accentColor + ",transparent);"}
            ></div>

          </div>
        );
      })}
    </div>

  </div>
</section>
