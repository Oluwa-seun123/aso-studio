---
import ProjectCard  from './ProjectCard.astro';
import SectionLabel from './ui/SectionLabel.astro';

var projects = [
  {
    slug:        'ai-brand-video',
    title:       'AI Brand Campaign Video',
    description: 'A cinematic AI-generated brand campaign video featuring dynamic AI scenes, custom color grading, and professional post-production storytelling for a luxury fashion brand.',
    category:    'AI Video',
    image:       '/images/1000613254.jpg',
    link:        '#',
    client:      'VeeLuxe',
  },
  {
    slug:        'chatbot-automation',
    title:       'Customer Support Chatbot',
    description: 'Built and deployed an AI-powered customer support chatbot with automated email sequences and CRM integration, cutting response time by 80%.',
    category:    'AI Automation',
    image:       '/images/1000611783.jpg',
    link:        '#',
    client:      'AutoFlow Co.',
  },
  {
    slug:        'visual-asset-design',
    title:       'Visual Asset Design System',
    description: 'Structured asset packages, vector layout alignments, and presentation mockups tailored for scaling companies — brand identity, social templates, and style guides.',
    category:    'Graphics',
    image:       '/images/1000611848.jpg',
    client:      'Brand Work',
  },
  {
    slug:        'web-experience',
    title:       'Full Web Experience Build',
    description: 'Architecture-first responsive codebase with lightweight portfolio structures and polished front-end animations built for performance, SEO, and conversion.',
    category:    'Web Dev',
    image:       '/images/1000613254.jpg',
    link:        '#',
    client:      'Client Work',
  },
];

var categories = ['All', 'AI Video', 'Graphics', 'Web Dev', 'AI Automation'];
---

<section id="work" class="reveal-section py-[120px]">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="04" text="Portfolio" />

    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-4">
      My <span class="gradient-text">Works</span>
    </h2>
    <p class="text-aso-text-secondary mb-10 max-w-xl leading-relaxed">
      A selection of projects across every service. Each one built with intention.
    </p>

    <!-- Filter buttons -->
    <div class="flex flex-wrap gap-3 mb-12" id="portfolio-filters">
      {categories.map(function(cat) {
        return (
          <button
            data-filter={cat}
            class={cat === 'All'
              ? 'filter-btn px-5 py-2 rounded-full text-sm font-heading font-medium transition-all duration-300 border bg-aso-gold text-aso-black border-aso-gold'
              : 'filter-btn px-5 py-2 rounded-full text-sm font-heading font-medium transition-all duration-300 border bg-transparent text-aso-text-secondary border-aso-border hover:border-aso-gold hover:text-aso-gold'
            }
          >
            {cat}
          </button>
        );
      })}
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-container" id="projects-grid">
      {projects.map(function(project) {
        return (
          <div class="stagger-item">
            <ProjectCard
              title={project.title}
              description={project.description}
              category={project.category}
              image={project.image}
              link={project.link}
              client={project.client}
              slug={project.slug}
            />
          </div>
        );
      })}
    </div>

    <!-- Google Drive "See More Work" box -->
    <div class="mt-14 p-8 rounded-2xl border border-aso-border bg-aso-elevated text-center">
      <div class="flex items-center justify-center gap-3 mb-3">
        <!-- Google Drive icon -->
        <svg width="28" height="28" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg">
          <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da"/>
          <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z" fill="#00ac47"/>
          <path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.5l5.85 11.5z" fill="#ea4335"/>
          <path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d"/>
          <path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc"/>
          <path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 27h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00"/>
        </svg>
        <span class="font-heading font-bold text-xl text-aso-text">Want to see more work?</span>
      </div>
      <p class="text-aso-text-secondary text-sm mb-6 max-w-md mx-auto">
        Browse my complete portfolio of AI videos, graphic design projects,
        and web builds — all in one place on Google Drive.
      </p>
      <!-- REPLACE the href below with your Google Drive folder link -->
      <a
        href="YOUR_GOOGLE_DRIVE_FOLDER_LINK"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-aso-gold text-aso-black font-heading font-semibold no-underline transition-all duration-300 hover:gold-glow-strong transform hover:-translate-y-0.5"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        View Full Portfolio on Drive
      </a>
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    var filterBtns = document.querySelectorAll('.filter-btn');
    var cards       = document.querySelectorAll('.project-card');

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');

        filterBtns.forEach(function (b) {
          b.classList.remove('bg-aso-gold', 'text-aso-black', 'border-aso-gold');
          b.classList.add('bg-transparent', 'text-aso-text-secondary', 'border-aso-border');
        });
        btn.classList.remove('bg-transparent', 'text-aso-text-secondary', 'border-aso-border');
        btn.classList.add('bg-aso-gold', 'text-aso-black', 'border-aso-gold');

        cards.forEach(function (card) {
          var cat  = card.getAttribute('data-category');
          var show = filter === 'All' || cat === filter;
          if (show) {
            card.classList.remove('filter-hidden');
            if (window.gsap) {
              window.gsap.fromTo(card,
                { opacity: 0, scale: 0.95 },
                { opacity: 1, scale: 1, duration: 0.4, ease: 'power2.out' }
              );
            }
          } else {
            if (window.gsap) {
              window.gsap.to(card, {
                opacity: 0, scale: 0.95, duration: 0.3, ease: 'power2.in',
                onComplete: function () { card.classList.add('filter-hidden'); }
              });
            } else {
              card.classList.add('filter-hidden');
            }
          }
        });
      });
    });
  })();
</script>
