---
const services = [
  {
    icon: "🎬",
    number: "01",
    title: "AI Video Creation",
    tagline: "Motion that converts",
    description: "Cinematic, AI-enhanced video content that stops the scroll and drives action. From concept to final render.",
    offerings: ["Promotional Videos", "Social Media Reels", "Brand Storytelling", "Product Showcases"],
  },
  {
    icon: "🎨",
    number: "02",
    title: "Graphic Design",
    tagline: "Visuals that speak",
    description: "Premium brand visuals that communicate authority and build trust across every touchpoint your audience sees.",
    offerings: ["Business Branding", "Flyer Design", "Social Media Graphics", "Church Materials"],
  },
  {
    icon: "💻",
    number: "03",
    title: "Web Development",
    tagline: "Experiences that perform",
    description: "Fast, modern websites and web apps built to rank, convert, and scale with your business over time.",
    offerings: ["Business Websites", "E-Commerce", "Web Apps", "Landing Pages"],
  },
  {
    icon: "🤖",
    number: "04",
    title: "AI Automation",
    tagline: "Systems that scale",
    description: "Intelligent systems that eliminate repetitive work so you can focus on growing your business.",
    offerings: ["Workflow Automation", "Chatbot Setup", "Email Sequences", "CRM Integration", "Social Media Automation"],
  },
];
---

<section id="services" class="relative py-20 overflow-hidden bg-background">
  <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10">
    
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-label text-xs tracking-widest uppercase text-gold">02 / What I Do</span>
        <div class="w-16 h-px bg-gold"></div>
      </div>
      <h2 class="font-heading font-bold text-3xl md:text-5xl text-primary mb-4">My Services</h2>
      <p class="font-body text-secondary max-w-md leading-relaxed">
        A focused set of services built for modern brands that want results — not just deliverables.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {services.map((service) => (
        <article class="group relative bg-surface border border-border rounded-2xl p-8 overflow-hidden cursor-pointer transition-all duration-300 hover:border-gold hover:-translate-y-2 hover:shadow-gold">
          
          <div class="flex items-start justify-between mb-7">
            <div class="w-12 h-12 rounded-xl bg-gold bg-opacity-10 border border-gold border-opacity-20 flex items-center justify-center transition-all duration-300 group-hover:bg-opacity-15 group-hover:border-opacity-45">
              <span class="text-xl">{service.icon}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-label text-xs tracking-widest text-muted">{service.number}</span>
              <div class="w-8 h-8 rounded-full bg-gold bg-opacity-10 border border-gold border-opacity-25 flex items-center justify-center text-gold text-sm opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
                ↗
              </div>
            </div>
          </div>

          <h3 class="font-heading font-bold text-lg text-primary mb-1 transition-colors duration-200 group-hover:text-gold">{service.title}</h3>
          <p class="font-label text-xs tracking-widest uppercase text-muted mb-4">{service.tagline}</p>
          <p class="font-body text-sm text-secondary leading-relaxed mb-7">{service.description}</p>

          <div class="flex flex-wrap gap-2">
            {service.offerings.map((item) => (
              <span class="font-label text-xs tracking-wider px-3 py-1.5 rounded-full bg-white bg-opacity-5 border border-border text-secondary transition-all duration-200 group-hover:border-gold group-hover:border-opacity-20 group-hover:text-primary">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-14 flex justify-center">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gold font-heading font-semibold text-sm text-background no-underline shadow-gold transition-all duration-300 hover:shadow-gold-lg hover:-translate-y-0.5">
        Start a Project →
      </a>
    </div>

  </div>
</section>
