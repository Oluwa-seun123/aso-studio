---
// Hero.astro
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-background"></div>
    <div class="absolute -top-[20%] -left-[10%] w-[600px] h-[600px] rounded-full opacity-[0.18] blur-[80px]" style="background:radial-gradient(circle,#c9a227 0%,transparent 70%); animation:float1 8s ease-in-out infinite;"></div>
    <div class="absolute -bottom-[20%] -right-[10%] w-[500px] h-[500px] rounded-full opacity-[0.13] blur-[100px]" style="background:radial-gradient(circle,#f59e0b 0%,transparent 70%); animation:float2 10s ease-in-out infinite;"></div>
    <div class="absolute top-[40%] right-[20%] w-[300px] h-[300px] rounded-full opacity-[0.08] blur-[60px]" style="background:radial-gradient(circle,#c9a227 0%,transparent 70%); animation:float3 12s ease-in-out infinite;"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image:radial-gradient(circle,#a1a1aa 1px,transparent 1px); background-size:32px 32px;"></div>
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at center,transparent 40%,#050505 100%);"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-site mx-auto pt-32 pb-20 px-10">
    <div class="max-w-[900px]">

      <!-- Availability Badge -->
      <div
        id="hero-badge"
        class="opacity-0 translate-y-8 inline-flex items-center gap-2.5 px-4 py-2 rounded-pill border border-gold border-opacity-30 bg-gold bg-opacity-[0.06] mb-8"
      >
        <span class="relative flex w-2 h-2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-green-500 opacity-75" style="animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite;"></span>
          <span class="relative inline-flex w-2 h-2 rounded-full bg-green-500"></span>
        </span>
        <span class="font-label text-xs tracking-[0.15em] uppercase text-gold">
          Available for freelance work
        </span>
      </div>

      <!-- Headline -->
      <h1 class="font-heading font-bold leading-[1.05] mb-6">
        <span
          id="hero-line-1"
          class="opacity-0 translate-y-8 block text-primary text-display-xl"
        >
          AI-Powered
        </span>
        <span
          id="hero-line-2"
          class="opacity-0 translate-y-8 block text-display-xl bg-gold-gradient bg-[length:200%_auto] bg-clip-text text-transparent"
          style="animation:shimmer 3s linear infinite;"
        >
          Creative Studio
        </span>
      </h1>

      <!-- Subtitle -->
      <p
        id="hero-sub"
        class="opacity-0 translate-y-8 font-body text-secondary leading-relaxed mb-10 max-w-[680px] text-lg"
      >
        From cinematic AI videos and premium brand graphics to full web
        experiences and intelligent automation — everything your brand needs
        to dominate in the <strong class="text-primary font-medium">AI era.</strong>
      </p>

      <!-- CTAs -->
      <div
        id="hero-ctas"
        class="opacity-0 translate-y-8 flex flex-wrap items-center gap-4 mb-14"
      >
        <a href="#work" class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-pill bg-gold-gradient font-heading font-semibold text-[15px] text-background no-underline shadow-gold transition-all duration-300 hover:shadow-lg">
          View My Work →
        </a>
        <a href="#contact" class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-pill border border-border bg-transparent font-heading font-semibold text-[15px] text-primary no-underline transition-all duration-300 hover:bg-border hover:bg-opacity-10">
          Start a Project ↗
        </a>
      </div>

      <!-- Social Proof -->
      <div
        id="hero-social"
        class="opacity-0 translate-y-8 flex items-center gap-3 flex-wrap"
      >
        <div class="flex">
          <div class="w-8 h-8 rounded-full bg-gold border-2 border-background flex items-center justify-center text-[10px] font-bold text-background -mr-2 z-[4]">A</div>
          <div class="w-8 h-8 rounded-full bg-indigo-500 border-2 border-background flex items-center justify-center text-[10px] font-bold text-white -mr-2 z-[3]">B</div>
          <div class="w-8 h-8 rounded-full bg-pink-500 border-2 border-background flex items-center justify-center text-[10px] font-bold text-white -mr-2 z-[2]">C</div>
          <div class="w-8 h-8 rounded-full bg-teal-500 border-2 border-background flex items-center justify-center text-[10px] font-bold text-white z-[1]">D</div>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-gold text-sm">★★★★★</span>
          <span class="font-label text-xs text-muted tracking-wide">
            Trusted by brands worldwide • 100% Remote
          </span>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll chevron -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5">
    <span class="font-label text-[10px] tracking-[0.25em] uppercase text-muted">Scroll</span>
    <span class="text-muted" style="animation:chevronBounce 2s ease-in-out infinite;">&#8964;</span>
  </div>

</section>

<style is:global>
  @keyframes float1 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(20px, 30px) scale(1.05);
    }
  }

  @keyframes float2 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-25px, -20px) scale(1.08);
    }
  }

  @keyframes float3 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(15px, -25px) scale(1.03);
    }
  }

  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  @keyframes chevronBounce {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    50% {
      transform: translateY(6px);
      opacity: 0.9;
    }
  }
</style>

<script>
  window.addEventListener("load", () => {
    if (typeof gsap === "undefined") return;
    const tl = gsap.timeline({ delay: 0.3 });
    tl.to("#hero-badge", { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" })
      .to("#hero-line-1", { opacity: 1, y: 0, duration: 0.65, ease: "power3.out" }, "-=0.3")
      .to("#hero-line-2", { opacity: 1, y: 0, duration: 0.65, ease: "power3.out" }, "-=0.45")
      .to("#hero-sub", { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" }, "-=0.35")
      .to("#hero-ctas", { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.3")
      .to("#hero-social", { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" }, "-=0.25");
  });
</script>
