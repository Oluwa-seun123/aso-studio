---
const stats = [
  {
    value: 50,
    suffix: "+",
    label: "Projects Delivered",
    description: "Across AI video, graphics & web",
  },
  {
    value: 30,
    suffix: "+",
    label: "Happy Clients",
    description: "Brands, founders & agencies",
  },
  {
    value: 5,
    suffix: "",
    label: "Countries Reached",
    description: "100% remote collaboration",
  },
  {
    value: 3,
    suffix: "+",
    label: "Years of Craft",
    description: "In creative & digital work",
  },
];
---

<section
  id="stats"
  style="position:relative; padding:64px 0; border-top:1px solid #27272a; border-bottom:1px solid #27272a; background:#0f0f0f;"
  aria-label="Studio statistics"
>
  <!-- Top glow line -->
  <div
    style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:400px; height:1px; background:linear-gradient(90deg,transparent,#c9a227,transparent);"
    aria-hidden="true"
  ></div>

  <div style="max-width:1280px; margin:0 auto; padding:0 2.5rem;">

    <!-- Eyebrow -->
    <div style="display:flex; justify-content:center; margin-bottom:40px;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.3em; text-transform:uppercase; color:#52525b;">
        By the numbers
      </span>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid" role="list">
      {stats.map((stat) => (
        <div class="stat-item" role="listitem">
          <!-- Icon box -->
          <div class="stat-icon-box" aria-hidden="true">★</div>

          <!-- Counter -->
          <span
            data-count={stat.value}
            data-suffix={stat.suffix}
            class="stat-number"
            aria-label={`${stat.value}${stat.suffix} ${stat.label}`}
          >
            0{stat.suffix}
          </span>

          <!-- Label -->
          <p class="stat-label">{stat.label}</p>

          <!-- Description -->
          <p class="stat-desc">{stat.description}</p>
        </div>
      ))}
    </div>

  </div>

  <!-- Bottom glow line -->
  <div
    style="position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:400px; height:1px; background:linear-gradient(90deg,transparent,#c9a227,transparent);"
    aria-hidden="true"
  ></div>
</section>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #27272a;
    border-radius: 12px;
    overflow: hidden;
  }

  .stat-item {
    background: #0f0f0f;
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
    transition: background 0.3s ease;
  }
  .stat-item:hover { background: #111111; }

  .stat-icon-box {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(201,162,39,0.1);
    border: 1px solid rgba(201,162,39,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c9a227;
    font-size: 16px;
    margin-bottom: 8px;
    transition: transform 0.3s ease;
  }
  .stat-item:hover .stat-icon-box { transform: scale(1.1); }

  .stat-number {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 1;
    color: #fafafa;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #fafafa;
    margin: 0;
  }

  .stat-desc {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: #52525b;
    line-height: 1.5;
    margin: 0;
    max-width: 140px;
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
