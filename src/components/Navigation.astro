---
// src/components/Navigation.astro
---

<header class="fixed top-0 left-0 w-full z-50 bg-aso-black/80 backdrop-blur-md border-b border-aso-border">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10 h-20 flex items-center justify-between relative">
    
    <a href="#hero" class="font-heading font-bold text-xl tracking-tight no-underline text-aso-text flex items-center gap-1">
      ASO <span class="text-aso-gold">STUDIO</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#services" class="text-sm font-medium text-aso-text-secondary hover:text-aso-gold transition-colors no-underline">Services</a>
      <a href="#work" class="text-sm font-medium text-aso-text-secondary hover:text-aso-gold transition-colors no-underline">Portfolio</a>
      <a href="#process" class="text-sm font-medium text-aso-text-secondary hover:text-aso-gold transition-colors no-underline">Process</a>
      <a href="#about" class="text-sm font-medium text-aso-text-secondary hover:text-aso-gold transition-colors no-underline">About</a>
    </nav>

    <div class="hidden md:block">
      <a href="#contact" class="px-5 py-2.5 bg-aso-gold hover:bg-aso-gold-glow text-aso-black text-xs font-bold font-heading rounded-full transition-all duration-200 shadow-md">
        Hire Me
      </a>
    </div>

    <button id="menu-toggle" class="block md:hidden text-aso-text p-2 focus:outline-none cursor-pointer" aria-label="Toggle Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
    </button>

    <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-aso-surface/95 backdrop-blur-xl border-b border-aso-border flex-col p-6 gap-5 shadow-2xl md:hidden z-50">
      <a href="#services" class="text-base font-semibold text-aso-text no-underline py-2 border-b border-aso-border/40">Services</a>
      <a href="#work" class="text-base font-semibold text-aso-text no-underline py-2 border-b border-aso-border/40">Portfolio</a>
      <a href="#process" class="text-base font-semibold text-aso-text no-underline py-2 border-b border-aso-border/40">Process</a>
      <a href="#about" class="text-base font-semibold text-aso-text no-underline py-2 border-b border-aso-border/40">About</a>
      <a href="#contact" class="mt-2 w-full py-3 bg-aso-gold text-aso-black font-bold font-heading rounded-xl text-center no-underline">
        Hire Me
      </a>
    </div>

  </div>
</header>
