---
import SectionLabel from './ui/SectionLabel.astro';

const services = [
  {
    icon: 'video',
    title: 'AI Video Creation',
    items: ['Promotional Videos', 'Social Media Reels', 'Brand Storytelling', 'Product Showcases'],
  },
  {
    icon: 'palette',
    title: 'Graphic Design',
    items: ['Business Branding', 'Flyer Design', 'Social Media Graphics', 'Church Materials'],
  },
  {
    icon: 'code-2',
    title: 'Web Development',
    items: ['Business Websites', 'E-Commerce', 'Web Apps', 'Landing Pages'],
  },
  {
    icon: 'bot',
    title: 'AI Automation',
    items: ['Workflow Automation', 'Chatbot Setup', 'Email Sequences', 'CRM Integration', 'Social Media Automation'],
  },
];
---

<section id="services" class="reveal-section py-[120px]">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="02" text="What I Do" />

    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-4">
      My <span class="gradient-text">Services</span>
    </h2>
    <p class="text-aso-text-secondary mb-16 max-w-xl leading-relaxed">
      A focused set of services built for modern brands that want results — not just deliverables.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-container">
      {services.map((service) => (
        <div class="stagger-item group relative bg-aso-black border border-aso-border rounded-2xl p-8 hover:border-aso-gold transition-all duration-500 transform hover:-translate-y-2 hover:gold-glow cursor-pointer overflow-hidden">

          <!-- Hover corner glow -->
          <div class="absolute top-0 right-0 w-32 h-32 rounded-bl-full bg-aso-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <!-- Arrow (appears on hover) -->
          <div class="absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-2 group-hover:translate-x-0">
            <i data-lucide="arrow-up-right" class="w-6 h-6 text-aso-gold"></i>
          </div>

          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-aso-surface border border-aso-border flex items-center justify-center mb-6 group-hover:border-aso-gold group-hover:bg-aso-gold/10 transition-all duration-500">
            <i data-lucide={service.icon} class="w-7 h-7 text-aso-gold"></i>
          </div>

          <!-- Title -->
          <h3 class="font-heading font-semibold text-2xl text-aso-text mb-4 group-hover:text-aso-gold transition-colors duration-300">
            {service.title}
          </h3>

          <!-- Items -->
          <ul class="space-y-2.5">
            {service.items.map((item) => (
              <li class="flex items-center gap-2.5 text-aso-text-secondary">
                <span class="w-1.5 h-1.5 rounded-full bg-aso-gold/60 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>

          <!-- Bottom border glow on hover -->
          <div class="absolute bottom-0 left-0 right-0 h-px scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" style="background: linear-gradient(90deg, #c9a227, #f59e0b, transparent);"></div>

        </div>
      ))}
    </div>

  </div>
</section>
