---
import ProjectCard    from './ProjectCard.astro';
import SectionLabel   from './ui/SectionLabel.astro';

var projects = [
  {
    slug:        'ai-brand-video',
    title:       'AI Brand Campaign Video',
    description: 'A cinematic AI-generated brand campaign video featuring dynamic AI scenes, custom color grading, and professional post-production storytelling that captured the essence of modern luxury fashion.',
    category:    'AI Video',
    image:       '/images/1000611783.jpg',
    link:        '#',
    client:      'VeeLuxe',
  },
  {
    slug:        'church-graphics',
    title:       'Premium Church Graphics Package',
    description: 'High-impact typographic hierarchies, asset balancing, and crisp flyer templates for ministry media presentations — including event banners and social media kits.',
    category:    'Graphics',
    image:       '/images/1000611783.jpg',
    client:      'AFCF FUOYE',
  },
  {
    slug:        'visual-asset-design',
    title:       'Visual Asset Design System',
    description: 'Structured asset packages, vector layout alignments, and presentation mockups tailored for scaling companies — including brand identity and social media templates.',
    category:    'Graphics',
    image:       '/images/1000611848.jpg',
    client:      'Brand Work',
  },
  {
    slug:        'web-experience',
    title:       'Full Web Experience Build',
    description: 'Architecture-first responsive codebase with lightweight portfolio structures and polished front-end animations built for performance, SEO, and conversion.',
    category:    'Web Dev',
    image:       '/images/1000613254.jpg',
    link:        '#',
    client:      'Client Work',
  },
];

var categories = ['All', 'AI Video', 'Graphics', 'Web Dev', 'AI Automation'];
---

<section id="work" class="reveal-section py-[120px]">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="04" text="Portfolio" />

    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-4">
      My <span class="gradient-text">Works</span>
    </h2>
    <p class="text-aso-text-secondary mb-10 max-w-xl leading-relaxed">
      A selection of projects across every service. Each one built with intention.
    </p>

    <!-- Filter buttons -->
    <div class="flex flex-wrap gap-3 mb-12" id="portfolio-filters">
      {categories.map(function(cat) {
        return (
          <button
            data-filter={cat}
            class={cat === 'All'
              ? 'filter-btn px-5 py-2 rounded-full text-sm font-heading font-medium transition-all duration-300 border bg-aso-gold text-aso-black border-aso-gold'
              : 'filter-btn px-5 py-2 rounded-full text-sm font-heading font-medium transition-all duration-300 border bg-transparent text-aso-text-secondary border-aso-border hover:border-aso-gold hover:text-aso-gold'
            }
          >
            {cat}
          </button>
        );
      })}
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-container" id="projects-grid">
      {projects.map(function(project) {
        return (
          <div class="stagger-item">
            <ProjectCard
              title={project.title}
              description={project.description}
              category={project.category}
              image={project.image}
              link={project.link}
              client={project.client}
              slug={project.slug}
            />
          </div>
        );
      })}
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    var filterBtns = document.querySelectorAll('.filter-btn');
    var cards      = document.querySelectorAll('.project-card');

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');

        filterBtns.forEach(function (b) {
          b.classList.remove('bg-aso-gold', 'text-aso-black', 'border-aso-gold');
          b.classList.add('bg-transparent', 'text-aso-text-secondary', 'border-aso-border');
        });
        btn.classList.remove('bg-transparent', 'text-aso-text-secondary', 'border-aso-border');
        btn.classList.add('bg-aso-gold', 'text-aso-black', 'border-aso-gold');

        cards.forEach(function (card) {
          var cat  = card.getAttribute('data-category');
          var show = filter === 'All' || cat === filter;
          if (show) {
            card.classList.remove('filter-hidden');
            if (window.gsap) {
              window.gsap.fromTo(card,
                { opacity: 0, scale: 0.95 },
                { opacity: 1, scale: 1, duration: 0.4, ease: 'power2.out' }
              );
            }
          } else {
            if (window.gsap) {
              window.gsap.to(card, {
                opacity: 0, scale: 0.95, duration: 0.3, ease: 'power2.in',
                onComplete: function () { card.classList.add('filter-hidden'); }
              });
            } else {
              card.classList.add('filter-hidden');
            }
          }
        });
      });
    });
  })();
</script>
