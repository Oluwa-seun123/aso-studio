---
// About.astro
---

<section
  id="about"
  style="position:relative; padding:120px 0; overflow:hidden; background:#050505;"
>
  <!-- Background -->
  <div style="position:absolute; inset:0; opacity:0.025; background-image:radial-gradient(circle,#a1a1aa 1px,transparent 1px); background-size:40px 40px;"></div>
  <div style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:700px; height:1px; background:linear-gradient(90deg,transparent,rgba(201,162,39,0.3),transparent);"></div>

  <div style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:0 2.5rem;">

    <!-- Section label -->
    <div id="about-label" style="opacity:0; transform:translateY(24px); display:flex; align-items:center; gap:12px; margin-bottom:64px;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.35em; text-transform:uppercase; color:#c9a227;">06 / About Me</span>
      <div style="width:60px; height:1px; background:linear-gradient(90deg,#c9a227,transparent);"></div>
    </div>

    <!-- Split Layout -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;" class="about-grid">

      <!-- LEFT: Photo -->
      <div id="about-photo-col" style="opacity:0; transform:translateX(-32px);">
        <div class="about-photo-wrap">
          <!-- Decorative offset borders -->
          <div class="about-deco-2"></div>
          <div class="about-deco-1"></div>

          <!-- Photo container -->
          <div class="about-photo-container">
            <img
              src="/images/samuel.jpg"
              alt="Samuel Aina — ASO Creative Studio"
              style="width:100%; height:100%; object-fit:cover; display:block;"
              onerror="this.style.display='none'; document.getElementById('about-photo-fallback').style.display='flex';"
            />
            <!-- Fallback if no photo -->
            <div
              id="about-photo-fallback"
              style="display:none; width:100%; height:100%; align-items:center; justify-content:center; flex-direction:column; gap:16px; background:linear-gradient(135deg,#0f0f0f,#1a1a1a);"
            >
              <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#c9a227,#f59e0b); display:flex; align-items:center; justify-content:center; font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:24px; color:#050505;">
                ASO
              </div>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.2em; color:#52525b; text-transform:uppercase;">Add your photo to<br>/public/images/samuel.jpg</span>
            </div>
          </div>

          <!-- Gold badge overlay -->
          <div style="position:absolute; bottom:-20px; right:-20px; z-index:10; background:#0f0f0f; border:1px solid rgba(201,162,39,0.3); border-radius:12px; padding:12px 16px; display:flex; align-items:center; gap:10px;">
            <div style="width:8px; height:8px; border-radius:50%; background:#22c55e;"></div>
            <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.1em; color:#a1a1aa;">Available for work</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Text -->
      <div id="about-text-col" style="opacity:0; transform:translateX(32px);">

        <!-- Headline -->
        <h2 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(2rem,3.5vw,3rem); line-height:1.1; color:#fafafa; margin:0 0 28px;">
          Hi, I'm <span style="background:linear-gradient(135deg,#c9a227,#f59e0b); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Samuel Aina</span>
        </h2>

        <!-- Bio -->
        <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:36px;">
          <p style="font-family:'Inter',sans-serif; font-size:15px; color:#a1a1aa; line-height:1.8; margin:0;">
            I'm the founder of <strong style="color:#fafafa; font-weight:500;">ASO Creative Studio</strong> — a one-person creative powerhouse built at the intersection of AI, design, and technology. I started ASO because I believe every brand, no matter the size, deserves world-class creative work.
          </p>
          <p style="font-family:'Inter',sans-serif; font-size:15px; color:#a1a1aa; line-height:1.8; margin:0;">
            My passion sits at the crossroads of <strong style="color:#fafafa; font-weight:500;">AI video production</strong>, premium brand design, and intelligent automation. I don't just create visuals — I build systems and experiences that drive real results for brands and businesses.
          </p>
          <p style="font-family:'Inter',sans-serif; font-size:15px; color:#a1a1aa; line-height:1.8; margin:0;">
            Based in <strong style="color:#fafafa; font-weight:500;">Nigeria</strong>, working with clients across 5 countries. Whether you're a startup finding your voice or an established brand ready to evolve — I'm the creative partner you need.
          </p>
        </div>

        <!-- Stats row -->
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:#27272a; border-radius:12px; overflow:hidden; margin-bottom:36px;">
          <div class="about-stat">
            <span class="about-stat-number" data-count="50" data-suffix="+">0+</span>
            <span class="about-stat-label">Projects</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-number" data-count="3" data-suffix="+">0+</span>
            <span class="about-stat-label">Years</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-number" data-count="100" data-suffix="%">0%</span>
            <span class="about-stat-label">Remote</span>
          </div>
        </div>

        <!-- CTA -->
        <a href="/resume.pdf" id="about-resume-btn" target="_blank" rel="noopener noreferrer">
          Download Resume ↓
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  /* Photo layout */
  .about-photo-wrap {
    position: relative;
    padding-bottom: 32px;
    padding-right: 32px;
  }
  .about-photo-container {
    aspect-ratio: 4/5;
    border-radius: 16px;
    overflow: hidden;
    background: #1a1a1a;
    border: 1px solid #27272a;
    position: relative;
    z-index: 3;
  }
  .about-deco-1 {
    position: absolute;
    top: 16px;
    right: 16px;
    width: calc(100% - 32px);
    height: calc(100% - 32px);
    border: 1.5px solid rgba(201,162,39,0.3);
    border-radius: 16px;
    z-index: 2;
    pointer-events: none;
  }
  .about-deco-2 {
    position: absolute;
    top: 28px;
    right: 4px;
    width: calc(100% - 32px);
    height: calc(100% - 32px);
    border: 1px solid rgba(201,162,39,0.12);
    border-radius: 16px;
    z-index: 1;
    pointer-events: none;
  }

  /* Stats */
  .about-stat {
    background: #0a0a0a;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
  }
  .about-stat-number {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 2rem;
    color: #fafafa;
    line-height: 1;
    tabular-nums: true;
  }
  .about-stat-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #52525b;
  }

  /* Resume button */
  #about-resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 9999px;
    border: 1.5px solid #c9a227;
    background: transparent;
    color: #c9a227;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  #about-resume-btn:hover {
    background: rgba(201,162,39,0.1);
    box-shadow: 0 0 24px rgba(201,162,39,0.2);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
    .about-photo-wrap {
      max-width: 380px;
      margin: 0 auto;
    }
  }
</style>

<script>
  window.addEventListener("load", () => {
    if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined") return;

    gsap.to("#about-label", {
      opacity: 1, y: 0, duration: 0.6, ease: "power3.out",
      scrollTrigger: { trigger: "#about", start: "top 80%" },
    });
    gsap.to("#about-photo-col", {
      opacity: 1, x: 0, duration: 0.8, ease: "power3.out", delay: 0.1,
      scrollTrigger: { trigger: "#about", start: "top 75%" },
    });
    gsap.to("#about-text-col", {
      opacity: 1, x: 0, duration: 0.8, ease: "power3.out", delay: 0.2,
      scrollTrigger: { trigger: "#about", start: "top 75%" },
    });
  });
</script>