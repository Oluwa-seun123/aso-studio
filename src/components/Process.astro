---
const steps = [
  {
    number: "01",
    title: "Discovery",
    subtitle: "Understand & align",
    desc: "We start with a focused conversation to understand your brand, goals, target audience, and what success looks like. No guesswork — just clarity.",
    bullets: ["Brand brief", "Goal mapping", "Timeline & scope"],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    number: "02",
    title: "Creation",
    subtitle: "Build & refine",
    desc: "With a clear brief locked in, I craft your solution — iterating and refining until every detail meets the standard your brand deserves.",
    bullets: ["Concept development", "Revisions included", "Progress updates"],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>`,
  },
  {
    number: "03",
    title: "Delivery",
    subtitle: "Launch & support",
    desc: "Final assets delivered in the formats you need, ready to use. I stay available for post-delivery support so nothing gets left behind.",
    bullets: ["All file formats", "Launch-ready assets", "Post-delivery support"],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  },
];
---

<section id="process" class="relative py-[120px] bg-aso-surface overflow-hidden">

  <div class="absolute left-0 top-1/4 bottom-1/4 w-px bg-gradient-to-b from-transparent via-aso-gold/20 to-transparent pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="mb-20 animate-on-scroll">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-label text-[11px] tracking-[0.35em] uppercase text-aso-gold">03 / How It Works</span>
        <div class="w-16 h-px bg-gradient-to-r from-aso-gold to-transparent"></div>
      </div>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <h2 class="font-heading font-bold text-aso-text" style="font-size: clamp(2rem, 4vw, 3.25rem);">My Process</h2>
        <p class="font-body text-sm text-aso-text-muted max-w-xs leading-relaxed lg:text-right">
          Simple. Transparent. Repeatable.<br />From first message to final file.
        </p>
      </div>
    </div>

    <!-- Desktop steps -->
    <div class="hidden lg:grid lg:grid-cols-3 lg:gap-8 relative">

      <!-- Connecting dashed line with embedded progress fill -->
      <div class="absolute top-14 left-[calc(16.66%+32px)] right-[calc(16.66%+32px)] h-px border-t border-dashed border-aso-border pointer-events-none z-0 overflow-visible">
        <div id="desktop-process-line" class="absolute -top-[1px] left-0 h-[2px] w-full bg-aso-gold origin-left scale-x-0 will-change-transform z-10"></div>
      </div>

      {steps.map(({ number, title, subtitle, desc, bullets, icon }, i) => (
        <div class="relative z-10 flex flex-col items-center text-center group animate-on-scroll" style={`transition-delay: ${i * 150}ms;`}>

          <!-- Icon circle -->
          <div class="relative mb-8">
            <!-- Number badge -->
            <span class="absolute -top-3 -right-1 font-label text-[10px] tracking-[0.15em] text-aso-gold px-2 py-0.5 rounded-full bg-aso-gold/10 border border-aso-gold/25 z-10">
              {number}
            </span>
            <div class="w-28 h-28 rounded-full bg-aso-elevated border-2 border-aso-border flex items-center justify-center text-aso-gold transition-all duration-300 group-hover:border-aso-gold group-hover:shadow-[0_0_24px_rgba(201,162,39,0.25)] relative overflow-hidden">
              <div class="relative z-10"><Fragment set:html={icon} /></div>
            </div>
          </div>

          <h3 class="font-heading font-bold text-xl text-aso-text mb-1">{title}</h3>
          <p class="font-label text-[11px] tracking-[0.2em] uppercase text-aso-gold mb-4">{subtitle}</p>
          <p class="font-body text-sm text-aso-text-secondary leading-relaxed mb-6 max-w-[260px]">{desc}</p>

          <ul class="flex flex-col gap-2 items-center" role="list">
            {bullets.map((bullet) => (
              <li class="flex items-center gap-2 font-body text-xs text-aso-text-muted">
                <span class="w-1 h-1 rounded-full bg-aso-gold flex-shrink-0"></span>
                {bullet}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Mobile vertical stack -->
    <div class="lg:hidden flex flex-col gap-0">
      {steps.map(({ number, title, subtitle, desc, bullets, icon }, i) => (
        <div class="relative flex gap-6 pb-12 last:pb-0 animate-on-scroll">

          <!-- Vertical connector with progress fill -->
          {i < steps.length - 1 && (
            <div class="absolute left-7 top-14 bottom-0 w-px bg-gradient-to-b from-aso-gold/60 to-aso-border pointer-events-none">
              <div class="mobile-process-line absolute top-0 left-0 w-full h-full bg-aso-gold origin-top scale-y-0 will-change-transform z-10"></div>
            </div>
          )}

          <!-- Icon -->
          <div class="flex-shrink-0 relative z-20">
            <span class="absolute -top-2 -right-1 font-label text-[9px] text-aso-gold px-1.5 py-0.5 rounded-full bg-aso-gold/10 border border-aso-gold/25">
              {number}
            </span>
            <div class="w-14 h-14 rounded-full bg-aso-elevated border-2 border-aso-border flex items-center justify-center text-aso-gold">
              <Fragment set:html={icon} />
            </div>
          </div>

          <!-- Content -->
          <div class="pt-1">
            <h3 class="font-heading font-bold text-lg text-aso-text mb-0.5">{title}</h3>
            <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-gold mb-3">{subtitle}</p>
            <p class="font-body text-sm text-aso-text-secondary leading-relaxed mb-4">{desc}</p>
            <ul class="flex flex-col gap-1.5" role="list">
              {bullets.map((bullet) => (
                <li class="flex items-center gap-2 font-body text-xs text-aso-text-muted">
                  <span class="w-1 h-1 rounded-full bg-aso-gold flex-shrink-0"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const processSection = document.getElementById('process');
    const desktopLine = document.getElementById('desktop-process-line');
    const mobileLines = document.querySelectorAll('.mobile-process-line');

    if (!processSection) return;

    let ticking = false;

    const computeLineProgress = () => {
      const rect = processSection.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      
      // Calculate start relative to when the top of the container hits the screen center
      const startTrigger = rect.top - viewportCenter;
      const distanceScrolled = -startTrigger;
      const totalScrollable = rect.height;
      
      let progressRaw = distanceScrolled / totalScrollable;
      const progress = Math.max(0, Math.min(1, progressRaw));

      if (desktopLine && window.innerWidth >= 1024) {
        desktopLine.style.transform = `scaleX(${progress})`;
      }

      if (mobileLines.length > 0 && window.innerWidth < 1024) {
        const segmentCost = 1 / mobileLines.length;
        
        mobileLines.forEach((line, index) => {
          const segmentStart = index * segmentCost;
          const segmentEnd = (index + 1) * segmentCost;
          
          let localProgress = (progress - segmentStart) / (segmentEnd - segmentStart);
          localProgress = Math.max(0, Math.min(1, localProgress));
          
          line.style.transform = `scaleY(${localProgress})`;
        });
      }

      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          computeLineProgress();
        });
        ticking = true;
      }
    }, { passive: true });

    computeLineProgress();
  });
</script>
