---
// Navigation.astro - No script tag, pure HTML/CSS with inline onclick
---

<<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-[1280px] mx-auto px-6 py-4 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-aso-gold flex items-center justify-center text-aso-black font-bold">ASO</div>
      <span class="text-aso-text font-bold text-lg hidden sm:block">Creative Studio</span>
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#work" class="text-aso-secondary hover:text-aso-text text-sm">Work</a>
      <a href="#services" class="text-aso-secondary hover:text-aso-text text-sm">Services</a>
      <a href="#process" class="text-aso-secondary hover:text-aso-text text-sm">Process</a>
      <a href="#about" class="text-aso-secondary hover:text-aso-text text-sm">About</a>
      <a href="#contact" class="text-aso-secondary hover:text-aso-text text-sm">Contact</a>
    </div>

    <!-- Desktop CTA -->
    <a href="#contact" class="hidden md:inline-flex px-6 py-2.5 rounded-full bg-aso-gold text-aso-black text-sm font-medium hover:bg-[#f59e0b]">Start a Project</a>

    <!-- Mobile Hamburger -->
    <button 
      onclick="document.getElementById('mobile-menu').classList.toggle('opacity-0');document.getElementById('mobile-menu').classList.toggle('pointer-events-none');document.getElementById('icon-menu').classList.toggle('hidden');document.getElementById('icon-close').classList.toggle('hidden');"
      class="md:hidden w-10 h-10 text-aso-text" 
      type="button"
    >
      <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-[#050505] z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity md:hidden">
    <a href="#work" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="text-3xl font-bold text-aso-text">Work</a>
    <a href="#services" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="text-3xl font-bold text-aso-text">Services</a>
    <a href="#process" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="text-3xl font-bold text-aso-text">Process</a>
    <a href="#about" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="text-3xl font-bold text-aso-text">About</a>
    <a href="#contact" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="text-3xl font-bold text-aso-text">Contact</a>
    <a href="#contact" onclick="document.getElementById('mobile-menu').classList.add('opacity-0','pointer-events-none');document.getElementById('icon-menu').classList.remove('hidden');document.getElementById('icon-close').classList.add('hidden');" class="px-8 py-3 rounded-full bg-aso-gold text-aso-black font-medium">Start a Project</a>
  </div>
</nav>
