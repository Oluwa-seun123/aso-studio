</script>
  function openMenu() {
    if (mobileMenu) {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      document.body.style.overflow = 'hidden';
      if (ham1) ham1.style.transform = 'rotate(45deg) translateY(6px)';
      if (ham2) ham2.style.opacity = '0';
      if (ham3) { ham3.style.width = '20px'; ham3.style.transform = 'rotate(-45deg) translateY(-6px)'; }
    }
  }

  function closeMenu() {
    if (mobileMenu) {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      document.body.style.overflow = '';
      if (ham1) ham1.style.transform = '';
      if (ham2) ham2.style.opacity = '1';
      if (ham3) { ham3.style.width = '12px'; ham3.style.transform = ''; }
    }
  }

  if (menuBtn) menuBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  mobileLinks.forEach(function(link) {
    link.addEventListener('click', closeMenu);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });

  // Nav scroll effect
  var mainNav = document.getElementById('main-nav');
  window.addEventListener('scroll', function() {
    if (!mainNav) return;
    if (window.scrollY > 80) {
      mainNav.classList.add('bg-aso-black/80', 'backdrop-blur-xl', 'border-b', 'border-aso-border');
    } else {
      mainNav.classList.remove('bg-aso-black/80', 'backdrop-blur-xl', 'border-b', 'border-aso-border');
    }
  }, { passive: true });

  // Theme toggle
  var themeBtn = document.getElementById('theme-toggle');
  var themeIcon = document.getElementById('theme-icon');

  function getSavedTheme() {
    try {
      return localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    } catch(e) {
      return 'dark';
    }
  }

  function applyTheme(theme) {
    var html = document.documentElement;
    if (theme === 'dark') {
      html.removeAttribute('data-theme');
      if (themeIcon) themeIcon.textContent = '🌙';
    } else {
      html.setAttribute('data-theme', 'light');
      if (themeIcon) themeIcon.textContent = '☀️';
    }
  }

  var currentTheme = getSavedTheme();
  applyTheme(currentTheme);

  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      var next = currentTheme === 'dark' ? 'light' : 'dark';
      currentTheme = next;
      try { localStorage.setItem('theme', next); } catch(e) {}
      applyTheme(next);
    });
  }
</script>
