---
import SectionLabel from './ui/SectionLabel.astro';

const steps = [
  {
    icon: 'search',
    number: '01',
    title: 'Discovery',
    description: 'We dive deep into your brand, goals, and audience to craft the perfect strategy for your project.',
  },
  {
    icon: 'sparkles',
    number: '02',
    title: 'Creation',
    description: 'I design, build, and animate — bringing your vision to life with precision and creative excellence.',
  },
  {
    icon: 'rocket',
    number: '03',
    title: 'Delivery',
    description: 'Polished, tested, and ready to launch. Plus ongoing support whenever you need it.',
  },
];
---

<section id="process" class="reveal-section py-[120px] bg-aso-surface/50">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="03" text="How It Works" />

    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-16">
      My <span class="gradient-text">Process</span>
    </h2>

    <!-- Desktop 3-step layout -->
    <div class="hidden lg:block relative">
      <!-- Connecting line SVG -->
      <svg
        class="absolute top-[60px] left-[16.66%] w-[66.66%] overflow-visible"
        height="4"
        aria-hidden="true"
      >
        <!-- Track (static dashed) -->
        <line x1="0" y1="2" x2="100%" y2="2" stroke="#27272a" stroke-width="1" stroke-dasharray="6 4" />
        <!-- Animated gold line -->
        <line
          id="process-line"
          x1="0" y1="2" x2="0" y2="2"
          stroke="#c9a227"
          stroke-width="2"
          style="filter: drop-shadow(0 0 4px rgba(201,162,39,0.8));"
        />
      </svg>

      <div class="grid grid-cols-3 gap-12 stagger-container">
        {steps.map((step) => (
          <div class="stagger-item relative text-center group z-10">

            <!-- Icon circle -->
            <div class="relative z-10 w-[120px] h-[120px] mx-auto rounded-2xl bg-aso-elevated border-2 border-aso-border flex items-center justify-center mb-8 hover:border-aso-gold hover:gold-glow transition-all duration-500">
              <span class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-aso-gold text-aso-black text-xs font-bold flex items-center justify-center font-mono">
                {step.number}
              </span>
              <i data-lucide={step.icon} class="w-10 h-10 text-aso-gold"></i>
            </div>

            <h3 class="font-heading font-semibold text-xl text-aso-text mb-3">{step.title}</h3>
            <p class="text-aso-text-secondary leading-relaxed max-w-xs mx-auto">{step.description}</p>

          </div>
        ))}
      </div>
    </div>

    <!-- Mobile vertical layout -->
    <div class="lg:hidden space-y-10 stagger-container">
      {steps.map((step, i) => (
        <div class="stagger-item flex gap-5 items-start">
          <div class="relative shrink-0 w-16 h-16 rounded-xl bg-aso-elevated border-2 border-aso-border flex items-center justify-center">
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-aso-gold text-aso-black text-[10px] font-bold flex items-center justify-center font-mono">
              {step.number}
            </span>
            <i data-lucide={step.icon} class="w-6 h-6 text-aso-gold"></i>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-lg text-aso-text mb-2">{step.title}</h3>
            <p class="text-aso-text-secondary leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (!window.gsap || !window.ScrollTrigger) return;

    var line = document.getElementById('process-line');
    if (!line) return;

    /* Get the parent SVG width for the end x2 value */
    var svg = line.parentElement;

    window.gsap.to(line, {
      attr: { x2: svg ? svg.clientWidth : '100%' },
      duration: 1.8,
      ease: 'power2.inOut',
      scrollTrigger: {
        trigger: '#process',
        start: 'top 60%',
        toggleActions: 'play none none reverse'
      }
    });
  });
</script>
