---
// src/layouts/MainLayout.astro
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Add your font links or global CSS imports here -->
  </head>
  <body class="bg-aso-black text-aso-text font-body antialiased selection:bg-aso-gold selection:text-aso-black overflow-x-hidden">
    
    <slot />

    <!-- GLOBAL ANIMATION & COUNTER ENGINE -->
    <script is:inline>
      (function() {
        // High-Precision Counter Engine
        function easeOutExpo(x) {
          return x === 1 ? 1 : 1 - Math.pow(2, -10 * x);
        }

        function triggerCounters(container) {
          const counters = container.querySelectorAll('.counter');
          if (container.classList.contains('counter')) {
            runCounter(container);
          }
          counters.forEach(runCounter);
        }

        function runCounter(el) {
          if (el.dataset.hasRun === 'true') return;
          el.dataset.hasRun = 'true';
          
          const target = parseInt(el.getAttribute('data-target') || '0', 10);
          const duration = 2000; // Strictly 2000ms duration per constraints
          let startTime = null;

          function updateCounter(currentTime) {
            if (!startTime) startTime = currentTime;
            const elapsed = currentTime - startTime;
            const rawProgress = elapsed / duration;
            const progress = Math.min(rawProgress, 1);
            
            const easedProgress = easeOutExpo(progress);
            const currentValue = Math.floor(easedProgress * target);
            
            el.textContent = currentValue;

            if (progress < 1) {
              requestAnimationFrame(updateCounter);
            } else {
              el.textContent = target; // Clamp exact final value
            }
          }
          requestAnimationFrame(updateCounter);
        }

        // Scroll Animation Engine
        function initGlobalObservers() {
          const animatableElements = document.querySelectorAll('.animate-on-scroll');
          if (!animatableElements.length) return;

          const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                requestAnimationFrame(() => {
                  entry.target.style.opacity = '1';
                  entry.target.style.transform = 'translateY(0)';
                  entry.target.classList.add('is-revealed');
                  triggerCounters(entry.target);
                });
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.05, rootMargin: '0px 0px -50px 0px' });

          // Viewport Failsafe (Immediate Reveal)
          animatableElements.forEach(el => {
            const rect = el.getBoundingClientRect();
            // If already inside the viewport on mount, trigger immediately
            if (rect.top < window.innerHeight && rect.bottom > 0) {
              requestAnimationFrame(() => {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
                el.classList.add('is-revealed');
                triggerCounters(el);
              });
            } else {
              // Standard CSS initialization for off-screen elements
              el.style.opacity = '0';
              el.style.transform = 'translateY(20px)';
              el.style.transition = 'opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
              observer.observe(el);
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initGlobalObservers);
        } else {
          initGlobalObservers();
        }
      })();
    </script>
  </body>
</html>
