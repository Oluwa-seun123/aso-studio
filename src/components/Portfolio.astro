---
// src/components/Portfolio.astro
---
<section id="work" class="py-32 bg-aso-black relative border-t border-aso-border">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
    
    <div class="mb-20 animate-on-scroll">
      <span class="font-label text-[11px] text-aso-gold uppercase tracking-[0.25em] block mb-3">Selected Catalog</span>
      <h2 class="text-4xl sm:text-5xl font-heading font-bold text-aso-text tracking-tight">Featured Creations</h2>
      <p class="text-aso-text-secondary mt-4 max-w-xl text-base sm:text-lg font-body">
        A precise compilation of technical artwork, cinematic assets, and structural designs.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <div class="premium-card rounded-2xl overflow-hidden flex flex-col h-full animate-on-scroll">
        <div class="w-full h-72 bg-aso-elevated relative flex flex-col items-center justify-center overflow-hidden border-b border-aso-border group">
          <div class="absolute inset-0 bg-gradient-to-t from-aso-black via-transparent to-transparent opacity-60 z-10"></div>
          <svg class="w-12 h-12 text-aso-gold relative z-20 opacity-80 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <span class="font-label text-[10px] uppercase tracking-widest text-aso-text-muted absolute bottom-4 left-4 z-20">Video Workspace Placeholder</span>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between">
          <div>
            <span class="font-label text-[10px] text-aso-gold uppercase tracking-wider block mb-2">Video Production</span>
            <h3 class="text-xl font-bold text-aso-text font-heading mb-3">AI Video Concepts</h3>
            <p class="text-aso-text-secondary text-sm leading-relaxed font-body">Generative video sequencing, stylistic composition control, and premium post-production storytelling frameworks.</p>
          </div>
        </div>
      </div>

      <div class="premium-card rounded-2xl overflow-hidden flex flex-col h-full animate-on-scroll">
        <div class="w-full h-72 bg-aso-elevated relative overflow-hidden border-b border-aso-border">
          <img src="/images/1000611783.jpg" alt="Premium Church Graphics" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="hidden absolute inset-0 bg-aso-elevated flex-col items-center justify-center text-aso-text-muted font-label text-xs">
            Asset Reference: 1000611783.jpg
          </div>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between">
          <div>
            <span class="font-label text-[10px] text-aso-gold uppercase tracking-wider block mb-2">Creative Design</span>
            <h3 class="text-xl font-bold text-aso-text font-heading mb-3">Premium Church Graphics</h3>
            <p class="text-aso-text-secondary text-sm leading-relaxed font-body">High-impact typographic hierarchies, asset balancing, and crisp flyer templates for media presentations.</p>
          </div>
        </div>
      </div>

      <div class="premium-card rounded-2xl overflow-hidden flex flex-col h-full animate-on-scroll">
        <div class="w-full h-72 bg-aso-elevated relative overflow-hidden border-b border-aso-border">
          <img src="/images/1000611848.jpg" alt="Visual Asset Design System" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="hidden absolute inset-0 bg-aso-elevated flex-col items-center justify-center text-aso-text-muted font-label text-xs">
            Asset Reference: 1000611848.jpg
          </div>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between">
          <div>
            <span class="font-label text-[10px] text-aso-gold uppercase tracking-wider block mb-2">Identity Systems</span>
            <h3 class="text-xl font-bold text-aso-text font-heading mb-3">Visual Asset Design</h3>
            <p class="text-aso-text-secondary text-sm leading-relaxed font-body">Structured asset packages, vector layout alignments, and presentation mockups tailored for scaling companies.</p>
          </div>
        </div>
      </div>

      <div class="premium-card rounded-2xl overflow-hidden flex flex-col h-full animate-on-scroll">
        <div class="w-full h-72 bg-aso-elevated relative overflow-hidden border-b border-aso-border">
          <img src="/images/1000613254.jpg" alt="Web Applications Layout System" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="hidden absolute inset-0 bg-aso-elevated flex-col items-center justify-center text-aso-text-muted font-label text-xs">
            Asset Reference: 1000613254.jpg
          </div>
        </div>
        <div class="p-8 flex-grow flex flex-col justify-between">
          <div>
            <span class="font-label text-[10px] text-aso-gold uppercase tracking-wider block mb-2">Web Development</span>
            <h3 class="text-xl font-bold text-aso-text font-heading mb-3">Full Web Experiences</h3>
            <p class="text-aso-text-secondary text-sm leading-relaxed font-body">Architecture-first responsive code bases, lightweight portfolio structures, and polished front-end animations.</p>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-24 text-center animate-on-scroll">
      <p class="text-aso-text-muted mb-6 font-body text-sm tracking-wide">Looking for my extended asset libraries?</p>
      <a href="#" class="inline-flex items-center gap-3 px-8 py-4 bg-transparent border border-aso-gold rounded-full text-aso-gold font-heading font-bold text-sm transition-all duration-300 hover:bg-[rgba(214,175,55,0.08)] hover:scale-105">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7.71 3.5L1.15 15l3.43 6 6.55-11.5M9.73 15L6.3 21h13.12l3.43-6M10.88 1.5h-6.86L15.42 21h6.86"/></svg>
        Explore Full Portfolio Drive
      </a>
    </div>

  </div>
</section>

<script is:inline>
  (function() {
    if (window._portfolioEngineInitialized) return;
    window._portfolioEngineInitialized = true;

    const filterButtons = document.querySelectorAll('.portfolio-filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    if (filterButtons.length === 0 || portfolioItems.length === 0) return;

    // Set 'All' filter as structurally active on mount
    filterButtons[0].classList.add('border-aso-gold', 'text-aso-text');
    filterButtons[0].classList.remove('text-aso-text-secondary');

    filterButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        
        const targetFilter = button.getAttribute('data-filter');

        // Update active class typography states
        filterButtons.forEach(btn => {
          btn.classList.remove('border-aso-gold', 'text-aso-text');
          btn.classList.add('text-aso-text-secondary');
        });
        button.classList.add('border-aso-gold', 'text-aso-text');
        button.classList.remove('text-aso-text-secondary');

        // Filter calculation grid loop
        portfolioItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category');
          
          if (targetFilter === 'all' || itemCategory === targetFilter) {
            window.requestAnimationFrame(() => {
              item.style.display = 'flex';
              setTimeout(() => { item.style.opacity = '1'; }, 10);
            });
          } else {
            window.requestAnimationFrame(() => {
              item.style.opacity = '0';
              item.style.display = 'none';
            });
          }
        });
      });
    });
  })();
</script>
</section>

<style>
  @import "tailwindcss";

  .card-hover {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
  }
  
  .card-hover:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px -12px rgba(201, 162, 39, 0.15);
  }

  /* Utility for JS filtering to prevent display layout issues */
  .filter-hidden {
    display: none !important;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const portfolioCards = document.querySelectorAll('.portfolio-card');
    const emptyState = document.getElementById('portfolio-empty');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filterValue = button.getAttribute('data-filter');

        // 1. Manage Active Button States (Vanilla class toggling)
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');
          btn.classList.add('bg-transparent', 'text-gray-300', 'border-gray-800');
        });
        
        button.classList.remove('bg-transparent', 'text-gray-300', 'border-gray-800');
        button.classList.add('bg-[#c9a227]', 'text-[#050505]', 'border-[#c9a227]');

        // 2. Filter Grid Items
        let visibleCount = 0;
        
        portfolioCards.forEach(card => {
          const category = card.getAttribute('data-category');
          
          if (filterValue === 'All' || filterValue === category) {
            card.classList.remove('filter-hidden');
            // Trigger a quick reflow for animation if needed
            void card.offsetWidth; 
            visibleCount++;
          } else {
            card.classList.add('filter-hidden');
          }
        });

        // 3. Handle Empty State Container
        if (visibleCount === 0) {
          emptyState.classList.remove('filter-hidden');
        } else {
          emptyState.classList.add('filter-hidden');
        }
      });
    });
  });
</script>
