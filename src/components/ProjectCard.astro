---
interface Props {
  title: string;
  description: string;
  category: string;
  image: string;
  link?: string;
  client?: string;
  slug: string;
}

const { title, description, category, image, link, client, slug } = Astro.props;

const categoryColors: Record<string, string> = {
  "AI Video":      "rgba(201,162,39,0.15)",
  "Graphics":      "rgba(99,102,241,0.15)",
  "Web Dev":       "rgba(20,184,166,0.15)",
  "AI Automation": "rgba(236,72,153,0.15)",
};

const categoryBorderColors: Record<string, string> = {
  "AI Video":      "rgba(201,162,39,0.35)",
  "Graphics":      "rgba(99,102,241,0.35)",
  "Web Dev":       "rgba(20,184,166,0.35)",
  "AI Automation": "rgba(236,72,153,0.35)",
};

const categoryTextColors: Record<string, string> = {
  "AI Video":      "#c9a227",
  "Graphics":      "#818cf8",
  "Web Dev":       "#2dd4bf",
  "AI Automation": "#f472b6",
};

const bgColor   = categoryColors[category]       ?? "rgba(201,162,39,0.1)";
const bdColor   = categoryBorderColors[category] ?? "rgba(201,162,39,0.3)";
const txtColor  = categoryTextColors[category]   ?? "#c9a227";
---

<article
  class="project-card group relative rounded-2xl overflow-hidden border transition-all duration-400"
  style="background: #0a0a0a; border-color: #27272a;"
  data-category={category}
  aria-label={`Project: ${title}`}
>
  <!-- ── Image Container ── -->
  <div class="relative overflow-hidden" style="aspect-ratio: 16/10;">

    <!-- Image -->
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />

    <!-- Fallback if image fails -->
    <div
      class="absolute inset-0 items-center justify-center hidden"
      style={`background: linear-gradient(135deg, #0f0f0f, #1a1a1a); border-bottom: 1px solid #27272a;`}
      aria-hidden="true"
    >
      <span class="font-label text-xs tracking-[0.2em] uppercase text-text-muted">
        {category}
      </span>
    </div>

    <!-- Hover overlay -->
<div
  class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300"
  style="background: rgba(5,5,5,0.75); backdrop-filter: blur(4px);"
  aria-hidden="true"
>
  
    href={link ?? "#work"}
    target={link ? "_blank" : "_self"}
    rel="noopener noreferrer"
    class="flex items-center gap-2 px-6 py-3 rounded-full font-heading font-semibold text-sm transition-all duration-200 hover:scale-105"
    style={link
      ? "background: linear-gradient(135deg, #c9a227, #f59e0b); color: #050505;"
      : "background: rgba(201,162,39,0.15); border: 1px solid rgba(201,162,39,0.4); color: #c9a227;"}
    tabindex="-1"
  >
    View Project
    <i data-lucide="external-link" class="w-4 h-4"></i>
  </a>
</div>

    <!-- Category badge -->
    <div class="absolute top-4 left-4">
      <span
        class="font-label text-[10px] tracking-[0.18em] uppercase px-3 py-1.5 rounded-full"
        style={`background: ${bgColor}; border: 1px solid ${bdColor}; color: ${txtColor};`}
      >
        {category}
      </span>
    </div>

  </div>

  <!-- ── Card Body ── -->
  <div class="p-6">

    <!-- Client line -->
    {client && (
      <p class="font-label text-[10px] tracking-[0.2em] uppercase text-text-muted mb-2">
        {client}
      </p>
    )}

    <!-- Title -->
    <h3
      class="font-heading font-bold text-[17px] text-text-primary mb-3 transition-colors duration-200 group-hover:text-gold leading-tight"
    >
      {title}
    </h3>

    <!-- Description -->
    <p class="font-body text-sm text-text-secondary leading-relaxed line-clamp-2 mb-5">
      {description}
    </p>

    <!-- Footer row -->
    <div class="flex items-center justify-between">
      <div
        class="h-px flex-1 mr-4"
        style="background: #27272a;"
        aria-hidden="true"
      ></div>
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110"
        style={`background: ${bgColor}; border: 1px solid ${bdColor};`}
        aria-hidden="true"
      >
        <i data-lucide="arrow-up-right" class="w-3.5 h-3.5" style={`color: ${txtColor};`}></i>
      </div>
    </div>

  </div>

  <!-- Bottom border glow on hover -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-left"
    style="background: linear-gradient(90deg, #c9a227, #f59e0b, transparent);"
    aria-hidden="true"
  ></div>

</article>

<style>
  .project-card:hover {
    border-color: rgba(201, 162, 39, 0.3) !important;
    box-shadow:
      0 0 24px rgba(201, 162, 39, 0.1),
      0 16px 48px rgba(0, 0, 0, 0.6);
    transform: translateY(-4px);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>