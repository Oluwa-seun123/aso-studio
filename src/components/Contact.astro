---
import SectionLabel from './ui/SectionLabel.astro';
---

<section id="contact" class="reveal-section py-[120px] bg-aso-surface/50">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- Left: Info -->
      <div>
        <SectionLabel number="07" text="Get In Touch" />

        <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl text-aso-text mb-6">
          Let's Create Something <span class="gradient-text">Extraordinary</span>
        </h2>
        <p class="text-aso-text-secondary leading-relaxed mb-10">
          Have a project in mind? I'd love to hear about it. Whether you need AI videos,
          graphics, a new website, or automation — let's make it happen.
        </p>

        <div class="space-y-6 mb-10">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <i data-lucide="mail" class="w-5 h-5 text-aso-gold"></i>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Email</div>
              <a href="mailto:samuelaina683@gmail.com" class="text-aso-text hover:text-aso-gold transition-colors">
                samuelaina683@gmail.com
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <i data-lucide="map-pin" class="w-5 h-5 text-aso-gold"></i>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Location</div>
              <div class="text-aso-text">Nigeria &middot; Available Worldwide</div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-aso-black border border-aso-border flex items-center justify-center flex-shrink-0">
              <i data-lucide="clock" class="w-5 h-5 text-aso-gold"></i>
            </div>
            <div>
              <div class="text-sm text-aso-text-muted font-mono">Response Time</div>
              <div class="text-aso-text">Within 24 hours</div>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-3 mb-10">
          <a href="https://twitter.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-aso-black border border-aso-border flex items-center justify-center text-aso-text-muted hover:text-aso-gold hover:border-aso-gold transition-all duration-300">
            <i data-lucide="twitter" class="w-4 h-4"></i>
          </a>
          <a href="https://instagram.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-aso-black border border-aso-border flex items-center justify-center text-aso-text-muted hover:text-aso-gold hover:border-aso-gold transition-all duration-300">
            <i data-lucide="instagram" class="w-4 h-4"></i>
          </a>
          <a href="https://www.linkedin.com/in/samuel-aina-150391390" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-aso-black border border-aso-border flex items-center justify-center text-aso-text-muted hover:text-aso-gold hover:border-aso-gold transition-all duration-300">
            <i data-lucide="linkedin" class="w-4 h-4"></i>
          </a>
          <a href="https://dribbble.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-aso-black border border-aso-border flex items-center justify-center text-aso-text-muted hover:text-aso-gold hover:border-aso-gold transition-all duration-300">
            <i data-lucide="dribbble" class="w-4 h-4"></i>
          </a>
        </div>

        <!-- Calendly -->
        <div class="p-6 rounded-2xl bg-aso-black border border-aso-border">
          <div class="flex items-center gap-3 mb-3">
            <i data-lucide="calendar" class="w-5 h-5 text-aso-gold"></i>
            <span class="font-heading font-medium text-aso-text">Prefer to book a call?</span>
          </div>
          <p class="text-sm text-aso-text-secondary mb-4">
            Schedule a free 30-minute discovery call to discuss your project.
          </p>
          <a
            href="https://calendly.com/samuelaina683/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-aso-gold/10 border border-aso-gold/30 text-aso-gold text-sm font-heading font-medium hover:bg-aso-gold hover:text-aso-black transition-all duration-300"
          >
            <i data-lucide="video" class="w-4 h-4"></i>
            Book a Call
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-aso-black border border-aso-border rounded-2xl p-8">
        <h3 class="font-heading font-bold text-xl text-aso-text mb-1">Send a Message</h3>
        <p class="text-sm text-aso-text-muted mb-8">I'll respond within 24 hours.</p>

        <form id="contact-form" novalidate>
          <div class="space-y-5">
            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-name">Name *</label>
              <input id="c-name" name="name" type="text"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors"
                placeholder="Your full name" />
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-email">Email *</label>
              <input id="c-email" name="email" type="email"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors"
                placeholder="your@email.com" />
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-service">Service *</label>
              <select id="c-service" name="service"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text focus:border-aso-gold focus:outline-none transition-colors cursor-pointer">
                <option value="" disabled selected>Select a service</option>
                <option value="AI Video">AI Video Creation</option>
                <option value="Graphics">Graphic Design</option>
                <option value="Web Dev">Web Development</option>
                <option value="AI Automation">AI Automation</option>
                <option value="Multiple">Multiple Services</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-heading font-medium text-aso-text mb-2" for="c-message">Message *</label>
              <textarea id="c-message" name="message" rows="4"
                class="w-full px-4 py-3 rounded-xl bg-aso-surface border border-aso-border text-aso-text placeholder-aso-text-muted focus:border-aso-gold focus:outline-none transition-colors resize-none"
                placeholder="Tell me about your project..."></textarea>
            </div>

            <button
              id="c-submit"
              type="button"
              class="w-full flex items-center justify-center gap-2.5 px-8 py-4 rounded-full bg-aso-gold text-aso-black font-heading font-semibold text-base border-none cursor-pointer transition-all duration-300 hover:gold-glow-strong transform hover:-translate-y-0.5"
            >
              <span id="c-btn-idle" class="flex items-center gap-2">
                <i data-lucide="send" class="w-4 h-4"></i>
                Send Message
              </span>
              <span id="c-btn-busy" style="display:none;" class="flex items-center gap-2">
                <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Sending...
              </span>
            </button>
          </div>
        </form>

        <div id="c-success" style="display:none;" class="mt-4 p-4 rounded-xl bg-green-500/10 border border-green-500/30 text-green-400 text-sm flex items-center gap-2">
          <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
          Message sent! I'll respond within 24 hours.
        </div>
        <div id="c-error" style="display:none;" class="mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm flex items-center gap-2">
          <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
          Something went wrong. Please try again or email me directly.
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  /* ── IDs ── */
  var FORMSPREE  = 'https://formspree.io/f/meedjqgv';
  var SHEET_URL  = 'https://script.google.com/macros/s/AKfycbzshACmsl7qo0mmquRhyNLAqVSvMIob6YS6P9CC2HF_Vk9LI6I3NRNsEMnbw2d15mS5ag/exec';

  /* ── Elements ── */
  var btnSubmit = document.getElementById('c-submit');
  var btnIdle   = document.getElementById('c-btn-idle');
  var btnBusy   = document.getElementById('c-btn-busy');
  var msgOk     = document.getElementById('c-success');
  var msgErr    = document.getElementById('c-error');

  /* ── Lock prevents any second click during request ── */
  var submitting = false;

  function setLoading(on) {
    submitting          = on;
    btnSubmit.disabled  = on;
    btnIdle.style.display = on ? 'none'  : 'flex';
    btnBusy.style.display = on ? 'flex'  : 'none';
  }

  function showMsg(ok) {
    msgOk.style.display  = ok  ? 'flex' : 'none';
    msgErr.style.display = ok  ? 'none' : 'flex';
    if (window.lucide) window.lucide.createIcons();
  }

  function resetMsgs() {
    msgOk.style.display = 'none';
    msgErr.style.display = 'none';
  }

  function logToSheet(data) {
    /* Fire-and-forget — never blocks UX, never causes double submission */
    try {
      fetch(SHEET_URL, {
        method:  'POST',
        mode:    'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          timestamp: new Date().toISOString(),
          name:      data.name,
          email:     data.email,
          service:   data.service,
          message:   data.message,
          status:    'New'
        })
      });
    } catch (e) { /* silent */ }
  }

  btnSubmit.addEventListener('click', function () {
    /* Hard guard — ignore any click while already submitting */
    if (submitting) return;

    /* Read values */
    var name    = document.getElementById('c-name').value.trim();
    var email   = document.getElementById('c-email').value.trim();
    var service = document.getElementById('c-service').value;
    var message = document.getElementById('c-message').value.trim();

    /* Basic validation */
    if (!name || !email || !service || !message) {
      alert('Please fill in all fields before sending.');
      return;
    }
    if (email.indexOf('@') < 1) {
      alert('Please enter a valid email address.');
      return;
    }

    resetMsgs();
    setLoading(true);

    var payload = { name: name, email: email, service: service, message: message };

    /* Single Formspree request — exactly once */
    fetch(FORMSPREE, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      if (data.ok || data.next) {
        showMsg(true);
        document.getElementById('contact-form').reset();
        /* Log to Google Sheet after confirmed success — non-blocking */
        logToSheet(payload);
      } else {
        showMsg(false);
      }
    })
    .catch(function () {
      showMsg(false);
    })
    .then(function () {
      /* Always runs — replaces .finally() for browser compat */
      setLoading(false);
    });
  });
})();
</script>
