---
import MainLayout from '../layouts/MainLayout.astro';
import Portfolio from '../components/Portfolio.astro';
---

<MainLayout title="ASO Studio — AI-Powered Creative Studio" description="From cinematic AI videos and premium brand graphics to full web experiences and intelligent automation.">
  
  <section class="relative min-h-screen flex flex-col justify-center items-center px-6 pt-32 pb-20 overflow-hidden bg-aso-black grid-bg">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-aso-black/50 to-aso-black z-10"></div>
    
    <div class="max-w-[800px] text-center relative z-20 flex flex-col items-center">
      
      <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-aso-elevated border border-aso-border mb-8 animate-on-scroll">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-gold font-bold">Available For Freelance Work</span>
      </div>

      <h1 class="text-5xl sm:text-7xl font-heading font-bold text-aso-text tracking-tight leading-[1.1] mb-6 animate-on-scroll">
        AI-Powered <br />
        <span class="text-gradient">Creative Studio</span>
      </h1>

      <p class="text-aso-text-secondary text-base sm:text-xl font-body max-w-xl leading-relaxed mb-10 mx-auto animate-on-scroll">
        From cinematic AI videos and premium brand graphics to full web experiences and intelligent automation — everything your brand needs to stand out in the <strong class="text-aso-text">AI era.</strong>
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center items-center mb-24 animate-on-scroll">
        <a href="#work" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-aso-gold hover:bg-aso-gold-hover text-aso-black font-heading font-bold text-sm rounded-full transition-all duration-300 hover:scale-105 shadow-lg shadow-aso-gold/10">
          View My Work
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="#contact" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent border border-aso-border hover:border-aso-text text-aso-text font-heading font-medium text-sm rounded-full transition-all duration-300">
          Start a Project
          <svg class="w-4 h-4 text-aso-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 pt-8 border-t border-aso-border/60 w-full animate-on-scroll">
        <div class="flex -space-x-3">
          <div class="w-8 h-8 rounded-full bg-aso-gold text-aso-black font-bold text-[10px] flex items-center justify-center border-2 border-aso-black font-heading">A</div>
          <div class="w-8 h-8 rounded-full bg-indigo-500 text-aso-text font-bold text-[10px] flex items-center justify-center border-2 border-aso-black font-heading">B</div>
          <div class="w-8 h-8 rounded-full bg-pink-500 text-aso-text font-bold text-[10px] flex items-center justify-center border-2 border-aso-black font-heading">C</div>
          <div class="w-8 h-8 rounded-full bg-teal-500 text-aso-text font-bold text-[10px] flex items-center justify-center border-2 border-aso-black font-heading">D</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="flex text-aso-gold text-xs">★★★★★</div>
          <span class="font-label text-[10px] uppercase tracking-widest text-aso-text-muted">Trusted Worldwide</span>
        </div>
      </div>

    </div>
  </section>

  <section class="py-16 bg-aso-black border-y border-aso-border relative z-20">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-6">
        <div class="text-center md:text-left animate-on-scroll">
          <h3 class="text-4xl sm:text-5xl font-heading font-bold text-aso-text mb-1"><span class="counter" data-target="50">0</span>+</h3>
          <p class="font-label text-[10px] uppercase tracking-widest text-aso-text-muted">Projects Completed</p>
        </div>
        <div class="text-center md:text-left animate-on-scroll">
          <h3 class="text-4xl sm:text-5xl font-heading font-bold text-aso-text mb-1"><span class="counter" data-target="3">0</span>+</h3>
          <p class="font-label text-[10px] uppercase tracking-widest text-aso-text-muted">Years Experience</p>
        </div>
      </div>
    </div>
  </section>

  <Portfolio />

</MainLayout>
