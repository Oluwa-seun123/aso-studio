---
// Standalone resume page — no layout imports needed
// Visit /resume → desktop: click "Download PDF" → browser prints to PDF
// Mobile: "Request PDF" sends you an email instead
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Samuel Aina — Resume | ASO Creative Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #f0f0f0;
      color: #1a1a1a;
      line-height: 1.6;
    }

    /* Top bar (hidden when printing) */
    .topbar {
      position: sticky; top: 0; z-index: 100;
      background: #c9a227;
      padding: 12px 24px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .topbarTitle {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700; font-size: 15px; color: #050505;
    }
    .topbarActions { display: flex; gap: 10px; }
    .btnPrint {
      background: #050505; color: #c9a227;
      border: none; padding: 8px 20px;
      border-radius: 999px; cursor: pointer;
      font-weight: 600; font-size: 13px; font-family: 'Inter', sans-serif;
      text-decoration: none;
      display: inline-flex; align-items: center;
    }
    .btnBack {
      background: transparent; color: #050505;
      border: 2px solid #050505; padding: 6px 18px;
      border-radius: 999px; font-weight: 600;
      font-size: 13px; text-decoration: none;
      font-family: 'Inter', sans-serif;
      display: inline-flex; align-items: center;
    }

    /* Mobile / Desktop toggle — ALL class names use camelCase, NO hyphens */
    .mobileOnly  { display: none; }
    .desktopOnly { display: inline-flex; }

    /* Resume page */
    .page {
      max-width: 800px; margin: 32px auto 64px;
      background: white; padding: 52px 56px;
      box-shadow: 0 4px 40px rgba(0,0,0,0.12);
    }

    /* Header */
    .rHeader { border-bottom: 3px solid #c9a227; padding-bottom: 24px; margin-bottom: 32px; }
    .rName   { font-family: 'Space Grotesk', sans-serif; font-size: 36px; font-weight: 700; color: #050505; }
    .rRole   { font-size: 15px; color: #c9a227; font-weight: 600; margin-top: 4px; letter-spacing: 0.05em; text-transform: uppercase; }
    .rContacts {
      display: flex; flex-wrap: wrap; gap: 6px 20px;
      margin-top: 12px; font-size: 13px; color: #444;
    }
    .rContacts a { color: #444; text-decoration: none; }
    .rContacts a:hover { color: #c9a227; }

    /* Section */
    .rSection { margin-bottom: 28px; }
    .rSectionTitle {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #c9a227; border-bottom: 1px solid #e8e8e8;
      padding-bottom: 6px; margin-bottom: 16px;
    }

    /* Experience item */
    .rItem { margin-bottom: 20px; }
    .rItemHeader { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .rItemTitle { font-weight: 700; font-size: 15px; color: #050505; }
    .rItemCompany { font-weight: 500; color: #555; font-size: 14px; }
    .rItemDate { font-size: 12px; color: #888; white-space: nowrap; flex-shrink: 0; }
    .rItem ul { margin-top: 8px; padding-left: 18px; }
    .rItem li { font-size: 13px; color: #333; margin-bottom: 4px; }

    /* Skills grid */
    .rSkills { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .rSkillGroupTitle { font-weight: 600; font-size: 13px; color: #050505; margin-bottom: 6px; }
    .rSkillTags { display: flex; flex-wrap: wrap; gap: 5px; }
    .rTag {
      background: #f5f5f5; color: #333; border: 1px solid #e0e0e0;
      padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 500;
    }

    /* Education */
    .rEduHeader { display: flex; justify-content: space-between; }
    .rEduSchool { font-weight: 700; font-size: 15px; color: #050505; }
    .rEduDegree { font-size: 13px; color: #555; margin-top: 2px; }
    .rEduThesis { font-size: 12px; color: #777; margin-top: 6px; font-style: italic; }

    /* Certifications */
    .rCert { margin-bottom: 10px; }
    .rCertTitle { font-weight: 600; font-size: 14px; color: #050505; }
    .rCertOrg { font-size: 13px; color: #555; }

    /* Projects */
    .rProject { margin-bottom: 14px; }
    .rProjectName { font-weight: 600; font-size: 14px; color: #050505; }
    .rProjectTech { font-size: 11px; color: #c9a227; font-weight: 600; margin-left: 8px; }
    .rProjectDesc { font-size: 13px; color: #444; margin-top: 2px; }

    /* Print styles */
    @media print {
      .topbar    { display: none !important; }
      body       { background: white; }
      .page      { margin: 0; box-shadow: none; padding: 32px 40px; }
      @page      { margin: 1cm; size: A4; }
    }

    @media (max-width: 600px) {
      .page { padding: 32px 24px; }
      .rSkills { grid-template-columns: 1fr; }
      .rItemHeader { flex-direction: column; }
      .mobileOnly  { display: inline-flex; }
      .desktopOnly { display: none; }
    }
  </style>
</head>
