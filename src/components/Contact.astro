---
// Contact.astro
---

<section id="contact" class="relative py-[120px] bg-aso-surface overflow-hidden">

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-px bg-gradient-to-r from-transparent via-aso-gold/30 to-transparent pointer-events-none"></div>

  <!-- Toast container -->
  <div id="toast-wrap" class="fixed top-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- LEFT: Info -->
      <div>
        <!-- Label -->
        <div class="flex items-center gap-3 mb-6">
          <span class="font-label text-[11px] tracking-[0.35em] uppercase text-aso-gold">07 / Get In Touch</span>
          <div class="w-16 h-px bg-gradient-to-r from-aso-gold to-transparent"></div>
        </div>

        <!-- Headline -->
        <h2 class="font-heading font-bold mb-5 text-balance" style="font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.1;">
          Let's Create Something<br />
          <span class="gradient-text">Extraordinary</span>
        </h2>

        <p class="font-body text-aso-text-secondary leading-relaxed mb-10 max-w-md">
          Have a project in mind? I'd love to hear about it. Send me a message and let's talk about how we can bring your vision to life.
        </p>

        <!-- Contact info -->
        <div class="flex flex-col gap-5 mb-10">

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-aso-gold/8 border border-aso-gold/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-text-muted mb-0.5">Email</p>
              <a href="mailto:hello@asocreative.studio" class="font-body text-sm text-aso-text-secondary no-underline hover:text-aso-gold transition-colors duration-200">
                hello@asocreative.studio
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-aso-gold/8 border border-aso-gold/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-text-muted mb-0.5">Location</p>
              <p class="font-body text-sm text-aso-text-secondary">Nigeria · Available Worldwide</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-aso-gold/8 border border-aso-gold/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-text-muted mb-0.5">Response Time</p>
              <p class="font-body text-sm text-aso-text-secondary">Within 24 hours</p>
            </div>
          </div>

        </div>

        <!-- Social icons -->
        <div class="flex items-center gap-3 mb-10">
          <a href="#twitter"   class="social-chip" aria-label="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#instagram" class="social-chip" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#linkedin"  class="social-chip" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#dribbble"  class="social-chip" aria-label="Dribbble">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>
          </a>
        </div>

        <!-- Calendly box -->
        <div class="rounded-2xl border border-aso-gold/25 bg-aso-gold/5 p-6">
          <p class="font-heading font-semibold text-[15px] text-aso-text mb-1">Prefer to book a call?</p>
          <p class="font-body text-sm text-aso-text-secondary mb-4 leading-relaxed">
            Schedule a free 30-minute discovery call directly on my calendar.
          </p>
          <a
            href="https://calendly.com/YOUR_CALENDLY_LINK"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-aso-gold/40 bg-transparent text-aso-gold font-heading font-semibold text-sm no-underline transition-all duration-300 hover:bg-aso-gold/10 hover:border-aso-gold"
          >
            Book a Call
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>

      <!-- RIGHT: Form -->
      <div>
        <div class="rounded-2xl border border-aso-border bg-aso-elevated p-8">

          <h3 class="font-heading font-bold text-xl text-aso-text mb-1">Send a Message</h3>
          <p class="font-body text-sm text-aso-text-muted mb-8">I'll respond within 24 hours.</p>

          <form id="contact-form" class="flex flex-col gap-5" novalidate>

            <!-- Name -->
            <div class="flex flex-col gap-2">
              <label class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-text-secondary" for="cf-name">
                Your Name *
              </label>
              <input
                id="cf-name"
                name="name"
                type="text"
                required
                placeholder="e.g. Victoria Abiodun"
                class="w-full px-4 py-3 rounded-xl border border-aso-border bg-aso-black text-aso-text font-body text-sm outline-none transition-all duration-200 focus:border-aso-gold focus:shadow-[0_0_0_3px_rgba(201,162,39,0.08)] placeholder:text-aso-text-muted"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-text-secondary" for="cf-email">
                Email Address *
              </label>
              <input
                id="cf-email"
                name="email"
                type="email"
                required
                placeholder="hello@yourbrand.com"
                class="w-full px-4 py-3 rounded-xl border border-aso-border bg-aso-black text-aso-text font-body text-sm outline-none transition-all duration-200 focus:border-aso-gold focus:shadow-[0_0_0_3px_rgba(201,162,39,0.08)] placeholder:text-aso-text-muted"
              />
            </div>

            <!-- Service -->
            <div class="flex flex-col gap-2">
              <label class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-text-secondary" for="cf-service">
                Service Needed *
              </label>
              <select
                id="cf-service"
                name="service"
                required
                class="w-full px-4 py-3 rounded-xl border border-aso-border bg-aso-black text-aso-text font-body text-sm outline-none transition-all duration-200 focus:border-aso-gold focus:shadow-[0_0_0_3px_rgba(201,162,39,0.08)] cursor-pointer appearance-none"
              >
                <option value="" disabled selected>Select a service...</option>
                <option value="AI Video">AI Video Creation</option>
                <option value="Graphics">Graphic Design</option>
                <option value="Web Dev">Web Development</option>
                <option value="AI Automation">AI Automation</option>
                <option value="Multiple">Multiple Services</option>
              </select>
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-2">
              <label class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-text-secondary" for="cf-message">
                Your Message *
              </label>
              <textarea
                id="cf-message"
                name="message"
                required
                rows="5"
                placeholder="Tell me about your project — goals, timeline, budget..."
                class="w-full px-4 py-3 rounded-xl border border-aso-border bg-aso-black text-aso-text font-body text-sm outline-none transition-all duration-200 focus:border-aso-gold focus:shadow-[0_0_0_3px_rgba(201,162,39,0.08)] placeholder:text-aso-text-muted resize-y"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              id="cf-submit"
              type="submit"
              class="w-full flex items-center justify-center gap-2.5 py-4 rounded-full bg-gradient-to-br from-aso-gold to-aso-gold-glow font-heading font-bold text-base text-aso-black border-none cursor-pointer transition-all duration-300 hover:scale-[1.02] gold-glow"
            >
              <span id="cf-btn-text">Send Message</span>
              <span id="cf-btn-spinner" class="hidden font-body">Sending...</span>
              <!-- Paper plane icon -->
              <svg id="cf-btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .social-chip {
    width: 40px; height: 40px;
    border-radius: 10px;
    border: 1px solid var(--color-aso-border);
    background: transparent;
    color: var(--color-aso-text-secondary);
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .social-chip:hover {
    border-color: rgba(201, 162, 39, 0.4);
    color: var(--color-aso-gold);
    background: rgba(201, 162, 39, 0.06);
  }

  .aso-toast {
    padding: 14px 18px;
    border-radius: 12px;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 14px;
    display: flex; align-items: center; gap: 10px;
    min-width: 280px;
    pointer-events: auto;
    animation: toastIn 0.3s ease;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .aso-toast-success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #86efac;
  }
  .aso-toast-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
  }
  @keyframes toastIn {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0);    }
  }
</style>

<script is:inline>
  var form      = document.getElementById('contact-form');
  var submitBtn = document.getElementById('cf-submit');
  var btnText   = document.getElementById('cf-btn-text');
  var btnSpinner = document.getElementById('cf-btn-spinner');
  var btnIcon   = document.getElementById('cf-btn-icon');
  var toastWrap = document.getElementById('toast-wrap');

  function showToast(msg, type) {
    var t = document.createElement('div');
    t.className = 'aso-toast aso-toast-' + type;
    t.innerHTML = (type === 'success' ? '✓ ' : '✕ ') + msg;
    toastWrap.appendChild(t);
    setTimeout(function() {
      t.style.opacity = '0';
      t.style.transition = 'opacity 0.3s ease';
      setTimeout(function() { t.remove(); }, 300);
    }, 5000);
  }

  function setLoading(on) {
    submitBtn.disabled = on;
    btnText.style.display   = on ? 'none' : 'inline';
    btnSpinner.style.display = on ? 'inline' : 'none';
    btnIcon.style.display    = on ? 'none' : 'inline';
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    setLoading(true);

    var data = {
      name:    document.getElementById('cf-name').value,
      email:   document.getElementById('cf-email').value,
      service: document.getElementById('cf-service').value,
      message: document.getElementById('cf-message').value,
    };

    /* ── Replace the URL with your Formspree endpoint or API route ── */
    fetch('https://formspree.io/f/YOUR_FORMSPREE_ID', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(data),
    })
    .then(function(res) { return res.json(); })
    .then(function(result) {
      if (result.ok || result.next) {
        showToast("Message Sent! I'll respond within 24 hours.", 'success');
        form.reset();
      } else {
        throw new Error('Form error');
      }
    })
    .catch(function() {
      showToast('Something went wrong. Please try again.', 'error');
    })
    .finally(function() {
      setLoading(false);
    });
  });
</script>      radio.addEventListener("change", function(e) {
        if (hidden) hidden.value = e.target.value;
      });
    });
  });
</script>
