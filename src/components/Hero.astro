---
// src/components/Hero.astro
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-aso-black">
  <div class="absolute inset-0 hero-grid opacity-100 pointer-events-none"></div>

  <div
    class="absolute -top-[10%] -left-[10%] w-[600px] h-[600px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%)", filter: "blur(60px)" }}
  ></div>
  <div
    class="absolute -bottom-[10%] -right-[10%] w-[500px] h-[500px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%)", filter: "blur(80px)" }}
  ></div>

  <div class="relative z-10 w-full max-w-[1280px] mx-auto px-6 lg:px-10 pt-32 pb-24">
    
    <div class="inline-flex items-center gap-3 px-4 py-2 mb-8 rounded-full border border-aso-gold/30 bg-aso-gold/5 backdrop-blur-sm">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-aso-green opacity-75 pulse-green"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-aso-green"></span>
      </span>
      <span class="font-label text-xs font-bold tracking-widest uppercase text-aso-text-secondary">
        Available for freelance projects
      </span>
    </div>

    <h1 class="font-heading font-extrabold leading-[1.05] tracking-tight mb-6 flex flex-col">
      <span
        class="text-aso-text"
        style={{ fontSize: "clamp(3.5rem, 8vw, 7.5rem)", transitionDelay: "100ms" }}
      >
        AI-Powered
      </span>
      <span
        class="text-aso-gold shimmer-gold"
        style={{ fontSize: "clamp(3.5rem, 8vw, 7.5rem)", transitionDelay: "200ms" }}
      >
        Creative Studio
      </span>
    </h1>

    <p
      class="font-body text-aso-text-secondary max-w-2xl mb-10 leading-relaxed"
      style={{ fontSize: "clamp(1.125rem, 2vw, 1.25rem)", transitionDelay: "300ms" }}
    >
      We craft cinematic video experiences, premium brand identities, and intelligent digital interfaces built for the <strong class="text-aso-text font-medium">AI era.</strong>
    </p>

    <div class="flex flex-wrap items-center gap-4 mb-14" style={{ transitionDelay: "400ms" }}>
      <a href="#contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-aso-gold text-aso-black font-label font-bold rounded-full transition-transform hover:scale-105 gold-glow">
        Start a Project
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
      
      <a href="#work" class="inline-flex items-center justify-center px-8 py-4 border border-aso-gold/30 text-aso-text bg-transparent hover:bg-aso-gold/5 font-label font-bold rounded-full transition-colors">
        Explore Work
      </a>
    </div>

    <div class="pt-8 border-t border-aso-gold/10 flex flex-col sm:flex-row items-start sm:items-center gap-6" style={{ transitionDelay: "500ms" }}>
      
      <div class="flex -space-x-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-800 text-aso-text font-label text-sm font-bold z-10">TR</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-700 text-aso-text font-label text-sm font-bold z-20">AL</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-600 text-aso-text font-label text-sm font-bold z-30">MK</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-aso-gold text-aso-black font-label text-sm font-bold z-40">50+</div>
      </div>

      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-1">
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <span class="font-body text-sm text-aso-text-muted tracking-wide">
          Trusted by worldwide leading brands
        </span>
      </div>
    </div>
    
  </div>
</section>
        class="text-aso-gold shimmer-gold"
        style={{ fontSize: "clamp(3.5rem, 8vw, 7rem)", transitionDelay: "200ms" }}
      >
        Creative Studio
      </span>
    </h1>

    <!-- Main Descriptor -->
    <p
      class="font-body text-aso-text-secondary max-w-2xl mb-10 leading-relaxed"
      style={{ fontSize: "clamp(1.125rem, 2vw, 1.25rem)", transitionDelay: "300ms" }}
    >
      We craft cinematic video experiences, premium brand identities, and intelligent digital interfaces built for the <strong class="text-aso-text font-medium">AI era.</strong>
    </p>

    <!-- Action Button Group -->
    <div class="flex flex-wrap items-center gap-4 mb-14" style={{ transitionDelay: "400ms" }}>
      <!-- Primary Action CTA -->
      <a href="#start" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-aso-gold text-aso-black font-label font-bold rounded-full transition-transform hover:scale-105 gold-glow">
        Start a Project
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
      
      <!-- Secondary Action CTA -->
      <a href="#work" class="inline-flex items-center justify-center px-8 py-4 border border-aso-gold/30 text-aso-text bg-transparent hover:bg-aso-gold/5 font-label font-bold rounded-full transition-colors">
        Explore Work
      </a>
    </div>

    <!-- Social Proof / Trust Signature Block -->
    <div class="pt-8 border-t border-aso-gold/10 flex flex-col sm:flex-row items-start sm:items-center gap-6" style={{ transitionDelay: "500ms" }}>
      
      <!-- Overlapping Avatar Cluster -->
      <div class="flex -space-x-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-800 text-aso-text font-label text-sm font-bold z-10">TR</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-700 text-aso-text font-label text-sm font-bold z-20">AL</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-neutral-600 text-aso-text font-label text-sm font-bold z-30">MK</div>
        <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-aso-black bg-aso-gold text-aso-black font-label text-sm font-bold z-40">50+</div>
      </div>

      <!-- Trust Copy & Star Graphics -->
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-1">
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-5 h-5 text-aso-gold fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <span class="font-body text-sm text-aso-text-muted tracking-wide">
          Trusted by worldwide leading brands
        </span>
      </div>
    </div>
    
  </div>
</section>
