---
// Footer.astro
---

<footer class="relative bg-aso-surface border-t border-aso-border py-12">

  <!-- Gold top line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-px bg-gradient-to-r from-transparent via-aso-gold to-transparent pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline group">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-aso-gold to-aso-gold-glow flex items-center justify-center font-heading font-bold text-[11px] tracking-widest text-aso-black flex-shrink-0 transition-transform duration-200 group-hover:scale-105">
          ASO
        </div>
        <span class="font-heading font-semibold text-sm text-aso-text-secondary tracking-wide">
          Creative Studio
        </span>
      </a>

      <!-- Copyright -->
      <p class="font-label text-xs text-aso-text-muted tracking-wide text-center">
        © 2026 ASO Creative Studio. All rights reserved.
      </p>

      <!-- Back to top -->
      <button
        id="back-to-top"
        class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-aso-border bg-transparent text-aso-text-muted font-heading font-medium text-sm cursor-pointer transition-all duration-300 hover:border-aso-gold hover:text-aso-gold hover:bg-aso-gold/5"
        aria-label="Back to top"
      >
        Back to top
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m18 15-6-6-6 6"/>
        </svg>
      </button>

    </div>
  </div>
</footer>

<script is:inline>
  document.getElementById('back-to-top').addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
