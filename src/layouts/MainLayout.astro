---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ASO Creative Studio — AI-Powered Creative Agency",
  description = "Nigeria-based. Working worldwide.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-aso-black text-aso-text antialiased min-h-screen relative">
    
    <slot />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        
        /* 1. Bulletproof Mobile Menu Toggle */
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (menuToggle && mobileMenu) {
          menuToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
          });

          // Close overlay when clicking outside
          document.addEventListener('click', (e) => {
            if (!mobileMenu.contains(e.target as Node) && e.target !== menuToggle) {
              mobileMenu.classList.add('hidden');
              mobileMenu.classList.remove('flex');
            }
          });
        }

        /* 2. Unified Scroll, Counter, & Process Line Observer */
        const globalObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              
              // Reveal Scroll Elements
              if (entry.target.classList.contains('animate-on-scroll')) {
                entry.target.classList.add('fade-up-visible');
              }
              
              // Draw Process Timeline Lines
              if (entry.target.classList.contains('process-animated-line')) {
                entry.target.classList.add('line-active');
              }
              
              // Animate Stats Numbers
              if (entry.target.classList.contains('counter')) {
                const el = entry.target;
                const target = parseInt(el.getAttribute('data-target') || '0', 10);
                let current = 0;
                const duration = 1500;
                const step = Math.max(Math.floor(duration / target), 12);
                
                const timer = setInterval(() => {
                  current += 1;
                  el.textContent = current.toString();
                  if (current >= target) {
                    el.textContent = target.toString();
                    clearInterval(timer);
                  }
                }, step);
              }
              
              globalObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        // Register all elements into the global watcher engine
        document.querySelectorAll('.animate-on-scroll, .counter, .process-animated-line').forEach(el => {
          globalObserver.observe(el);
        });
      });
    </script>
  </body>
</html>
