---
const services = [
  {
    number: "01",
    title: "AI Video Creation",
    tagline: "Motion that converts",
    desc: "Cinematic, AI-enhanced video content that stops the scroll and drives action. From concept to final render.",
    offerings: ["Promotional Videos", "Social Media Reels", "Brand Storytelling", "Product Showcases"],
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  },
  {
    number: "02",
    title: "Graphic Design",
    tagline: "Visuals that speak",
    desc: "Premium brand visuals that communicate authority and build trust across every touchpoint your audience sees.",
    offerings: ["Business Branding", "Flyer Design", "Social Media Graphics", "Church Materials"],
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.437-.652-.437-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
  },
  {
    number: "03",
    title: "Web Development",
    tagline: "Experiences that perform",
    desc: "Fast, modern websites and web apps built to rank, convert, and scale with your business over time.",
    offerings: ["Business Websites", "E-Commerce", "Web Apps", "Landing Pages"],
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    number: "04",
    title: "AI Automation",
    tagline: "Systems that scale",
    desc: "Intelligent systems that eliminate repetitive work so you can focus on what matters most — growing your business.",
    offerings: ["Workflow Automation", "Chatbot Setup", "Email Sequences", "CRM Integration", "Social Media Automation"],
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4M8 16v.01M16 16v.01"/></svg>`,
  },
];
---

<section id="services" class="relative py-[120px] bg-aso-black overflow-hidden">

  <!-- Background grid -->
  <div class="absolute inset-0 hero-grid opacity-30 pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-px bg-gradient-to-r from-transparent via-aso-gold/40 to-transparent pointer-events-none"></div>

  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-label text-[11px] tracking-[0.35em] uppercase text-aso-gold">02 / What I Do</span>
        <div class="w-16 h-px bg-gradient-to-r from-aso-gold to-transparent"></div>
      </div>
      <h2 class="font-heading font-bold text-aso-text mb-4" style="font-size: clamp(2rem, 4vw, 3.25rem);">My Services</h2>
      <p class="font-body text-aso-text-secondary max-w-xl leading-relaxed">
        A focused set of services built for modern brands that want results — not just deliverables.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {services.map((s) => (
        <article class="card-hover group relative rounded-2xl border border-aso-border bg-aso-elevated p-8 cursor-pointer overflow-hidden">

          <!-- Subtle corner gradient -->
          <div class="absolute top-0 right-0 w-32 h-32 rounded-bl-full bg-aso-gold/5 pointer-events-none transition-opacity duration-300 opacity-0 group-hover:opacity-100"></div>

          <!-- Top row -->
          <div class="flex items-start justify-between mb-7">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-aso-gold/10 border border-aso-gold/20 flex items-center justify-center text-aso-gold transition-all duration-300 group-hover:bg-aso-gold/20 group-hover:border-aso-gold/50">
              <Fragment set:html={s.icon} />
            </div>
            <!-- Number + arrow -->
            <div class="flex items-center gap-3">
              <span class="font-label text-[11px] tracking-[0.2em] text-aso-text-muted">{s.number}</span>
              <div class="w-7 h-7 rounded-full bg-aso-gold/10 border border-aso-gold/25 flex items-center justify-center text-aso-gold text-xs opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
                ↗
              </div>
            </div>
          </div>

          <!-- Title + tagline -->
          <h3 class="font-heading font-bold text-[18px] text-aso-text mb-1 transition-colors duration-200 group-hover:text-aso-gold">
            {s.title}
          </h3>
          <p class="font-label text-[11px] tracking-[0.18em] uppercase text-aso-text-muted mb-4">{s.tagline}</p>

          <!-- Description -->
          <p class="font-body text-sm text-aso-text-secondary leading-relaxed mb-7">{s.desc}</p>

          <!-- Offerings -->
          <div class="flex flex-wrap gap-2">
            {s.offerings.map((item) => (
              <span class="font-label text-[11px] tracking-wide px-3 py-1 rounded-full border border-aso-border bg-aso-black/50 text-aso-text-muted transition-all duration-200 group-hover:border-aso-gold/20 group-hover:text-aso-text-secondary">
                {item}
              </span>
            ))}
          </div>

          <!-- Bottom gold line (draws in on hover) -->
          <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-aso-gold via-aso-gold-glow to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 flex justify-center">
      <a
        href="#contact"
        class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-gradient-to-br from-aso-gold to-aso-gold-glow font-heading font-semibold text-aso-black no-underline gold-glow transition-all duration-300 hover:scale-105"
      >
        Start a Project
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
