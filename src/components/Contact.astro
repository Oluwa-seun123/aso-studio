---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact — ASO Creative Studio"
  description="Get in touch with ASO Creative Studio. Let's build something extraordinary together."
>
  <main style="min-height:100vh; background:#050505; padding:120px 0 80px;">
    <div style="max-width:800px; margin:0 auto; padding:0 2.5rem;">

      <!-- Header -->
      <div style="text-align:center; margin-bottom:48px;">
        <div style="display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:20px;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.35em; text-transform:uppercase; color:#c9a227;">
            07 / Get In Touch
          </span>
        </div>
        <h1 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(2rem,5vw,3.5rem); line-height:1.1; color:#fafafa; margin:0 0 16px;">
          Let's Work Together
        </h1>
        <p style="font-family:'Inter',sans-serif; font-size:17px; color:#a1a1aa; line-height:1.7; margin:0; max-width:500px; margin-left:auto; margin-right:auto;">
          Tell me about your project and I'll get back to you within 24 hours.
        </p>
      </div>

      <!-- Service Type Picker -->
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:40px;">
        <label class="service-radio-label">
          <input type="radio" name="serviceType" value="web" class="sr-only" checked />
          <div class="service-radio-card">
            <span style="font-size:24px; margin-bottom:8px; display:block;">🌐</span>
            <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px; color:#fafafa;">Web Development</span>
          </div>
        </label>
        <label class="service-radio-label">
          <input type="radio" name="serviceType" value="ai" class="sr-only" />
          <div class="service-radio-card">
            <span style="font-size:24px; margin-bottom:8px; display:block;">🤖</span>
            <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px; color:#fafafa;">AI Automation</span>
          </div>
        </label>
        <label class="service-radio-label">
          <input type="radio" name="serviceType" value="multiple" class="sr-only" />
          <div class="service-radio-card">
            <span style="font-size:24px; margin-bottom:8px; display:block;">🎨</span>
            <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px; color:#fafafa;">Multiple Services</span>
          </div>
        </label>
      </div>

      <!-- Form -->
      <div style="background:#0a0a0a; border:1px solid #27272a; border-radius:20px; padding:40px;">
        <form
          id="contact-form"
          action="https://formspree.io/f/meedjqgv"
          method="POST"
        >
          <input type="hidden" name="service" id="serviceValue" value="web" />

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;" class="form-row">
            <div class="form-group">
              <label class="form-label">Name *</label>
              <input type="text" name="name" required class="form-input" placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label class="form-label">Email *</label>
              <input type="email" name="email" required class="form-input" placeholder="your@email.com" />
            </div>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label class="form-label">Message *</label>
            <textarea
              name="message"
              rows="5"
              required
              class="form-input"
              placeholder="Tell me about your project — goals, timeline, budget..."
              style="resize:vertical;"
            ></textarea>
          </div>

          <button type="submit" id="submit-btn">
            Send Message →
          </button>
        </form>
      </div>

      <!-- Calendly box -->
      <div style="margin-top:32px; padding:24px; border-radius:16px; border:1px solid rgba(201,162,39,0.25); background:rgba(201,162,39,0.05); text-align:center;">
        <p style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:15px; color:#fafafa; margin:0 0 6px;">Prefer to book a call?</p>
        <p style="font-family:'Inter',sans-serif; font-size:13px; color:#a1a1aa; margin:0 0 16px;">Schedule a free 30-minute discovery call on my calendar.</p>
        <a href="https://calendly.com/YOUR_CALENDLY_LINK" id="calendly-btn" target="_blank" rel="noopener noreferrer">
          Book a Call →
        </a>
      </div>

    </div>
  </main>
</MainLayout>

<style>
  /* Service radio cards */
  .service-radio-label { cursor: pointer; }
  .service-radio-card {
    padding: 16px;
    border-radius: 12px;
    border: 2px solid #27272a;
    text-align: center;
    transition: all 0.2s ease;
    background: #0a0a0a;
  }
  .service-radio-label input:checked + .service-radio-card {
    border-color: #c9a227;
    background: rgba(201,162,39,0.08);
  }
  .service-radio-card:hover {
    border-color: rgba(201,162,39,0.4);
  }

  /* Form elements */
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #a1a1aa;
  }
  .form-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid #27272a;
    background: #111111;
    color: #fafafa;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }
  .form-input:focus {
    border-color: rgba(201,162,39,0.5);
    box-shadow: 0 0 0 3px rgba(201,162,39,0.08);
  }
  .form-input::placeholder { color: #3f3f46; }

  /* Submit button */
  #submit-btn {
    width: 100%;
    padding: 16px 32px;
    border-radius: 9999px;
    border: none;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    color: #050505;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 24px rgba(201,162,39,0.3);
    margin-top: 8px;
  }
  #submit-btn:hover {
    box-shadow: 0 0 40px rgba(245,158,11,0.5);
    transform: translateY(-1px);
  }

  /* Calendly button */
  #calendly-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    border-radius: 9999px;
    border: 1px solid rgba(201,162,39,0.4);
    background: transparent;
    color: #c9a227;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  #calendly-btn:hover {
    background: rgba(201,162,39,0.1);
    border-color: #c9a227;
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr !important; }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Sync radio selection to hidden input
    const radios = document.querySelectorAll('input[name="serviceType"]');
    const hidden = document.getElementById("serviceValue");
    radios.forEach(function(radio) {
      radio.addEventListener("change", function(e) {
        if (hidden) hidden.value = e.target.value;
      });
    });
  });
</script>
