---
var props      = Astro.props;
var href       = props.href;
var variant    = props.variant || 'primary';
var btnSize    = props.size || 'md';
var btnType    = props.type || 'button';
var target     = props.target;
var rel        = props.rel;
var extraClass = props['class'] || '';

var base = 'inline-flex items-center justify-center gap-2 font-heading font-medium rounded-full transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none';

var variantMap = {
  primary:   'bg-aso-gold text-aso-black hover:gold-glow-strong',
  secondary: 'bg-aso-surface text-aso-text hover:bg-aso-elevated border border-aso-border',
  outline:   'border border-aso-border text-aso-text hover:border-aso-gold hover:text-aso-gold bg-transparent',
};

var sizeMap = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-4 text-base',
};

var variantClass = variantMap[variant] || variantMap['primary'];
var sizeClass    = sizeMap[btnSize]   || sizeMap['md'];
var classes      = [base, variantClass, sizeClass, extraClass].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button type={btnType} class={classes}>
    <slot />
  </button>
)}
