---
const projects = [
  {
    id: "p1",
    title: "AI Brand Campaign Video",
    desc: "A cinematic AI-generated brand launch video for a luxury fashion brand, blending storytelling with high-end visual effects to drive awareness and sales.",
    category: "AI Video",
    client: "VeeLuxe",
    date: "Oct 2024",
    tagColor:    "#c9a227",
    tagBg:       "rgba(201,162,39,0.12)",
    tagBorder:   "rgba(201,162,39,0.35)",
    iconBg:      "rgba(201,162,39,0.10)",
    iconBorder:  "rgba(201,162,39,0.25)",
    link: "#",
  },
  {
    id: "p2",
    title: "Complete Brand Identity System",
    desc: "Full brand identity for a fast-growing Nigerian tech startup — logo, colour system, typography, business cards, social media kit, and brand guidelines.",
    category: "Graphics",
    client: "BrandSpark",
    date: "Sep 2024",
    tagColor:    "#818cf8",
    tagBg:       "rgba(129,140,248,0.12)",
    tagBorder:   "rgba(129,140,248,0.35)",
    iconBg:      "rgba(129,140,248,0.10)",
    iconBorder:  "rgba(129,140,248,0.25)",
    link: "#",
  },
  {
    id: "p3",
    title: "E-Commerce Website Redesign",
    desc: "A full redesign and rebuild of an e-commerce storefront — mobile-first layout, seamless checkout, and Paystack integration.",
    category: "Web Dev",
    client: "VibeMedia",
    date: "Jul 2024",
    tagColor:    "#2dd4bf",
    tagBg:       "rgba(45,212,191,0.12)",
    tagBorder:   "rgba(45,212,191,0.35)",
    iconBg:      "rgba(45,212,191,0.10)",
    iconBorder:  "rgba(45,212,191,0.25)",
    link: "#",
  },
  {
    id: "p4",
    title: "Customer Support Chatbot Automation",
    desc: "Built and deployed an AI-powered chatbot with automated email sequences and CRM integration, cutting response time by 80%.",
    category: "AI Automation",
    client: "AutoFlow Co.",
    date: "Jun 2024",
    tagColor:    "#f472b6",
    tagBg:       "rgba(244,114,182,0.12)",
    tagBorder:   "rgba(244,114,182,0.35)",
    iconBg:      "rgba(244,114,182,0.10)",
    iconBorder:  "rgba(244,114,182,0.25)",
    link: "#",
  },
];

const filters = ["All", "AI Video", "Graphics", "Web Dev", "AI Automation"];
---

<section id="work" class="relative py-[120px] bg-aso-black overflow-hidden">

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-px bg-gradient-to-r from-transparent via-aso-gold/30 to-transparent pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-label text-[11px] tracking-[0.35em] uppercase text-aso-gold">04 / Portfolio</span>
        <div class="w-16 h-px bg-gradient-to-r from-aso-gold to-transparent"></div>
      </div>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <h2 class="font-heading font-bold text-aso-text text-display-lg">My Works</h2>
        <p class="font-body text-sm text-aso-text-muted max-w-xs leading-relaxed lg:text-right">
          A selection of projects across every service.<br />Each one built with intention.
        </p>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-12" id="filter-bar" role="tablist">
      {filters.map((f, i) => (
        <button
          class={i === 0
            ? "filter-btn font-label text-[11px] tracking-[0.18em] uppercase px-5 py-2.5 rounded-full border cursor-pointer bg-aso-gold border-aso-gold text-aso-black transition-all duration-200"
            : "filter-btn font-label text-[11px] tracking-[0.18em] uppercase px-5 py-2.5 rounded-full border cursor-pointer bg-transparent border-aso-border text-aso-text-secondary hover:border-aso-gold hover:text-aso-gold transition-all duration-200"}
          data-filter={f}
          role="tab"
        >
          {f}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="projects-grid">
      {projects.map((p) => (
        <article
          class="group relative rounded-2xl border border-aso-border bg-aso-elevated overflow-hidden transition-all duration-300 hover:border-aso-gold hover:-translate-y-1 hover:shadow-[0_0_32px_rgba(201,162,39,0.1)]"
          data-category={p.category}
        >
          <!-- Image container -->
          <div class="relative overflow-hidden" style="aspect-ratio:16/10;">
            <!-- Placeholder gradient — replace with <img> when you have images -->
            <div class="w-full h-full flex items-center justify-center" style={`background: linear-gradient(135deg, #0f0f0f, ${p.tagBg});`}>
              <span class="font-label text-xs tracking-[0.2em] uppercase" style={`color: ${p.tagColor};`}>{p.category}</span>
            </div>

            <!-- Hover overlay -->
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 backdrop-blur-sm" style="background:rgba(5,5,5,0.72);">
              <a
                href={p.link}
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-heading font-semibold text-sm text-aso-black no-underline transition-transform duration-200 hover:scale-105"
                style={`background: linear-gradient(135deg, #c9a227, #f59e0b);`}
              >
                View Project
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>

            <!-- Category badge -->
            <div class="absolute top-4 left-4">
              <span
                class="font-label text-[10px] tracking-[0.18em] uppercase px-3 py-1.5 rounded-full"
                style={`background: ${p.tagBg}; border: 1px solid ${p.tagBorder}; color: ${p.tagColor};`}
              >
                {p.category}
              </span>
            </div>
          </div>

          <!-- Card body -->
          <div class="p-6">
            <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-text-muted mb-2">
              {p.client} &middot; {p.date}
            </p>
            <h3 class="font-heading font-bold text-[17px] text-aso-text mb-3 leading-tight transition-colors duration-200 group-hover:text-aso-gold">
              {p.title}
            </h3>
            <p class="font-body text-sm text-aso-text-secondary leading-relaxed mb-5 line-clamp-2">
              {p.desc}
            </p>
            <div class="flex items-center justify-between">
              <div class="h-px flex-1 mr-4 bg-aso-border"></div>
              <div
                class="w-8 h-8 rounded-full flex items-center justify-center text-sm transition-transform duration-300 group-hover:scale-110"
                style={`background: ${p.iconBg}; border: 1px solid ${p.iconBorder}; color: ${p.tagColor};`}
              >
                &#x2197;
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="portfolio-empty" class="hidden flex-col items-center justify-center py-20 text-center">
      <p class="font-heading text-lg text-aso-text-secondary">No projects in this category yet.</p>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 flex justify-center">
      <a
        href="#contact"
        class="group inline-flex items-center gap-2.5 px-8 py-4 rounded-full border border-aso-border text-aso-text-secondary bg-transparent no-underline transition-all duration-300 hover:border-aso-gold hover:text-aso-gold font-heading font-semibold"
      >
        Have a project in mind?
        <svg class="transition-transform duration-200 group-hover:translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script is:inline>
  var filterBtns = document.querySelectorAll('.filter-btn');
  var cards      = document.querySelectorAll('[data-category]');
  var emptyState = document.getElementById('portfolio-empty');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = this.getAttribute('data-filter');

      filterBtns.forEach(function(b) {
        b.classList.remove('bg-aso-gold', 'border-aso-gold', 'text-aso-black');
        b.classList.add('bg-transparent', 'border-aso-border', 'text-aso-text-secondary');
      });
      this.classList.remove('bg-transparent', 'border-aso-border', 'text-aso-text-secondary');
      this.classList.add('bg-aso-gold', 'border-aso-gold', 'text-aso-black');

      var visible = 0;
      cards.forEach(function(card) {
        if (filter === 'All' || card.getAttribute('data-category') === filter) {
          card.classList.remove('filter-hidden');
          visible++;
        } else {
          card.classList.add('filter-hidden');
        }
      });

      if (emptyState) {
        emptyState.style.display = visible === 0 ? 'flex' : 'none';
      }
    });
  });
</script>
