    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="block px-3 py-3 text-base font-medium text-gray-700 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg transition-colors"
        >
          {link.name}
        </a>
      ))}
      <a 
        href="/contact" 
        class="block px-3 py-3 text-base font-medium text-white bg-amber-500 rounded-lg hover:bg-amber-600 transition-colors text-center mt-4"
      >
        Get Started
      </a>
    </div>
  </div>
</nav>

