---
interface Props {
  title: string;
  description: string;
  category: string;
  image: string;
  link?: string;
  client?: string;
  slug: string;
}

const { title, description, category, image, link, client, slug } = Astro.props;

const categoryColors: Record<string, string> = {
  "AI Video":      "rgba(201,162,39,0.15)",
  "Graphics":      "rgba(99,102,241,0.15)",
  "Web Dev":       "rgba(20,184,166,0.15)",
  "AI Automation": "rgba(236,72,153,0.15)",
};
const categoryBorderColors: Record<string, string> = {
  "AI Video":      "rgba(201,162,39,0.35)",
  "Graphics":      "rgba(99,102,241,0.35)",
  "Web Dev":       "rgba(20,184,166,0.35)",
  "AI Automation": "rgba(236,72,153,0.35)",
};
const categoryTextColors: Record<string, string> = {
  "AI Video":      "#c9a227",
  "Graphics":      "#818cf8",
  "Web Dev":       "#2dd4bf",
  "AI Automation": "#f472b6",
};

const bgColor  = categoryColors[category]       ?? "rgba(201,162,39,0.1)";
const bdColor  = categoryBorderColors[category] ?? "rgba(201,162,39,0.3)";
const txtColor = categoryTextColors[category]   ?? "#c9a227";
---

<article
  class="project-card group relative rounded-2xl overflow-hidden border transition-all duration-400"
  style="background:#0a0a0a; border-color:#27272a;"
  data-category={category}
  aria-label={`Project: ${title}`}
>
  <!-- Image Container -->
  <div class="relative overflow-hidden" style="aspect-ratio:16/10;">

    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />

    <!-- Fallback -->
    <div
      class="absolute inset-0 items-center justify-center hidden"
      style="background:linear-gradient(135deg,#0f0f0f,#1a1a1a);"
      aria-hidden="true"
    >
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#52525b;">
        {category}
      </span>
    </div>

    <!-- Hover overlay — THIS WAS THE BUG: <a tag was missing -->
    <div
      class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300"
      style="background:rgba(5,5,5,0.75); backdrop-filter:blur(4px);"
      aria-hidden="true"
    >
      <a
        href={link ?? "#work"}
        target={link ? "_blank" : "_self"}
        rel="noopener noreferrer"
        class="view-project-btn"
        tabindex="-1"
      >
        View Project ↗
      </a>
    </div>

    <!-- Category badge -->
    <div class="absolute top-4 left-4">
      <span
        style={`font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; padding:6px 12px; border-radius:9999px; background:${bgColor}; border:1px solid ${bdColor}; color:${txtColor};`}
      >
        {category}
      </span>
    </div>

  </div>

  <!-- Card Body -->
  <div style="padding:24px;">

    {client && (
      <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:#52525b; margin:0 0 8px;">
        {client}
      </p>
    )}

    <h3 class="card-title">
      {title}
    </h3>

    <p style="font-family:'Inter',sans-serif; font-size:14px; color:#a1a1aa; line-height:1.7; margin:0 0 20px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
      {description}
    </p>

    <div style="display:flex; align-items:center; justify-content:space-between;">
      <div style="height:1px; flex:1; margin-right:16px; background:#27272a;"></div>
      <div
        style={`width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:${bgColor}; border:1px solid ${bdColor}; color:${txtColor}; font-size:14px; transition:transform 0.3s ease;`}
        aria-hidden="true"
      >
        ↗
      </div>
    </div>

  </div>

  <!-- Bottom border glow -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-left"
    style="background:linear-gradient(90deg,#c9a227,#f59e0b,transparent);"
    aria-hidden="true"
  ></div>

</article>

<style is:global>
  .project-card:hover {
    border-color: rgba(201,162,39,0.3) !important;
    box-shadow: 0 0 24px rgba(201,162,39,0.1), 0 16px 48px rgba(0,0,0,0.6);
    transform: translateY(-4px);
  }

  .card-title {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: #fafafa;
    margin: 0 0 12px;
    line-height: 1.3;
    transition: color 0.2s ease;
  }
  .project-card:hover .card-title { color: #c9a227; }

  .view-project-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #050505;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .view-project-btn:hover { transform: scale(1.05); }
</style>
