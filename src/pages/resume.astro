  <title>Samuel Aina — Resume | ASO Creative Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #f0f0f0;
      color: #1a1a1a;
      line-height: 1.6;
    }

    /* ── Top bar (hidden when printing) ── */
    .topbar {
      position: sticky; top: 0; z-index: 100;
      background: #c9a227;
      padding: 12px 24px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .topbar-title {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700; font-size: 15px; color: #050505;
    }
    .topbar-actions { display: flex; gap: 10px; }
    .btn-print {
      background: #050505; color: #c9a227;
      border: none; padding: 8px 20px;
      border-radius: 999px; cursor: pointer;
      font-weight: 600; font-size: 13px; font-family: 'Inter', sans-serif;
      text-decoration: none;
      display: inline-flex; align-items: center;
    }
    .btn-back {
      background: transparent; color: #050505;
      border: 2px solid #050505; padding: 6px 18px;
      border-radius: 999px; font-weight: 600;
      font-size: 13px; text-decoration: none;
      font-family: 'Inter', sans-serif;
      display: inline-flex; align-items: center;
    }

    /* Mobile / Desktop toggle — FIXED: renamed to avoid class: keyword */
    .mobileOnly  { display: none; }
    .desktopOnly { display: inline-flex; }

    /* ── Resume page ── */
    .page {
      max-width: 800px; margin: 32px auto 64px;
      background: white; padding: 52px 56px;
      box-shadow: 0 4px 40px rgba(0,0,0,0.12);
    }

    /* ── Header ── */
    .r-header { border-bottom: 3px solid #c9a227; padding-bottom: 24px; margin-bottom: 32px; }
    .r-name   { font-family: 'Space Grotesk', sans-serif; font-size: 36px; font-weight: 700; color: #050505; }
    .r-role   { font-size: 15px; color: #c9a227; font-weight: 600; margin-top: 4px; letter-spacing: 0.05em; text-transform: uppercase; }
    .r-contacts {
      display: flex; flex-wrap: wrap; gap: 6px 20px;
      margin-top: 12px; font-size: 13px; color: #444;
    }
    .r-contacts a { color: #444; text-decoration: none; }
    .r-contacts a:hover { color: #c9a227; }

    /* ── Section ── */
    .r-section { margin-bottom: 28px; }
    .r-section-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #c9a227; border-bottom: 1px solid #e8e8e8;
      padding-bottom: 6px; margin-bottom: 16px;
    }

    /* ── Experience item ── */
    .r-item { margin-bottom: 20px; }
    .r-item-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .r-item-title { font-weight: 700; font-size: 15px; color: #050505; }
    .r-item-company { font-weight: 500; color: #555; font-size: 14px; }
    .r-item-date { font-size: 12px; color: #888; white-space: nowrap; flex-shrink: 0; }
    .r-item ul { margin-top: 8px; padding-left: 18px; }
    .r-item li { font-size: 13px; color: #333; margin-bottom: 4px; }

    /* ── Skills grid ── */
    .r-skills { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .r-skill-group-title { font-weight: 600; font-size: 13px; color: #050505; margin-bottom: 6px; }
    .r-skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .r-tag {
      background: #f5f5f5; color: #333; border: 1px solid #e0e0e0;
      padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 500;
    }

    /* ── Education ── */
    .r-edu-header { display: flex; justify-content: space-between; }
    .r-edu-school { font-weight: 700; font-size: 15px; color: #050505; }
    .r-edu-degree { font-size: 13px; color: #555; margin-top: 2px; }
    .r-edu-thesis { font-size: 12px; color: #777; margin-top: 6px; font-style: italic; }

    /* ── Certifications ── */
    .r-cert { margin-bottom: 10px; }
    .r-cert-title { font-weight: 600; font-size: 14px; color: #050505; }
    .r-cert-org { font-size: 13px; color: #555; }

    /* ── Projects ── */
    .r-project { margin-bottom: 14px; }
    .r-project-name { font-weight: 600; font-size: 14px; color: #050505; }
    .r-project-tech { font-size: 11px; color: #c9a227; font-weight: 600; margin-left: 8px; }
    .r-project-desc { font-size: 13px; color: #444; margin-top: 2px; }

    /* ── Print styles ── */
    @media print {
      .topbar    { display: none !important; }
      body       { background: white; }
      .page      { margin: 0; box-shadow: none; padding: 32px 40px; }
      @page      { margin: 1cm; size: A4; }
    }

    @media (max-width: 600px) {
      .page { padding: 32px 24px; }
      .r-skills { grid-template-columns: 1fr; }
      .r-item-header { flex-direction: column; }
      .mobileOnly  { display: inline-flex; }
      .desktopOnly { display: none; }
    }
  </style>
</head>
