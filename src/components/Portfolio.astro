---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const allProjects = await getCollection("projects");

const sortedProjects = allProjects.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const filters = ["All", "AI Video", "Graphics", "Web Dev", "AI Automation"];
---

<section
  id="work"
  class="relative py-[120px] overflow-hidden bg-surface"
  aria-labelledby="portfolio-heading"
>
  <!-- Background grid -->
  <div
    class="absolute inset-0 opacity-[0.02]"
    style="background-image: radial-gradient(circle, #a1a1aa 1px, transparent 1px); background-size: 36px 36px;"
    aria-hidden="true"
  ></div>

  <!-- Top ambient line -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-px"
    style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.3), transparent);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10">

    <!-- Section Header -->
    <div class="mb-12 gsap-hidden">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-label text-xs tracking-[0.35em] uppercase text-gold">
          04 / Portfolio
        </span>
        <div
          class="flex-1 h-px max-w-[60px]"
          style="background: linear-gradient(90deg, #c9a227, transparent);"
          aria-hidden="true"
        ></div>
      </div>

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <h2
          id="portfolio-heading"
          class="font-heading font-bold text-primary text-display-md"
        >
          My Works
        </h2>
        <p class="font-body text-sm text-muted max-w-xs leading-relaxed lg:text-right">
          A selection of projects across every service.
          <br />Each one built with intention.
        </p>
      </div>
    </div>

    <!-- Filter Buttons -->
    <div
      class="flex flex-wrap gap-3 mb-12 gsap-hidden"
      role="tablist"
      aria-label="Filter projects by category"
      id="filter-bar"
    >
      {filters.map((filter, i) => (
        <button
          class="filter-btn font-label text-xs tracking-[0.18em] uppercase px-5 py-2.5 rounded-full border transition-all duration-250"
          data-filter={filter}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          style={
            i === 0
              ? "background: #c9a227; border-color: #c9a227; color: #050505;"
              : "background: transparent; border-color: #27272a; color: #a1a1aa;"
          }
        >
          {filter}
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    <div
      id="projects-grid"
      class="grid grid-cols-1 md:grid-cols-2 gap-6"
      role="tabpanel"
      aria-label="Project list"
    >
      {sortedProjects.map((project) => (
        <div
          class="project-item"
          data-category={project.data.category}
        >
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            image={project.data.image}
            link={project.data.link}
            client={project.data.client}
            slug={project.slug}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div
      id="empty-state"
      class="hidden flex-col items-center justify-center py-20 text-center"
    >
      <div
        class="w-14 h-14 rounded-full flex items-center justify-center mb-4 bg-gold/10 border border-gold/20"
      >
        <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
        </svg>
      </div>
      <p class="font-heading text-lg text-secondary">No projects in this category yet.</p>
      <p class="font-body text-sm text-muted mt-2">Check back soon.</p>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 flex justify-center gsap-hidden">
      <a
        href="#contact"
        class="group inline-flex items-center gap-2.5 px-8 py-4 rounded-full font-heading font-semibold text-[15px] border border-border text-secondary bg-transparent transition-all duration-300 hover:border-gold hover:text-gold"
      >
        Have a project in mind?
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  window.addEventListener("load", () => {

    /* GSAP scale-in for cards */
    if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
      const items = document.querySelectorAll(".project-item");
      gsap.fromTo(
        items,
        { opacity: 0, scale: 0.94, y: 20 },
        {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 0.55,
          ease: "power3.out",
          stagger: 0.1,
          scrollTrigger: {
            trigger: "#projects-grid",
            start: "top 85%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    /* Category Filtering */
    const filterBtns = document.querySelectorAll(".filter-btn");
    const projectItems = document.querySelectorAll(".project-item");
    const emptyState = document.getElementById("empty-state");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const selected = btn.getAttribute("data-filter") ?? "All";

        /* Update button styles */
        filterBtns.forEach((b) => {
          const isActive = b === btn;
          b.style.background     = isActive ? "#c9a227"    : "transparent";
          b.style.borderColor    = isActive ? "#c9a227"    : "#27272a";
          b.style.color          = isActive ? "#050505"    : "#a1a1aa";
          b.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        /* Show/hide project items */
        let visibleCount = 0;
        projectItems.forEach((item) => {
          const cat = item.getAttribute("data-category") ?? "";
          const show = selected === "All" || cat === selected;

          if (show) {
            item.style.display = "block";
            item.style.animation = "filterFadeIn 0.35s ease forwards";
            visibleCount++;
          } else {
            item.style.display = "none";
          }
        });

        /* Toggle empty state */
        if (emptyState) {
          emptyState.style.display = visibleCount === 0 ? "flex" : "none";
        }
      });
    });
  });
</script>
