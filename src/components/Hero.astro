---
// Hero.astro
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">

  <!-- Background layers -->
  <div class="absolute inset-0 bg-aso-black z-0"></div>
  <div class="absolute inset-0 dot-grid z-0 opacity-100"></div>
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-aso-gold/10 rounded-full blur-[120px] animate-pulse z-0"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-aso-gold-glow/5 rounded-full blur-[100px] animate-pulse z-0" style="animation-delay:1s;"></div>

  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-8 text-center">

    <!-- Availability badge -->
    <div class="hero-item gsap-hidden inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-aso-surface border border-aso-border mb-8">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
      </span>
      <span class="text-sm text-aso-text-secondary font-medium">Available for freelance work</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-item gsap-hidden mb-6">
      <span class="block font-heading font-bold text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-aso-text tracking-tight leading-[1.05]">
        AI-Powered
      </span>
      <span class="block font-heading font-bold text-5xl sm:text-6xl md:text-7xl lg:text-8xl gradient-text tracking-tight leading-[1.05] mt-2">
        Creative Studio
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-item gsap-hidden mt-6 text-lg sm:text-xl text-aso-text-secondary max-w-2xl mx-auto leading-relaxed mb-10">
      I craft <span class="text-aso-gold font-medium">AI videos</span>,
      <span class="text-aso-gold font-medium">stunning graphics</span>,
      <span class="text-aso-gold font-medium">modern websites</span>, and
      <span class="text-aso-gold font-medium">smart automations</span> that help brands grow faster and work smarter.
    </p>

    <!-- CTAs -->
    <div class="hero-item gsap-hidden flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a href="#work" class="group inline-flex items-center gap-2 px-8 py-4 rounded-full bg-aso-gold text-aso-black font-heading font-semibold transition-all duration-300 hover:gold-glow-strong transform hover:-translate-y-1">
        View My Work
        <i data-lucide="arrow-down" class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-1"></i>
      </a>
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-full border border-aso-border text-aso-text hover:border-aso-gold hover:text-aso-gold transition-all duration-300 transform hover:-translate-y-1">
        Start a Project
      </a>
    </div>

    <!-- Social proof -->
    <p class="hero-item gsap-hidden text-sm text-aso-text-muted font-mono tracking-wide">
      Trusted by brands worldwide &nbsp;&bull;&nbsp; 100% Remote
    </p>

  </div>

  <!-- Scroll chevron -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <a href="#stats" class="text-aso-text-muted hover:text-aso-gold transition-colors duration-300">
      <i data-lucide="chevron-down" class="w-6 h-6"></i>
    </a>
  </div>

</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (!window.gsap) return;
    var items = document.querySelectorAll('.hero-item');
    items.forEach(function (item) {
      item.classList.remove('gsap-hidden');
    });
    window.gsap.fromTo(
      items,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: 'power3.out',
        delay: 0.2
      }
    );
  });
</script>
