---
const services = [
  {
    icon: "🎬",
    number: "01",
    title: "AI Video Creation",
    tagline: "Motion that converts",
    description: "Cinematic, AI-enhanced video content that stops the scroll and drives action. From concept to final render.",
    offerings: ["Promotional Videos", "Social Media Reels", "Brand Storytelling", "Product Showcases"],
  },
  {
    icon: "🎨",
    number: "02",
    title: "Graphic Design",
    tagline: "Visuals that speak",
    description: "Premium brand visuals that communicate authority and build trust across every touchpoint your audience sees.",
    offerings: ["Business Branding", "Flyer Design", "Social Media Graphics", "Church Materials"],
  },
  {
    icon: "💻",
    number: "03",
    title: "Web Development",
    tagline: "Experiences that perform",
    description: "Fast, modern websites and web apps built to rank, convert, and scale with your business over time.",
    offerings: ["Business Websites", "E-Commerce", "Web Apps", "Landing Pages"],
  },
  {
    icon: "🤖",
    number: "04",
    title: "AI Automation",
    tagline: "Systems that scale",
    description: "Intelligent systems that eliminate repetitive work so you can focus on growing your business.",
    offerings: ["Workflow Automation", "Chatbot Setup", "Email Sequences", "CRM Integration", "Social Media Automation"],
  },
];
---

<section
  id="services"
  style="position:relative; padding:120px 0; overflow:hidden; background:#050505;"
>
  <!-- Background grid -->
  <div style="position:absolute; inset:0; opacity:0.025; background-image:radial-gradient(circle,#a1a1aa 1px,transparent 1px); background-size:40px 40px;"></div>

  <!-- Top line -->
  <div style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:700px; height:1px; background:linear-gradient(90deg,transparent,rgba(201,162,39,0.4),transparent);"></div>

  <div style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:0 2.5rem;">

    <!-- Header -->
    <div style="margin-bottom:64px;">
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.35em; text-transform:uppercase; color:#c9a227;">02 / What I Do</span>
        <div style="width:60px; height:1px; background:linear-gradient(90deg,#c9a227,transparent);"></div>
      </div>
      <h2 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(2rem,4vw,3.25rem); line-height:1.1; color:#fafafa; margin:0 0 16px;">My Services</h2>
      <p style="font-family:'Inter',sans-serif; color:#a1a1aa; max-width:480px; line-height:1.6; margin:0;">
        A focused set of services built for modern brands that want results — not just deliverables.
      </p>
    </div>

    <!-- Cards Grid -->
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:20px;" id="services-grid">
      {services.map((service) => (
        <article class="service-card">
          <!-- Top row -->
          <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:28px;">
            <div class="service-icon-box">
              <span style="font-size:20px;">{service.icon}</span>
            </div>
            <div style="display:flex; align-items:center; gap:12px;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.2em; color:#52525b;">{service.number}</span>
              <div class="service-arrow">↗</div>
            </div>
          </div>

          <!-- Title -->
          <h3 class="service-title">{service.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#52525b; margin:0 0 16px;">{service.tagline}</p>

          <!-- Description -->
          <p style="font-family:'Inter',sans-serif; font-size:14px; color:#a1a1aa; line-height:1.7; margin:0 0 28px;">{service.description}</p>

          <!-- Tags -->
          <div style="display:flex; flex-wrap:wrap; gap:8px;">
            {service.offerings.map((item) => (
              <span class="service-tag">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div style="margin-top:56px; display:flex; justify-content:center;">
      <a href="#contact" id="services-cta">Start a Project →</a>
    </div>

  </div>
</section>

<style>
  .service-card {
    background: #0a0a0a;
    border: 1px solid #27272a;
    border-radius: 16px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .service-card:hover {
    border-color: rgba(201,162,39,0.5);
    transform: translateY(-8px);
    box-shadow: 0 0 32px rgba(201,162,39,0.15), 0 20px 60px rgba(0,0,0,0.5);
  }

  .service-icon-box {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(201,162,39,0.08);
    border: 1px solid rgba(201,162,39,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .service-card:hover .service-icon-box {
    background: rgba(201,162,39,0.15);
    border-color: rgba(201,162,39,0.45);
  }

  .service-arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(201,162,39,0.1);
    border: 1px solid rgba(201,162,39,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c9a227;
    font-size: 14px;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s ease;
  }
  .service-card:hover .service-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .service-title {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #fafafa;
    margin: 0 0 6px;
    transition: color 0.2s ease;
  }
  .service-card:hover .service-title { color: #c9a227; }

  .service-tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 6px 12px;
    border-radius: 9999px;
    background: rgba(255,255,255,0.04);
    border: 1px solid #27272a;
    color: #a1a1aa;
    transition: all 0.2s ease;
  }
  .service-card:hover .service-tag {
    border-color: rgba(201,162,39,0.2);
    color: #d4d4d8;
  }

  #services-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #050505;
    text-decoration: none;
    box-shadow: 0 0 24px rgba(201,162,39,0.35);
    transition: all 0.3s ease;
  }
  #services-cta:hover {
    box-shadow: 0 0 40px rgba(245,158,11,0.5);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    #services-grid { grid-template-columns: 1fr !important; }
  }
</style>
