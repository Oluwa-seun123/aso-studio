---
// src/components/Hero.astro
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-aso-black">
  <div class="absolute inset-0 hero-grid opacity-100 pointer-events-none"></div>

  <!-- Ambient Glows using correct JSX Style Object Syntax -->
  <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%)", filter: "blur(60px)" }}>
  </div>

  <div class="absolute -bottom-40 -right-20 w-[500px] h-[500px] rounded-full pointer-events-none"
    style={{ background: "radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%)", filter: "blur(80px)" }}>
  </div>

  <div class="relative z-10 max-w-[1280px] mx-auto px-6 lg:px-10 pt-32 pb-24">
    <div class="max-w-4xl">

      <!-- Status Tag -->
      <div class="animate-on-scroll inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-aso-gold/30 bg-aso-gold/5 mb-8">
        <span class="relative flex w-2.5 h-2.5">
          <span class="pulse-green absolute inline-flex w-full h-full rounded-full bg-aso-green opacity-75"></span>
          <span class="relative inline-flex w-2.5 h-2.5 rounded-full bg-aso-green"></span>
        </span>
        <span class="font-label text-[11px] tracking-[0.15em] uppercase text-aso-gold">
          Available for freelance work
        </span>
      </div>

      <!-- Heading Elements using safe JSX styles for clamping and delays -->
      <h1 class="font-heading font-bold leading-[1.05] mb-6">
        <span class="animate-on-scroll block text-aso-text" style={{ fontSize: "clamp(3rem, 8vw, 7rem)", transitionDelay: "100ms" }}>
          AI-Powered
        </span>
        <span class="animate-on-scroll block shimmer-gold" style={{ fontSize: "clamp(3rem, 8vw, 7rem)", transitionDelay: "200ms" }}>
          Creative Studio
        </span>
      </h1>

      <p class="animate-on-scroll font-body text-aso-text-secondary leading-relaxed mb-10 max-w-2xl text-balance"
        style={{ fontSize: "clamp(1.05rem, 2vw, 1.25rem)", transitionDelay: "300ms" }}>
        From cinematic AI videos and premium brand graphics to full web experiences
        and intelligent automation — everything your brand needs to stand out in the
        <strong class="text-aso-text font-medium">AI era.</strong>
      </p>

      <!-- CTAs System -->
      <div class="animate-on-scroll flex flex-wrap items-center gap-4 mb-14" style={{ transitionDelay: "400ms" }}>
        <a href="#contact" class="gold-glow inline-flex items-center justify-center px-8 py-4 rounded-full bg-aso-text text-aso-black font-label text-[13px] tracking-[0.1em] uppercase hover:bg-aso-text-secondary transition-all duration-300">
          Start a Project
          <svg class="w-4 h-4 ml-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
        <a href="#work" class="inline-flex items-center justify-center px-8 py-4 rounded-full border border-aso-gold/30 bg-aso-gold/5 text-aso-gold font-label text-[13px] tracking-[0.1em] uppercase hover:bg-aso-gold/10 transition-all duration-300">
          Explore Work
        </a>
      </div>

      <!-- Avatar Stacks & Metric Counter Section -->
      <div class="animate-on-scroll flex flex-wrap items-center gap-6 pt-8 border-t border-aso-gold/10" style={{ transitionDelay: "500ms" }}>
        <div class="flex -space-x-3">
          <div class="w-11 h-11 rounded-full border-2 border-aso-black bg-aso-gold/20 flex items-center justify-center text-aso-gold font-label text-xs">
            TR
          </div>
          <div class="w-11 h-11 rounded-full border-2 border-aso-black bg-aso-gold/30 flex items-center justify-center text-aso-gold font-label text-xs">
            AL
          </div>
          <div class="w-11 h-11 rounded-full border-2 border-aso-black bg-aso-gold/40 flex items-center justify-center text-aso-gold font-label text-xs">
            MK
          </div>
          <div class="w-11 h-11 rounded-full border-2 border-aso-black bg-aso-gold flex items-center justify-center text-aso-black font-label text-xs font-bold">
            50+
          </div>
        </div>
        
        <div class="flex flex-col">
          <div class="flex items-center gap-1 mb-1 text-aso-gold text-sm">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <span class="font-body text-[13px] text-aso-text-muted">
            Trusted by 50+ visionary brands worldwide
          </span>
        </div>
      </div>

    </div>
  </div>
</section>
