---
// Contact.astro
---

<section
  id="contact"
  style="position:relative; padding:120px 0; overflow:hidden; background:#0f0f0f;"
>
  <!-- Background -->
  <div style="position:absolute; inset:0; opacity:0.02; background-image:radial-gradient(circle,#a1a1aa 1px,transparent 1px); background-size:36px 36px;"></div>
  <div style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:700px; height:1px; background:linear-gradient(90deg,transparent,rgba(201,162,39,0.3),transparent);"></div>

  <!-- Toast container -->
  <div id="toast-container" style="position:fixed; top:24px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:12px; pointer-events:none;"></div>

  <div style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:0 2.5rem;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:flex-start;" class="contact-grid">

      <!-- ── LEFT: Info ── -->
      <div id="contact-left" style="opacity:0; transform:translateY(32px);">

        <!-- Label -->
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.35em; text-transform:uppercase; color:#c9a227;">07 / Get In Touch</span>
          <div style="width:60px; height:1px; background:linear-gradient(90deg,#c9a227,transparent);"></div>
        </div>

        <!-- Headline -->
        <h2 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(2rem,4vw,3.25rem); line-height:1.1; color:#fafafa; margin:0 0 20px;">
          Let's Create Something<br>
          <span style="background:linear-gradient(135deg,#c9a227,#f59e0b); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Extraordinary</span>
        </h2>

        <p style="font-family:'Inter',sans-serif; font-size:15px; color:#a1a1aa; line-height:1.7; margin:0 0 40px; max-width:420px;">
          Have a project in mind? I'd love to hear about it. Send me a message and let's talk about how we can bring your vision to life.
        </p>

        <!-- Contact Info -->
        <div style="display:flex; flex-direction:column; gap:16px; margin-bottom:40px;">
          <div class="contact-info-row">
            <div class="contact-info-icon">✉</div>
            <div>
              <p class="contact-info-label">Email</p>
              <a href="mailto:hello@asocreative.studio" class="contact-info-value">hello@asocreative.studio</a>
            </div>
          </div>
          <div class="contact-info-row">
            <div class="contact-info-icon">📍</div>
            <div>
              <p class="contact-info-label">Location</p>
              <p class="contact-info-value">Nigeria · Available Worldwide</p>
            </div>
          </div>
          <div class="contact-info-row">
            <div class="contact-info-icon">⚡</div>
            <div>
              <p class="contact-info-label">Response Time</p>
              <p class="contact-info-value">Within 24 hours</p>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:40px;">
          <a href="#" class="social-icon-btn" aria-label="Twitter">𝕏</a>
          <a href="#" class="social-icon-btn" aria-label="Instagram">ig</a>
          <a href="#" class="social-icon-btn" aria-label="LinkedIn">in</a>
          <a href="#" class="social-icon-btn" aria-label="Dribbble">dr</a>
        </div>

        <!-- Calendly Box -->
        <div style="padding:24px; border-radius:16px; border:1px solid rgba(201,162,39,0.25); background:rgba(201,162,39,0.05);">
          <p style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:15px; color:#fafafa; margin:0 0 6px;">Prefer to book a call?</p>
          <p style="font-family:'Inter',sans-serif; font-size:13px; color:#a1a1aa; margin:0 0 16px; line-height:1.5;">Schedule a free 30-minute discovery call directly on my calendar.</p>
          <a href="https://calendly.com/YOUR_CALENDLY_LINK" id="calendly-btn" target="_blank" rel="noopener noreferrer">
            Book a Call →
          </a>
        </div>

      </div>

      <!-- ── RIGHT: Form ── -->
      <div id="contact-right" style="opacity:0; transform:translateY(32px);">
        <div style="background:#0a0a0a; border:1px solid #27272a; border-radius:20px; padding:40px;">

          <h3 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:20px; color:#fafafa; margin:0 0 8px;">Send a Message</h3>
          <p style="font-family:'Inter',sans-serif; font-size:13px; color:#52525b; margin:0 0 32px;">I'll respond within 24 hours.</p>

          <form id="contact-form" style="display:flex; flex-direction:column; gap:20px;">

            <!-- Hidden Web3Forms key -->
            <input type="hidden" name="access_key" value="b39c434e-aa8b-439d-adf0-24cb80deb590" />
            <input type="hidden" name="subject" value="New Project Inquiry — ASO Creative Studio" />
            <input type="hidden" name="from_name" value="ASO Portfolio Contact Form" />
            <input type="checkbox" name="botcheck" style="display:none;" />

            <!-- Name -->
            <div class="form-group">
              <label class="form-label">Your Name *</label>
              <input
                type="text"
                name="name"
                placeholder="e.g. Victoria Abiodun"
                class="form-input"
                required
              />
            </div>

            <!-- Email -->
            <div class="form-group">
              <label class="form-label">Email Address *</label>
              <input
                type="email"
                name="email"
                placeholder="hello@yourbrand.com"
                class="form-input"
                required
              />
            </div>

            <!-- Service -->
            <div class="form-group">
              <label class="form-label">Service Needed *</label>
              <select name="service" class="form-input" required>
                <option value="" disabled selected>Select a service...</option>
                <option value="AI Video">AI Video Creation</option>
                <option value="Graphics">Graphic Design</option>
                <option value="Web Dev">Web Development</option>
                <option value="AI Automation">AI Automation</option>
                <option value="Multiple">Multiple Services</option>
              </select>
            </div>

            <!-- Message -->
            <div class="form-group">
              <label class="form-label">Your Message *</label>
              <textarea
                name="message"
                placeholder="Tell me about your project — goals, timeline, budget..."
                class="form-input"
                rows="5"
                required
                style="resize:vertical;"
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" id="form-submit-btn">
              <span id="btn-text">Send Message →</span>
              <span id="btn-spinner" style="display:none;">Sending...</span>
            </button>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Contact info */
  .contact-info-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .contact-info-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(201,162,39,0.08);
    border: 1px solid rgba(201,162,39,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .contact-info-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #52525b;
    margin: 0 0 2px;
  }
  .contact-info-value {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    color: #a1a1aa;
    margin: 0;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  a.contact-info-value:hover { color: #c9a227; }

  /* Social icons */
  .social-icon-btn {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid #27272a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a1a1aa;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .social-icon-btn:hover {
    border-color: rgba(201,162,39,0.4);
    color: #c9a227;
    background: rgba(201,162,39,0.08);
  }

  /* Calendly button */
  #calendly-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 9999px;
    border: 1px solid rgba(201,162,39,0.4);
    background: transparent;
    color: #c9a227;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  #calendly-btn:hover {
    background: rgba(201,162,39,0.1);
    border-color: #c9a227;
  }

  /* Form */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #a1a1aa;
  }
  .form-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid #27272a;
    background: #111111;
    color: #fafafa;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
    appearance: none;
    -webkit-appearance: none;
  }
  .form-input:focus {
    border-color: rgba(201,162,39,0.5);
    box-shadow: 0 0 0 3px rgba(201,162,39,0.08);
  }
  .form-input::placeholder { color: #3f3f46; }
  .form-input option { background: #111111; color: #fafafa; }

  /* Submit button */
  #form-submit-btn {
    width: 100%;
    padding: 16px 32px;
    border-radius: 9999px;
    border: none;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    color: #050505;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 24px rgba(201,162,39,0.3);
  }
  #form-submit-btn:hover {
    box-shadow: 0 0 40px rgba(245,158,11,0.5);
    transform: translateY(-1px);
  }
  #form-submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Toast */
  .toast {
    padding: 16px 20px;
    border-radius: 12px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: auto;
    animation: toastIn 0.3s ease;
    min-width: 280px;
    max-width: 360px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .toast-success {
    background: #052e16;
    border: 1px solid rgba(34,197,94,0.3);
    color: #86efac;
  }
  .toast-error {
    background: #2d0a0a;
    border: 1px solid rgba(239,68,68,0.3);
    color: #fca5a5;
  }
  @keyframes toastIn {
    from { opacity:0; transform:translateX(20px); }
    to   { opacity:1; transform:translateX(0); }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
  }
</style>

<script>
  window.addEventListener("load", () => {
    /* GSAP entrance */
    if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
      gsap.to("#contact-left", {
        opacity: 1, y: 0, duration: 0.7, ease: "power3.out",
        scrollTrigger: { trigger: "#contact", start: "top 80%" },
      });
      gsap.to("#contact-right", {
        opacity: 1, y: 0, duration: 0.7, ease: "power3.out", delay: 0.15,
        scrollTrigger: { trigger: "#contact", start: "top 80%" },
      });
    } else {
      const el = document.getElementById("contact-left");
      const er = document.getElementById("contact-right");
      if (el) { el.style.opacity = "1"; el.style.transform = "none"; }
      if (er) { er.style.opacity = "1"; er.style.transform = "none"; }
    }

    /* Toast helper */
    function showToast(message: string, type: "success" | "error") {
      const container = document.getElementById("toast-container");
      if (!container) return;
      const toast = document.createElement("div");
      toast.className = `toast toast-${type}`;
      toast.innerHTML = `<span>${type === "success" ? "✓" : "✕"}</span> ${message}`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transition = "opacity 0.3s ease";
        setTimeout(() => toast.remove(), 300);
      }, 5000);
    }

    /* Form submission */
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById("form-submit-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const btnSpinner = document.getElementById("btn-spinner");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      /* Loading state */
      submitBtn.disabled = true;
      if (btnText)    btnText.style.display    = "none";
      if (btnSpinner) btnSpinner.style.display = "inline";

      try {
        const formData = new FormData(form);
        const object: Record<string, string> = {};
        formData.forEach((value, key) => { object[key] = value.toString(); });

        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", "Accept": "application/json" },
          body: JSON.stringify(object),
        });

        const result = await response.json();

        if (result.success) {
          showToast("Message sent! I'll respond within 24 hours.", "success");
          form.reset();
        } else {
          throw new Error(result.message ?? "Submission failed");
        }
      } catch (err) {
        showToast("Something went wrong. Please try again.", "error");
      } finally {
        submitBtn.disabled = false;
        if (btnText)    btnText.style.display    = "inline";
        if (btnSpinner) btnSpinner.style.display = "none";
      }
    });
  });
</script>