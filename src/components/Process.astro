---
import SectionLabel from './ui/SectionLabel.astro';

var steps = [
  {
    icon: 'search',
    number: '01',
    title: 'Discovery',
    description: 'We dive deep into your brand, goals, and audience to craft the perfect strategy for your project.',
  },
  {
    icon: 'sparkles',
    number: '02',
    title: 'Creation',
    description: 'I design, build, and animate — bringing your vision to life with precision and creative excellence.',
  },
  {
    icon: 'rocket',
    number: '03',
    title: 'Delivery',
    description: 'Polished, tested, and ready to launch. Plus ongoing support whenever you need it.',
  },
];
---

<section id="process" class="reveal-section py-[120px] bg-aso-surface/50">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">

    <SectionLabel number="03" text="How It Works" />
    <h2 class="mt-6 font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-aso-text mb-16">
      My <span class="gradient-text">Process</span>
    </h2>

    <!-- Single layout — works on all screen sizes, no responsive duplication -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      {steps.map(function(step) {
        return (
          <div class="flex lg:flex-col items-start lg:items-center gap-5 lg:gap-0 lg:text-center group">
            <!-- Icon circle -->
            <div class="relative flex-shrink-0 w-20 h-20 lg:w-28 lg:h-28 rounded-2xl bg-aso-elevated border-2 border-aso-border flex items-center justify-center lg:mx-auto lg:mb-6 hover:border-aso-gold hover:gold-glow transition-all duration-500">
              <span class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-aso-gold text-aso-black text-xs font-bold flex items-center justify-center font-mono">
                {step.number}
              </span>
              <i data-lucide={step.icon} class="w-8 h-8 text-aso-gold"></i>
            </div>
            <!-- Text -->
            <div>
              <h3 class="font-heading font-semibold text-xl text-aso-text mb-3">{step.title}</h3>
              <p class="text-aso-text-secondary leading-relaxed">{step.description}</p>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>---
