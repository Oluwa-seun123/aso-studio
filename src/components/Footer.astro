---
// Footer.astro
---

<footer class="bg-aso-black border-t border-aso-border py-12">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Logo -->
      <a href="#hero" class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-lg bg-aso-gold flex items-center justify-center text-aso-black font-heading font-bold text-sm transition-all duration-300 group-hover:gold-glow">
          ASO
        </div>
        <span class="font-heading font-medium text-aso-text-secondary text-sm">Creative Studio</span>
      </a>

      <!-- Copyright -->
      <p class="text-aso-text-muted text-sm text-center font-mono">
        &copy; 2026 ASO Creative Studio &mdash; All rights reserved.
      </p>

      <!-- Back to top -->
      <button
        id="back-to-top"
        class="group flex items-center gap-2 text-aso-text-muted hover:text-aso-gold transition-colors duration-300 text-sm font-heading bg-transparent border-none cursor-pointer"
        aria-label="Back to top"
      >
        Back to top
        <i data-lucide="arrow-up" class="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-1"></i>
      </button>

    </div>
  </div>
</footer>

<script is:inline>
  document.getElementById('back-to-top').addEventListener('click', function () {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
