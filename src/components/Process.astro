---
// src/components/Process.astro
---
<section id="process" class="py-32 bg-aso-surface relative overflow-hidden border-t border-aso-border">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10">
    
    <div class="mb-20 text-center animate-on-scroll">
      <span class="font-label text-[11px] text-aso-gold uppercase tracking-[0.25em]">Execution Framework</span>
      <h2 class="text-3xl sm:text-5xl font-heading font-bold text-aso-text mt-2">The Work Process</h2>
    </div>

    <div class="process-line-container max-w-3xl mx-auto mt-16 pl-8 md:pl-0">
      
      <div class="process-animated-line"></div>

      <div class="relative md:grid md:grid-cols-2 gap-8 mb-16 animate-on-scroll">
        <div class="md:text-right md:pr-12 pb-4">
          <span class="text-xs font-label text-aso-gold bg-aso-gold/10 px-3 py-1 rounded-full">01</span>
          <h3 class="text-xl font-bold font-heading text-aso-text mt-3">Architecture & Strategy</h3>
          <p class="text-sm text-aso-text-secondary mt-2">Deep layout structural blueprinting and design asset scoping before rendering frames.</p>
        </div>
        <div class="hidden md:block"></div>
      </div>

      <div class="relative md:grid md:grid-cols-2 gap-8 mb-16 animate-on-scroll">
        <div class="hidden md:block"></div>
        <div class="md:pl-12 pb-4">
          <span class="text-xs font-label text-aso-gold bg-aso-gold/10 px-3 py-1 rounded-full">02</span>
          <h3 class="text-xl font-bold font-heading text-aso-text mt-3">Creative Synthesis</h3>
          <p class="text-sm text-aso-text-secondary mt-2">Injecting cinematic components, asset vectors, and rich imagery pipelines safely.</p>
        </div>
      </div>

    </div>
  </div>
</section>

          <!-- Content -->
          <div class="pt-1">
            <h3 class="font-heading font-bold text-lg text-aso-text mb-0.5">{title}</h3>
            <p class="font-label text-[10px] tracking-[0.2em] uppercase text-aso-gold mb-3">{subtitle}</p>
            <p class="font-body text-sm text-aso-text-secondary leading-relaxed mb-4">{desc}</p>
            <ul class="flex flex-col gap-1.5" role="list">
              {bullets.map((bullet) => (
                <li class="flex items-center gap-2 font-body text-xs text-aso-text-muted">
                  <span class="w-1 h-1 rounded-full bg-aso-gold flex-shrink-0"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const processSection = document.getElementById('process');
    const desktopLine = document.getElementById('desktop-process-line');
    const mobileLines = document.querySelectorAll('.mobile-process-line');

    if (!processSection) return;

    let ticking = false;

    const computeLineProgress = () => {
      const rect = processSection.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      
      // Calculate start relative to when the top of the container hits the screen center
      const startTrigger = rect.top - viewportCenter;
      const distanceScrolled = -startTrigger;
      const totalScrollable = rect.height;
      
      let progressRaw = distanceScrolled / totalScrollable;
      const progress = Math.max(0, Math.min(1, progressRaw));

      if (desktopLine && window.innerWidth >= 1024) {
        desktopLine.style.transform = `scaleX(${progress})`;
      }

      if (mobileLines.length > 0 && window.innerWidth < 1024) {
        const segmentCost = 1 / mobileLines.length;
        
        mobileLines.forEach((line, index) => {
          const segmentStart = index * segmentCost;
          const segmentEnd = (index + 1) * segmentCost;
          
          let localProgress = (progress - segmentStart) / (segmentEnd - segmentStart);
          localProgress = Math.max(0, Math.min(1, localProgress));
          
          line.style.transform = `scaleY(${localProgress})`;
        });
      }

      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          computeLineProgress();
        });
        ticking = true;
      }
    }, { passive: true });

    computeLineProgress();
  });
</script>
