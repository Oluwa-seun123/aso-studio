---
// Footer.astro
---

<footer
  style="position:relative; background:#050505; border-top:1px solid #27272a; padding:40px 0;"
>
  <!-- Top gold line -->
  <div
    style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:400px; height:1px; background:linear-gradient(90deg,transparent,rgba(201,162,39,0.4),transparent);"
    aria-hidden="true"
  ></div>

  <div style="max-width:1280px; margin:0 auto; padding:0 2.5rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:24px;">

      <!-- LEFT: Logo -->
      <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none;">
        <div style="width:36px; height:36px; border-radius:8px; background:linear-gradient(135deg,#c9a227,#f59e0b); display:flex; align-items:center; justify-content:center; font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.1em; color:#050505; flex-shrink:0;">
          ASO
        </div>
        <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px; color:#a1a1aa; letter-spacing:0.02em;">
          Creative Studio
        </span>
      </a>

      <!-- CENTER: Copyright -->
      <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:#52525b; letter-spacing:0.08em; margin:0; text-align:center;">
        © 2026 ASO Creative Studio. All rights reserved.
      </p>

      <!-- RIGHT: Back to top -->
      <button id="back-to-top" aria-label="Back to top">
        Back to top ↑
      </button>

    </div>
  </div>
</footer>

<style>
  #back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 9999px;
    border: 1px solid #27272a;
    background: transparent;
    color: #a1a1aa;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 500;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  #back-to-top:hover {
    border-color: rgba(201,162,39,0.4);
    color: #c9a227;
    background: rgba(201,162,39,0.06);
  }

  @media (max-width: 640px) {
    footer > div > div {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>