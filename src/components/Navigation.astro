---
const navLinks = [
  { name: "Work",     href: "#work"     },
  { name: "Services", href: "#services" },
  { name: "Process",  href: "#process"  },
  { name: "About",    href: "#about"    },
  { name: "Contact",  href: "#contact"  },
];
---

<nav id="main-nav" style="position:fixed; top:0; left:0; right:0; z-index:50; transition:background 0.3s ease, box-shadow 0.3s ease;">

  <div style="max-width:1280px; margin:0 auto; padding:0 2.5rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; height:72px;">

      <!-- Logo -->
      <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none;">
        <div style="width:40px; height:40px; border-radius:10px; background:linear-gradient(135deg,#c9a227,#f59e0b); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:12px; letter-spacing:0.15em; color:#050505; flex-shrink:0;">
          ASO
        </div>
        <div style="display:flex; flex-direction:column; line-height:1;">
          <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:15px; color:#fafafa;">Creative Studio</span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#52525b; letter-spacing:0.2em; text-transform:uppercase; margin-top:2px;">AI · Design · Web</span>
        </div>
      </a>

      <!-- Desktop Links -->
      <ul id="nav-links" style="display:flex; align-items:center; gap:32px; list-style:none; margin:0; padding:0;">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="aso-navlink">{link.name}</a>
          </li>
        ))}
      </ul>

      <!-- Desktop Right -->
      <div id="nav-right" style="display:flex; align-items:center; gap:12px;">
        <button id="theme-toggle" class="aso-theme-btn" aria-label="Toggle theme">🌙</button>
        <a href="#contact" class="aso-nav-cta">Start a Project</a>
      </div>

      <!-- Hamburger -->
      <button id="mobile-menu-btn" class="aso-hamburger" aria-label="Open menu">
        <span class="aso-ham-line"></span>
        <span class="aso-ham-line"></span>
        <span class="aso-ham-line aso-ham-short"></span>
      </button>

    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div id="mobile-menu" class="aso-mobile-overlay">
  <button id="mobile-close" class="aso-mobile-close">✕</button>
  <ul class="aso-mobile-list">
    {navLinks.map((link) => (
      <li><a href={link.href} class="aso-mobile-link">{link.name}</a></li>
    ))}
  </ul>
  <a href="#contact" class="aso-mobile-cta">Start a Project</a>
</div>

<style is:global>
  #main-nav.nav-scrolled {
    background: rgba(5, 5, 5, 0.92);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(39, 39, 42, 0.6);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
  }

  .aso-navlink {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #a1a1aa;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 4px;
  }
  .aso-navlink:hover {
    color: #fafafa;
  }
  .aso-navlink::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    height: 1px;
    width: 0;
    background: #c9a227;
    transition: width 0.3s ease;
  }
  .aso-navlink:hover::after {
    width: 100%;
  }

  .aso-theme-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid #27272a;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: all 0.2s ease;
  }
  .aso-theme-btn:hover {
    border-color: rgba(201, 162, 39, 0.4);
    background: rgba(201, 162, 39, 0.06);
  }

  .aso-nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #050505;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(201, 162, 39, 0.3);
    transition: all 0.3s ease;
  }
  .aso-nav-cta:hover {
    box-shadow: 0 0 32px rgba(245, 158, 11, 0.5);
    transform: translateY(-1px);
  }

  .aso-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .aso-ham-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background: #fafafa;
    border-radius: 2px;
  }
  .aso-ham-short {
    width: 16px;
    background: #c9a227;
  }

  .aso-mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 40;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(5, 5, 5, 0.97);
    backdrop-filter: blur(20px);
  }
  .aso-mobile-close {
    position: absolute;
    top: 24px;
    right: 24px;
    background: none;
    border: none;
    color: #a1a1aa;
    font-size: 24px;
    cursor: pointer;
  }
  .aso-mobile-list {
    list-style: none;
    margin: 0 0 40px;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  .aso-mobile-link {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 2.25rem;
    color: #fafafa;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .aso-mobile-link:hover {
    color: #c9a227;
  }
  .aso-mobile-cta {
    display: inline-flex;
    align-items: center;
    padding: 16px 40px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a227, #f59e0b);
    color: #050505;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
  }

  @media (max-width: 1023px) {
    #nav-links  { display: none !important; }
    #nav-right  { display: none !important; }
    .aso-hamburger { display: flex !important; }
  }
</style>

<script is:inline>
  var menuBtn   = document.getElementById('mobile-menu-btn');
  var closeBtn  = document.getElementById('mobile-close');
  var mobileMenu = document.getElementById('mobile-menu');
  var mobileLinks = document.querySelectorAll('.aso-mobile-link, .aso-mobile-cta');

  function openMenu() {
    if (mobileMenu) {
      mobileMenu.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  }
  function closeMenu() {
    if (mobileMenu) {
      mobileMenu.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  if (menuBtn) menuBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  mobileLinks.forEach(function(link) {
    link.addEventListener('click', closeMenu);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });

  var mainNav = document.getElementById('main-nav');
  window.addEventListener('scroll', function() {
    if (!mainNav) return;
    if (window.scrollY > 80) {
      mainNav.classList.add('nav-scrolled');
    } else {
      mainNav.classList.remove('nav-scrolled');
    }
  }, { passive: true });

  var themeBtn = document.getElementById('theme-toggle');

  function getSavedTheme() {
    try {
      return localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    } catch(e) {
      return 'dark';
    }
  }

  function applyTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    if (themeBtn) themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
  }

  applyTheme(getSavedTheme());

  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      var current = getSavedTheme();
      var next = current === 'dark' ? 'light' : 'dark';
      try { localStorage.setItem('theme', next); } catch(e) {}
      applyTheme(next);
    });
  }
</script>
